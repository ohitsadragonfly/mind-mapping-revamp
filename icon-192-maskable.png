const WORD_EFFECT=new Map();  // positive effect type: 'water', 'wave', 'shock'
Object.values(CATEGORY_DATA).forEach(d=>{
  d.words.forEach(w=>{
    WORD_EMOJI.set(w.name,w.emoji);
    WORD_KIND.set(w.name,'neg');
  });
  d.pos.forEach(p=>{
    WORD_KIND.set(p.name,'pos');
    WORD_EFFECT.set(p.name,p.effect);
  });
});
CORE_POS.forEach(w=>{
  WORD_KIND.set(w,'pos');
});

// Fisher-Yates shuffle (per user's spec)
function shuffleArray(array){
  for(let i=array.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [array[i],array[j]]=[array[j],array[i]];
  }
  return array;
}

