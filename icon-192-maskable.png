<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<title>Mind Real Estate — Train Your Mental Habits</title>

<!-- SEO / App description -->
<meta name="description" content="Mind Real Estate is a meditative habit visualizer. Choose mindful thoughts, watch negative habits stack up, and clear them with positive ones to reach flow state." />
<meta name="keywords" content="mindfulness, habits, mental health, meditation, focus, productivity, wellness" />
<meta name="author" content="Mind Real Estate" />
<meta name="theme-color" content="#000000" />
<meta name="color-scheme" content="dark" />

<!-- iOS PWA -->
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Mind Real Estate" />
<meta name="format-detection" content="telephone=no" />

<!-- Android PWA -->
<meta name="mobile-web-app-capable" content="yes" />
<meta name="application-name" content="Mind Real Estate" />

<!-- Open Graph (social previews) -->
<meta property="og:title" content="Mind Real Estate" />
<meta property="og:description" content="A meditative habit visualizer. Train your mind." />
<meta property="og:type" content="website" />
<meta property="og:image" content="icon-512.png" />

<!-- PWA manifest -->
<link rel="manifest" href="manifest.json" />

<!-- Icons -->
<link rel="icon" type="image/png" sizes="32x32" href="icon-32.png" />
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="icon-512.png" />
<link rel="apple-touch-icon" href="icon-180.png" />
<link rel="apple-touch-icon" sizes="180x180" href="icon-180.png" />

<!-- iOS splash screens (Apple wants per-device sizes; one fallback shown here) -->
<link rel="apple-touch-startup-image" href="splash-1290x2796.png" media="(device-width: 430px) and (device-height: 932px) and (-webkit-device-pixel-ratio: 3)" />
<link rel="apple-touch-startup-image" href="splash-1170x2532.png" media="(device-width: 390px) and (device-height: 844px) and (-webkit-device-pixel-ratio: 3)" />
<link rel="apple-touch-startup-image" href="splash-1125x2436.png" media="(device-width: 375px) and (device-height: 812px) and (-webkit-device-pixel-ratio: 3)" />

<style>
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{width:100%;height:100%;background:#000;color:#fff;overflow:hidden;
    font-family:ui-monospace,Menlo,Monaco,monospace;-webkit-user-select:none;user-select:none;
    -webkit-tap-highlight-color:transparent;touch-action:none;overscroll-behavior:none}
  canvas{display:block;position:absolute;inset:0}
  #introCanvas{z-index:20;pointer-events:all}
  #introCanvas.gone{opacity:0;pointer-events:none;transition:opacity .8s ease}

  .hud{position:fixed;left:0;right:0;padding:14px 16px;display:flex;
    justify-content:space-between;font-size:9px;letter-spacing:.28em;
    color:rgba(255,255,255,.55);text-transform:uppercase;pointer-events:none;z-index:10}
  #hudTop{top:0}
  #hudBot{bottom:auto;top:auto;left:0;right:0;flex-direction:column;gap:5px;
    padding:6px 18px}
  /* Position will be set inline via JS based on brain bottom position */
  #bar{width:100%;height:1px;background:rgba(255,255,255,.1);overflow:hidden}
  #fill{height:100%;width:0%;background:linear-gradient(90deg,#4FC3F7,#B3E5FC);
    transition:width .5s ease;box-shadow:0 0 10px #4FC3F7}
  #row{display:flex;justify-content:space-between;align-items:center;gap:10px}
  #eraseCount{font-size:8px;letter-spacing:.32em;color:rgba(79,195,247,.75);
    text-shadow:0 0 6px rgba(79,195,247,.5)}
  /* PROCRASTINATE BUTTON — red glowing pill that drops 5 negatives + clears 2 biggest */
  #procBtn{display:none;margin:6px auto 0;padding:9px 22px;
    font-family:inherit;font-size:10px;letter-spacing:.4em;font-weight:600;
    color:#FFD0D0;background:linear-gradient(180deg,rgba(255,40,40,.18),rgba(180,10,10,.32));
    border:1px solid rgba(255,90,90,.7);border-radius:4px;
    text-transform:uppercase;cursor:pointer;pointer-events:auto;
    box-shadow:0 0 14px rgba(255,82,82,.45),inset 0 0 12px rgba(255,82,82,.18);
    text-shadow:0 0 6px rgba(255,120,120,.85);
    transition:all .15s ease;touch-action:manipulation;
    display:flex;flex-direction:column;align-items:center;gap:2px}
  #procBtn small{font-size:6.5px;letter-spacing:.22em;color:rgba(255,200,200,.65);
    text-shadow:none;font-weight:400}
  #procBtn:active{transform:scale(.95);background:linear-gradient(180deg,rgba(255,60,60,.4),rgba(200,20,20,.5))}
  #procBtn.cooldown{opacity:.35;pointer-events:none;filter:grayscale(.5)}
  #procBtn.show{display:flex}

  /* MENU BTN */
  #menuBtn{position:fixed;top:38px;right:14px;z-index:50;
    background:rgba(0,0,0,.7);border:1px solid rgba(255,255,255,.4);
    color:#fff;font-family:inherit;font-size:9px;
    letter-spacing:.35em;padding:9px 13px;text-transform:uppercase;
    cursor:pointer;transition:all .2s ease;display:none;
    touch-action:manipulation;pointer-events:auto}
  #menuBtn.show{display:block}
  #menuBtn:active,#menuBtn:hover{background:rgba(255,255,255,.15);border-color:#fff}

  /* STREAK POPUP - big glowing "COMBO X3" style */
  #streakPopup{position:fixed;top:38%;left:50%;transform:translateX(-50%) scale(.4);
    font-family:'Impact','Arial Black',sans-serif;font-size:42px;font-weight:900;
    letter-spacing:.06em;color:#fff;
    background:linear-gradient(180deg,#FF4FB8 0%,#8B6FFF 50%,#4FC3F7 100%);
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
    filter:drop-shadow(0 0 16px rgba(255,79,184,.7)) drop-shadow(0 0 28px rgba(79,195,247,.6));
    pointer-events:none;z-index:40;opacity:0;
    transition:opacity .15s ease,transform .35s cubic-bezier(.34,1.8,.64,1);
    text-transform:uppercase;white-space:nowrap;text-align:center}
  #streakPopup.pop{opacity:1;transform:translateX(-50%) scale(1)}

  /* MENU POPUP */
  #menuPopup{position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:60;
    display:none;align-items:center;justify-content:center;flex-direction:column;
    gap:14px;padding:24px;touch-action:manipulation;pointer-events:auto}
  #menuPopup.show{display:flex}
  #menuPopup h2{font-size:11px;letter-spacing:.45em;font-weight:400;
    color:rgba(255,255,255,.6);text-transform:uppercase;margin-bottom:12px}
  .menuOpt{background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff;
    font-family:inherit;font-size:12px;letter-spacing:.32em;padding:18px 24px;
    text-transform:uppercase;cursor:pointer;min-width:260px;text-align:left;
    transition:all .2s ease;touch-action:manipulation;pointer-events:auto}
  .menuOpt:active,.menuOpt:hover{background:rgba(255,255,255,.10);border-color:#fff}
  .menuOpt small{display:block;margin-top:5px;font-size:8px;letter-spacing:.3em;
    color:rgba(255,255,255,.5)}
  #menuClose{margin-top:14px;font-size:10px;letter-spacing:.4em;
    color:rgba(255,255,255,.55);background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.2);
    font-family:inherit;text-transform:uppercase;cursor:pointer;padding:10px 20px;
    touch-action:manipulation;pointer-events:auto}

  /* SETTINGS POPUP */
  #settingsPopup{position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:65;
    display:none;align-items:center;justify-content:center;flex-direction:column;
    gap:18px;padding:24px;touch-action:manipulation;pointer-events:auto}
  #settingsPopup.show{display:flex}
  #settingsPopup h2{font-size:11px;letter-spacing:.45em;font-weight:400;
    color:#fff;margin-bottom:8px;text-transform:uppercase}
  .settingRow{display:flex;align-items:center;justify-content:space-between;
    width:100%;max-width:280px;padding:14px 16px;
    background:rgba(255,255,255,.04);border:1px solid rgba(79,195,247,.25);
    border-radius:4px}
  .settingLabel{font-size:10px;letter-spacing:.32em;color:#fff;
    text-transform:uppercase;display:flex;flex-direction:column;gap:3px}
  .settingLabel small{font-size:8px;letter-spacing:.3em;color:rgba(79,195,247,.7)}
  /* Toggle switch */
  .toggleSwitch{position:relative;display:inline-block;width:44px;height:22px;flex-shrink:0}
  .toggleSwitch input{opacity:0;width:0;height:0}
  .toggleSlider{position:absolute;cursor:pointer;inset:0;background:rgba(255,255,255,.1);
    border:1px solid rgba(255,255,255,.2);transition:.25s;border-radius:11px}
  .toggleSlider:before{position:absolute;content:'';height:14px;width:14px;left:3px;top:50%;
    margin-top:-7px;background:rgba(255,255,255,.6);transition:.25s;border-radius:50%}
  .toggleSwitch input:checked + .toggleSlider{background:rgba(79,195,247,.25);
    border-color:#4FC3F7;box-shadow:0 0 8px rgba(79,195,247,.4)}
  .toggleSwitch input:checked + .toggleSlider:before{transform:translateX(22px);
    background:#4FC3F7;box-shadow:0 0 6px rgba(79,195,247,.7)}
  /* Volume slider */
  .volSlider{-webkit-appearance:none;appearance:none;width:120px;height:4px;
    background:rgba(255,255,255,.15);border-radius:2px;outline:none;cursor:pointer}
  .volSlider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;
    width:16px;height:16px;background:#4FC3F7;border-radius:50%;cursor:pointer;
    box-shadow:0 0 8px rgba(79,195,247,.7)}
  .volSlider::-moz-range-thumb{width:16px;height:16px;background:#4FC3F7;
    border-radius:50%;cursor:pointer;border:none;box-shadow:0 0 8px rgba(79,195,247,.7)}
  #settingsClose{margin-top:8px;font-size:10px;letter-spacing:.4em;
    color:rgba(255,255,255,.55);background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.2);
    font-family:inherit;text-transform:uppercase;cursor:pointer;padding:10px 20px}
  #settingsClose:active{background:rgba(255,255,255,.12)}

  /* SCREEN OVERLAYS (boot + intro) */
  .screen-overlay,#intro,#bootScreen{position:fixed;inset:0;background:#000;z-index:30;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    padding:24px;gap:12px;transition:opacity .5s ease;overflow-y:auto}
  .screen-overlay.gone,#intro.gone,#bootScreen.gone{opacity:0;pointer-events:none}
  /* Chrome-bevel title — heavy beveled MIND with cyan-glow REAL ESTATE */
  #intro h1,#bootScreen h1{display:flex;flex-direction:column;align-items:center;
    gap:2px;margin-bottom:14px;line-height:1}
  .title-mind{font-family:'Impact','Arial Black',sans-serif;font-size:54px;font-weight:900;
    letter-spacing:.04em;line-height:.92;text-transform:uppercase;
    background:linear-gradient(180deg,
      #ffffff 0%,
      #ffeaf5 8%,
      #ff95d2 20%,
      #FF4FB8 38%,
      #c45fff 55%,
      #8B6FFF 70%,
      #4FC3F7 88%,
      #B3E5FC 100%);
    -webkit-background-clip:text;background-clip:text;
    color:transparent;-webkit-text-fill-color:transparent;
    filter:
      drop-shadow(0 2px 0 rgba(20,5,40,.65))
      drop-shadow(0 4px 1px rgba(40,10,60,.4))
      drop-shadow(0 0 14px rgba(255,79,184,.55))
      drop-shadow(0 0 26px rgba(79,195,247,.4))
      drop-shadow(0 0 42px rgba(139,111,255,.25))}
  .title-real{font-family:'Impact','Arial Black',sans-serif;font-size:17px;font-weight:700;
    letter-spacing:.36em;color:#4FC3F7;text-transform:uppercase;
    text-shadow:
      0 0 10px rgba(79,195,247,.85),
      0 0 22px rgba(79,195,247,.45),
      0 1px 0 rgba(0,30,50,.6)}
  @media(min-width:680px){.title-mind{font-size:78px}.title-real{font-size:22px}}
  /* Legacy single-line title fallback (kept for safety) */
  #intro h1.legacy,#bootScreen h1.legacy{display:block;font-size:30px;letter-spacing:.18em}
  .subtitle,#intro p,#bootScreen p{font-size:9px;letter-spacing:.35em;color:rgba(180,200,230,.55);
    text-transform:uppercase;margin-bottom:16px;text-align:center;
    text-shadow:0 0 6px rgba(79,195,247,.3)}

  /* GALLERY WALL — grid of mind-map frames */
  .gallery-wall{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;
    width:100%;max-width:760px;padding:6px;margin-bottom:8px}
  @media(min-width:680px){.gallery-wall{grid-template-columns:repeat(3,1fr)}}

  .gallery-frame{background:rgba(10,10,10,.85);border:1px solid rgba(255,255,255,.18);
    aspect-ratio:4/3;padding:14px;display:flex;flex-direction:column;
    justify-content:space-between;cursor:pointer;color:#fff;
    transition:all .3s cubic-bezier(.16,1,.3,1);position:relative;overflow:hidden;
    font-family:inherit;text-align:left;
    opacity:0;transform:translateY(20px);animation:pop .5s ease forwards}
  .gallery-frame:active,.gallery-frame:hover{border-color:#4FC3F7;
    box-shadow:0 0 18px rgba(79,195,247,.25);transform:translateY(-2px)}
  .gallery-frame.cleared{border-color:rgba(79,195,247,.55);
    box-shadow:0 0 14px rgba(79,195,247,.15) inset}
  .gallery-frame.cleared::after{content:'◆ SYNCED';position:absolute;top:10px;right:12px;
    color:#4FC3F7;font-size:7px;letter-spacing:.25em;
    text-shadow:0 0 8px rgba(79,195,247,.7)}
  .frame-title{font-size:9px;letter-spacing:.25em;font-weight:600;
    text-transform:uppercase;margin-bottom:6px;color:#fff}
  .frame-desc{font-size:8px;color:rgba(255,255,255,.45);line-height:1.5;
    letter-spacing:.05em;text-transform:none}
  .frame-status{font-size:7px;letter-spacing:.2em;color:#4FC3F7;
    text-transform:uppercase;margin-top:auto;padding-top:8px;opacity:.8}

  /* Boot title button (special standalone) */
  #initSyncBtn{aspect-ratio:auto;padding:18px 32px;max-width:280px;width:100%;
    text-align:center;display:flex;flex-direction:column;gap:8px;align-items:center;
    border-color:rgba(255,255,255,.35)}
  #initSyncBtn .frame-title{text-align:center;width:100%;font-size:10px;
    text-shadow:0 0 6px rgba(255,255,255,.5)}
  #initSyncBtn .frame-status{text-align:center;width:100%;margin-top:0;padding-top:0}

  .gallery-frame:nth-child(1){animation-delay:.05s}
  .gallery-frame:nth-child(2){animation-delay:.12s}
  .gallery-frame:nth-child(3){animation-delay:.19s}
  .gallery-frame:nth-child(4){animation-delay:.26s}
  .gallery-frame:nth-child(5){animation-delay:.33s}
  @keyframes pop{to{opacity:1;transform:translateY(0)}}

  /* GAME OVER */
  #over{position:fixed;inset:0;background:radial-gradient(ellipse at center,#1a0a14 0%,#000 75%);
    z-index:40;display:none;align-items:center;justify-content:center;flex-direction:column;
    padding:24px;text-align:center;gap:8px}
  #over.show{display:flex}
  /* Title on over screen mirrors boot screen — scaled down and given entrance animation */
  .over-title{margin-bottom:18px;opacity:0;transform:translateY(14px);
    animation:overTitleIn .9s cubic-bezier(.16,1,.3,1) .15s forwards}
  .over-title .title-mind{font-size:48px}
  .over-title .title-real{font-size:15px}
  @media(min-width:680px){.over-title .title-mind{font-size:72px}.over-title .title-real{font-size:20px}}
  @keyframes overTitleIn{from{opacity:0;transform:translateY(14px) scale(.96)}
    to{opacity:1;transform:translateY(0) scale(1)}}
  #saying{font-size:14px;letter-spacing:.42em;font-weight:500;
    text-transform:uppercase;line-height:1.4;color:rgba(220,235,255,.85);
    text-shadow:0 0 10px rgba(79,195,247,.4);
    animation:flicker 1s ease}
  #subSaying{margin-top:20px;font-size:9px;letter-spacing:.4em;
    color:rgba(255,255,255,.4);text-transform:uppercase}
  @keyframes flicker{
    0%{opacity:0;transform:scale(.9)}
    20%{opacity:1}
    60%{opacity:.6}
    100%{opacity:1;transform:scale(1)}
  }

  /* scroll hint */
  #scrollHint{position:fixed;top:50%;right:8px;writing-mode:vertical-rl;
    font-size:8px;letter-spacing:.4em;color:rgba(255,255,255,.3);
    text-transform:uppercase;pointer-events:none;z-index:10;
    animation:pulse 2.4s ease-in-out infinite;transform:translateY(-50%)}
  @keyframes pulse{0%,100%{opacity:.15}50%{opacity:.55}}
</style>
</head>
<body>

<canvas id="introCanvas"></canvas>
<canvas id="g"></canvas>

<div class="hud" id="hudTop"><span id="cat">·</span><span id="ph">·</span></div>
<button id="menuBtn" aria-label="menu">MENU</button>
<div id="streakPopup"></div>

<!-- Background music. Add more files to TRACKS array in JS to rotate. -->
<audio id="bgMusic" loop preload="auto">
  <source src="audio/audio.mp3" type="audio/mpeg">
</audio>

<div id="menuPopup">
  <h2>menu</h2>
  <button class="menuOpt" id="goHomeBtn">Go Home<small>back to category screen</small></button>
  <button class="menuOpt" id="restartBtn">Restart<small>empty the brain · keep category</small></button>
  <button class="menuOpt" id="settingsBtn">Settings<small>sound · volume</small></button>
  <button id="menuClose">close</button>
</div>

<div id="settingsPopup">
  <h2>settings</h2>
  <div class="settingRow">
    <div class="settingLabel">Music
      <small id="musicStateLabel">on</small>
    </div>
    <label class="toggleSwitch">
      <input type="checkbox" id="musicToggle" checked>
      <span class="toggleSlider"></span>
    </label>
  </div>
  <div class="settingRow">
    <div class="settingLabel">Volume
      <small id="volumeLabel">50%</small>
    </div>
    <input type="range" id="volumeSlider" min="0" max="100" value="50" class="volSlider">
  </div>
  <button id="settingsClose">close</button>
</div>
<div class="hud" id="hudBot">
  <div id="row">
    <span>flow state</span>
    <span id="eraseCount">CLEARED 0000</span>
    <span id="pct">0%</span>
  </div>
  <div id="bar"><div id="fill"></div></div>
  <button id="procBtn" type="button">[ PROCRASTINATE ]<small>+5 thoughts · clears 2 biggest</small></button>
</div>
<div id="scrollHint">scroll</div>

<!-- ═══ INTRO CANVAS OVERLAY (replaces bootScreen) ═══
     The intro engine draws directly onto #introCanvas:
     Phase 0 → person screaming words; Phase 1 → zoom into brain;
     Phase 2 → mind-map 14 nodes; Phase 3 → hand selects 14→7→6;
     Phase 4 → zoom to category select. Tap anywhere to skip. -->
<div id="bootScreen" style="display:none"></div>

<div id="intro" class="screen-overlay gone" style="z-index:25;padding:18px 12px 10px">
  <h1 style="margin-bottom:6px;font-size:13px;letter-spacing:.4em">SELECT BRAIN NETWORK</h1>
  <p class="subtitle" style="margin-bottom:12px">Choose the cognitive system to clear — each network shapes how you think</p>
  <div class="gallery-wall" id="galleryWallGrid">
    <button class="gallery-frame" data-cat="quantum" style="border-color:rgba(255,105,180,.45)">
      <div><div class="frame-title" style="color:#FF69B4">⚡ SALIENCE NETWORK</div>
      <div class="frame-desc" style="font-size:8px;color:rgba(255,155,200,.65)">Detects threats, salient events &amp; switches cognitive control (dACC · AI · Amygdala)</div></div>
      <div class="frame-status" style="color:rgba(255,105,180,.6)">SN // PRESS TO ENTER</div>
    </button>
    <button class="gallery-frame" data-cat="self" style="border-color:rgba(180,100,255,.45)">
      <div><div class="frame-title" style="color:#B464FF">🌙 DEFAULT MODE</div>
      <div class="frame-desc" style="font-size:8px;color:rgba(200,155,255,.65)">Self-reflection, autobiographical memory &amp; mind-wandering (mPFC · PCC · Angular Gyrus)</div></div>
      <div class="frame-status" style="color:rgba(180,100,255,.6)">DMN // PRESS TO ENTER</div>
    </button>
    <button class="gallery-frame" data-cat="parenting" style="border-color:rgba(64,196,255,.45)">
      <div><div class="frame-title" style="color:#40C4FF">🎯 ATTENTION NETWORKS</div>
      <div class="frame-desc" style="font-size:8px;color:rgba(130,210,255,.65)">Top-down focus &amp; bottom-up reorienting (IPS · FEF · VFC · TPJ)</div></div>
      <div class="frame-status" style="color:rgba(64,196,255,.6)">DAN/VAN // PRESS TO ENTER</div>
    </button>
    <button class="gallery-frame" data-cat="engineer" style="border-color:rgba(100,230,130,.45)">
      <div><div class="frame-title" style="color:#64E682">🧩 EXECUTIVE CONTROL</div>
      <div class="frame-desc" style="font-size:8px;color:rgba(150,240,170,.65)">Working memory, planning &amp; goal-directed decisions (dlPFC · PPC · IPS)</div></div>
      <div class="frame-status" style="color:rgba(100,230,130,.6)">CEN // PRESS TO ENTER</div>
    </button>
    <button class="gallery-frame" data-cat="senior" style="border-color:rgba(255,200,50,.45)">
      <div><div class="frame-title" style="color:#FFC832">💎 REWARD NETWORK</div>
      <div class="frame-desc" style="font-size:8px;color:rgba(255,220,120,.65)">Dopamine, motivation &amp; reinforcement learning (VTA · NAc · OFC · Amygdala)</div></div>
      <div class="frame-status" style="color:rgba(255,200,50,.6)">MESOLIMBIC // PRESS TO ENTER</div>
    </button>
  </div>
</div>

<div id="over">
  <h1 class="over-title"><span class="title-mind">MIND</span><span class="title-real">REAL ESTATE</span></h1>
  <div id="saying">LET'S GET TO WORK</div>
  <div id="subSaying">tap to begin again</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js"></script>
<script>
"use strict";
// roundRect polyfill for older browsers (Safari < 15.4, older Android)
if(typeof CanvasRenderingContext2D!=='undefined'&&!CanvasRenderingContext2D.prototype.roundRect){
  CanvasRenderingContext2D.prototype.roundRect=function(x,y,w,h,r){
    const R=Math.min(r,w/2,h/2);
    this.moveTo(x+R,y);
    this.lineTo(x+w-R,y);this.quadraticCurveTo(x+w,y,x+w,y+R);
    this.lineTo(x+w,y+h-R);this.quadraticCurveTo(x+w,y+h,x+w-R,y+h);
    this.lineTo(x+R,y+h);this.quadraticCurveTo(x,y+h,x,y+h-R);
    this.lineTo(x,y+R);this.quadraticCurveTo(x,y,x+R,y);
    this.closePath();
    return this;
  };
}
const{Engine,Bodies,Body,Composite,Events}=Matter;

// ═══════════════════════════════════════════════════════════════
// INTRO CINEMATIC ENGINE
// 5-phase animated intro playing on #introCanvas overlay.
// Phase 0: Person holds head, words burst out of brain
// Phase 1: Camera zooms into brain silhouette
// Phase 2: Mind-map explodes — 14 thought-nodes orbit the brain
// Phase 3: Giant hand descends; taps once (14→7), taps again (7→6)
// Phase 4: Final zoom → category select fades in
// Tap / click anywhere to skip straight to category select.
// ═══════════════════════════════════════════════════════════════
const iCV=document.getElementById('introCanvas');
const iCX=iCV.getContext('2d');
let iW=0,iH=0,iDPR=1;
let iPhase=0,iT=0,iPrev=0;
let iRunning=true;
let _iRAF=0;

// Phase durations in ms
const IPH_DUR=[3200,2600,2000,0,600];  // phase3=0 (skip), phase4=quick fade
const NETWORK_COLORS={quantum:'#FF69B4',self:'#B464FF',parenting:'#40C4FF',engineer:'#64E682',senior:'#FFC832'};

// Thought words that burst from the person's head
const BURST_WORDS=[
  'doomscrolling','overthinking','procrastinating','comparing yourself',
  'negative self-talk','people pleasing','ruminating','fear of failure',
  'perfectionism','avoidance','isolation','late nights',
  'overspending','toxic loops','junk food','skipping workouts',
  'self-sabotage','catastrophizing',
];

// Word particles (phase 0)
let iParts=[];
function spawnBurstWords(cx,cy){
  iParts=[];
  BURST_WORDS.forEach((w,i)=>{
    const angle=(i/BURST_WORDS.length)*Math.PI*2-Math.PI/2;
    const speed=0.04+Math.random()*0.05;
    const dist=0.12+Math.random()*0.18; // fraction of screen
    iParts.push({
      word:w, x:cx, y:cy,
      tx:cx+Math.cos(angle)*iW*dist, ty:cy+Math.sin(angle)*iH*dist,
      progress:0, speed, size:Math.min(iW*0.026,11),
      col:`hsl(${340+Math.random()*60},90%,68%)`
    });
  });
}

// Mind-map nodes (phase 2-3)
let iNodes=[];
let iNodeVisible=14;
let iHandY=-200;
let iHandTap=0; // 0=approaching, 1=first tap done, 2=second tap done
let iHandX=0;

function buildNodes(){
  iNodes=[];
  const words=[...BURST_WORDS.slice(0,14)];
  for(let i=0;i<14;i++){
    const angle=(i/14)*Math.PI*2;
    const r=Math.min(iW,iH)*0.28;
    iNodes.push({
      word:words[i], angle, r,
      x:iW/2+Math.cos(angle)*r, y:iH*0.42+Math.sin(angle)*r*0.7,
      alive:true, dead:false, deadT:0
    });
  }
}

// Resize intro canvas to match window
function resizeIntro(){
  iDPR=Math.min(devicePixelRatio||1,2);
  iW=innerWidth; iH=innerHeight;
  iCV.width=iW*iDPR; iCV.height=iH*iDPR;
  iCV.style.width=iW+'px'; iCV.style.height=iH+'px';
  iCX.setTransform(iDPR,0,0,iDPR,0,0);
}

function drawPerson(ax,ay,scale,alpha){
  const cx=iCX;
  const s=scale;
  cx.globalAlpha=alpha;
  cx.strokeStyle='#fff';
  cx.lineWidth=Math.max(1.5,s*3.5);
  cx.lineCap='round';
  cx.lineJoin='round';
  // Head
  cx.beginPath();cx.arc(ax,ay-s*60,s*24,0,Math.PI*2);cx.stroke();
  // Body
  cx.beginPath();cx.moveTo(ax,ay-s*36);cx.lineTo(ax,ay+s*30);cx.stroke();
  // Arms UP — hands gripping sides of head (distress)
  cx.beginPath();cx.moveTo(ax,ay-s*20);
  cx.lineTo(ax-s*32,ay-s*50);cx.lineTo(ax-s*20,ay-s*72);cx.stroke();
  cx.beginPath();cx.moveTo(ax,ay-s*20);
  cx.lineTo(ax+s*32,ay-s*50);cx.lineTo(ax+s*20,ay-s*72);cx.stroke();
  // Legs
  cx.beginPath();cx.moveTo(ax,ay+s*30);cx.lineTo(ax-s*20,ay+s*76);cx.stroke();
  cx.beginPath();cx.moveTo(ax,ay+s*30);cx.lineTo(ax+s*20,ay+s*76);cx.stroke();
  // Screaming mouth (open oval, red)
  cx.fillStyle='#FF5252';
  cx.beginPath();
  cx.ellipse(ax,ay-s*52,s*12,s*8,0,0,Math.PI*2);cx.fill();
  // Eyes (wide)
  cx.fillStyle='#fff';
  cx.beginPath();cx.arc(ax-s*9,ay-s*65,s*5,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.arc(ax+s*9,ay-s*65,s*5,0,Math.PI*2);cx.fill();
  cx.fillStyle='#111';
  cx.beginPath();cx.arc(ax-s*9,ay-s*65,s*2.5,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.arc(ax+s*9,ay-s*65,s*2.5,0,Math.PI*2);cx.fill();
  cx.globalAlpha=1;
}

function drawBrainShape(bx,by,bw,bh,col,alpha,lineW){
  const cx=iCX;
  cx.globalAlpha=alpha;
  cx.strokeStyle=col; cx.lineWidth=lineW;
  cx.fillStyle='rgba(10,20,40,0.6)';
  // Same walnut brain path as HUD icon, scaled to bw/bh
  const sx=bw*0.5, sy=bh*0.5;
  cx.beginPath();
  cx.moveTo(bx-sx*0.16,by+sy*0.84);
  cx.bezierCurveTo(bx-sx*0.22,by+sy,bx-sx*0.70,by+sy*0.80,bx-sx*0.96,by+sy*0.24);
  cx.bezierCurveTo(bx-sx*1.10,by-sy*0.06,bx-sx*1.05,by-sy*0.78,bx-sx*0.66,by-sy*0.98);
  cx.bezierCurveTo(bx-sx*0.44,by-sy*1.10,bx-sx*0.14,by-sy*1.12,bx,by-sy*1.08);
  cx.bezierCurveTo(bx+sx*0.14,by-sy*1.12,bx+sx*0.44,by-sy*1.10,bx+sx*0.66,by-sy*0.98);
  cx.bezierCurveTo(bx+sx*1.05,by-sy*0.78,bx+sx*1.10,by-sy*0.06,bx+sx*0.96,by+sy*0.24);
  cx.bezierCurveTo(bx+sx*0.70,by+sy*0.80,bx+sx*0.22,by+sy,bx+sx*0.16,by+sy*0.84);
  cx.bezierCurveTo(bx+sx*0.11,by+sy*0.96,bx-sx*0.11,by+sy*0.96,bx-sx*0.16,by+sy*0.84);
  cx.closePath(); cx.fill(); cx.stroke();
  cx.globalAlpha=1;
}

function drawHandCursor(hx,hy,alpha){
  const cx=iCX;
  const s=Math.min(iW,iH)*0.12;
  cx.globalAlpha=alpha;
  cx.strokeStyle='rgba(255,255,255,.9)'; cx.lineWidth=2.5;
  cx.fillStyle='rgba(255,255,255,.15)';
  // Palm
  cx.beginPath();cx.ellipse(hx,hy+s*0.4,s*0.38,s*0.32,0,0,Math.PI*2);cx.fill();cx.stroke();
  // Index finger pointing down
  cx.beginPath();
  cx.moveTo(hx-s*0.06,hy+s*0.1);
  cx.lineTo(hx-s*0.1,hy-s*0.5);
  cx.quadraticCurveTo(hx,hy-s*0.72,hx+s*0.1,hy-s*0.5);
  cx.lineTo(hx+s*0.06,hy+s*0.1);
  cx.closePath(); cx.fill(); cx.stroke();
  // Other fingers curled
  cx.fillStyle='rgba(255,255,255,.2)';
  cx.strokeStyle='rgba(255,255,255,.6)';
  [-0.32,-0.22,0.22,0.32].forEach((dx,i)=>{
    const fy=hy+s*(0.05+i*0.04);
    cx.beginPath();
    cx.ellipse(hx+dx*s,fy,s*0.09,s*0.18,dx*0.3,0,Math.PI*2);
    cx.fill(); cx.stroke();
  });
  cx.globalAlpha=1;
}

// ──── PHASE DRAWERS ────────────────────────────────────────────

function iDrawPhase0(tMs){
  const t=tMs/1000;
  const prog=Math.min(1,tMs/IPH_DUR[0]);
  const cx=iCX;
  
  // Scanline bg
  cx.fillStyle='#030810';
  cx.fillRect(0,0,iW,iH);
  for(let y=0;y<iH;y+=5){cx.fillStyle='rgba(0,0,0,.08)';cx.fillRect(0,y,iW,2);}

  // Person — slightly to left of center, slightly below mid
  const px=iW*0.5, py=iH*0.55;
  const s=Math.min(iW,iH)*0.0055;
  drawPerson(px,py,s,Math.min(1,tMs/600));

  // Word particles burst outward from head
  if(tMs>300){
    if(iParts.length===0) spawnBurstWords(px,py-s*80);
    iParts.forEach(p=>{
      p.progress=Math.min(1,p.progress+p.speed*(16/1000)*5);
      const ex=p.x+(p.tx-p.x)*p.progress;
      const ey=p.y+(p.ty-p.y)*p.progress;
      const fade=p.progress<0.8?1:1-(p.progress-0.8)/0.2;
      cx.globalAlpha=fade*Math.min(1,tMs/500);
      cx.fillStyle=p.col;
      cx.font=`bold ${p.size}px monospace`;
      cx.textAlign='center';
      cx.shadowColor=p.col; cx.shadowBlur=6;
      cx.fillText(p.word,ex,ey);
      cx.shadowBlur=0;
      cx.globalAlpha=1;
    });
  }
  
  // "IT'S TOO MANY CHOICES!" text
  if(tMs>500){
    const yell=Math.min(1,(tMs-500)/800);
    cx.globalAlpha=yell;
    cx.fillStyle='#FF5252';
    cx.font=`bold ${Math.min(iW*0.062,26)}px monospace`;
    cx.textAlign='center';
    cx.shadowColor='#FF2020'; cx.shadowBlur=16+Math.sin(t*12)*6;
    cx.fillText("IT'S TOO MANY CHOICES!",iW/2,iH*0.14);
    cx.shadowBlur=0; cx.globalAlpha=1;
  }

  // Sub text
  if(tMs>1800){
    const sub=Math.min(1,(tMs-1800)/600);
    cx.globalAlpha=sub*0.6;
    cx.fillStyle='#aaa';
    cx.font=`${Math.min(iW*0.030,12)}px monospace`;
    cx.fillText('— tap anywhere to skip —',iW/2,iH*0.94);
    cx.globalAlpha=1;
  }

  // Transition fade-out at end of phase
  if(tMs>IPH_DUR[0]-500){
    const fade=(tMs-(IPH_DUR[0]-500))/500;
    cx.globalAlpha=Math.min(1,fade);
    cx.fillStyle='#000';
    cx.fillRect(0,0,iW,iH);
    cx.globalAlpha=1;
  }
}

function iDrawPhase1(tMs){
  const t=tMs/1000;
  const prog=Math.min(1,tMs/IPH_DUR[1]);
  const cx=iCX;

  cx.fillStyle='#030810';cx.fillRect(0,0,iW,iH);

  // Brain zooms in from small to full
  const scl=0.18+prog*0.82;
  const bw=Math.min(iW*0.52,200)*scl;
  const bh=bw*0.78;
  const bx=iW/2, by=iH*0.42;
  
  // Neural glow rings
  const glowR=bw*1.6+Math.sin(t*2)*12;
  const grd=cx.createRadialGradient(bx,by,bw*0.4,bx,by,glowR);
  grd.addColorStop(0,'rgba(79,195,247,0.18)');
  grd.addColorStop(1,'rgba(0,0,0,0)');
  cx.fillStyle=grd; cx.fillRect(0,0,iW,iH);

  drawBrainShape(bx,by,bw,bh,'rgba(79,195,247,0.9)',prog,2);

  // "ZOOMING INTO YOUR BRAIN..." 
  const textA=Math.min(1,tMs/800);
  cx.globalAlpha=textA*(1-(Math.max(0,tMs-IPH_DUR[1]+800)/800));
  cx.fillStyle='#4FC3F7';
  cx.font=`bold ${Math.min(iW*0.048,20)}px monospace`;
  cx.textAlign='center';
  cx.shadowColor='#4FC3F7'; cx.shadowBlur=10;
  cx.fillText('ZOOMING INTO YOUR BRAIN...',iW/2,iH*0.82);
  cx.shadowBlur=0; cx.globalAlpha=1;

  // MIND REAL ESTATE title appears
  if(tMs>1200){
    const ta=(tMs-1200)/800;
    cx.globalAlpha=Math.min(1,ta);
    cx.fillStyle='#fff';
    cx.font=`700 ${Math.min(iW*0.062,28)}px monospace`;
    cx.letterSpacing='0.3em';
    cx.fillText('MIND REAL ESTATE',iW/2,iH*0.12);
    cx.globalAlpha=1;
  }

  if(tMs>IPH_DUR[1]-500){
    const fade=(tMs-(IPH_DUR[1]-500))/500;
    cx.globalAlpha=Math.min(1,fade);cx.fillStyle='#000';
    cx.fillRect(0,0,iW,iH);cx.globalAlpha=1;
  }
}

// ─── INTRO PHASE 2: Brain-galaxy ─────────────────────────────────────
// Large EMPTY brain in center. Habit words float ALL AROUND it outside.
// Mini brain icons fill the deep background (Images 1&2 reference).
// No count labels — pure visual.
const INTRO_WORDS=[
  'Procrastination','Overanalysis','Complacency','Perfectionism',
  'Fear of Failure','Trading Time','Emotional Reactivity','Over-Engineering',
  'Identity Loss','Imposter Syndrome','Scope Creep','Distraction',
  'Martyrdom','Overthinking','Self-Limitation','Rigid Planning',
  'Analysis Paralysis','Under-pricing','Brain Stagnation','Technical Debt'
];

function iDrawPhase2(tMs){
  const t=tMs/1000;
  const cx=iCX;
  cx.fillStyle='#020810';cx.fillRect(0,0,iW,iH);

  const bx=iW/2, by=iH*0.44;
  const bw=Math.min(iW*0.46,180), bh=bw*0.82;
  const appear=Math.min(1,tMs/1000);

  // ── Deep-background: mini brain icons scattered (Images 1 & 2) ──
  for(let i=0;i<30;i++){
    const bgi_x=iW*(0.04+Math.sin(i*1.9+0.4)*0.46+0.46);
    const bgi_y=iH*(0.04+Math.cos(i*1.6+0.9)*0.46+0.46);
    const bgi_sz=(7+Math.sin(i*0.8)*3)*appear;
    const bgi_col=(['#64E682','#4FC3F7','#FFC832','#CE93D8'])[i%4];
    const bgi_a=appear*(0.18+Math.sin(t*0.5+i)*0.07);
    cx.save();
    cx.globalAlpha=bgi_a;
    cx.strokeStyle=bgi_col;cx.lineWidth=0.9;
    cx.shadowColor=bgi_col;cx.shadowBlur=bgi_sz;
    const bs=bgi_sz*0.45;
    const nx=bgi_x+Math.sin(t*0.3+i)*3;
    const ny=bgi_y+Math.cos(t*0.25+i)*2;
    // Tiny brain walnut
    cx.beginPath();
    cx.moveTo(nx-bs*0.16,ny+bs*0.84);
    cx.bezierCurveTo(nx-bs*0.22,ny+bs,nx-bs*0.70,ny+bs*0.80,nx-bs*0.96,ny+bs*0.24);
    cx.bezierCurveTo(nx-bs*1.10,ny-bs*0.06,nx-bs*1.05,ny-bs*0.78,nx-bs*0.66,ny-bs*0.98);
    cx.bezierCurveTo(nx-bs*0.44,ny-bs*1.10,nx-bs*0.14,ny-bs*1.12,nx,ny-bs*1.08);
    cx.bezierCurveTo(nx+bs*0.14,ny-bs*1.12,nx+bs*0.44,ny-bs*1.10,nx+bs*0.66,ny-bs*0.98);
    cx.bezierCurveTo(nx+bs*1.05,ny-bs*0.78,nx+bs*1.10,ny-bs*0.06,nx+bs*0.96,ny+bs*0.24);
    cx.bezierCurveTo(nx+bs*0.70,ny+bs*0.80,nx+bs*0.22,ny+bs,nx+bs*0.16,ny+bs*0.84);
    cx.bezierCurveTo(nx+bs*0.10,ny+bs*0.96,nx-bs*0.10,ny+bs*0.96,nx-bs*0.16,ny+bs*0.84);
    cx.closePath();cx.stroke();
    cx.restore();
  }

  // ── HABIT WORDS floating in orbit OUTSIDE the brain ──
  const wordRx=bw*1.45, wordRy=bh*1.55; // orbit ellipse, outside the brain
  INTRO_WORDS.forEach((word,i)=>{
    const a=appear*Math.min(1,(tMs-i*60)/500);
    if(a<=0)return;
    const angle=(i/INTRO_WORDS.length)*Math.PI*2+(t*0.18);
    // Slight wobble so each word drifts independently
    const wobble=Math.sin(t*0.4+i*0.7)*0.04;
    const wx=bx+Math.cos(angle+wobble)*wordRx;
    const wy=by+Math.sin(angle+wobble)*wordRy;
    const isRed=i%3!==0;
    const wCol=isRed?'#FF6B6B':'#FF9999';
    cx.save();
    cx.globalAlpha=a*0.85;
    // Word box
    cx.font=`bold ${Math.min(iW*0.024,10)}px monospace`;
    const tw=cx.measureText(word).width+10;
    cx.fillStyle='rgba(255,60,60,0.12)';
    cx.strokeStyle=wCol+'88';cx.lineWidth=0.9;
    cx.beginPath();cx.roundRect(wx-tw/2,wy-8,tw,16,3);cx.fill();cx.stroke();
    cx.fillStyle=wCol;
    cx.textAlign='center';
    cx.shadowColor=wCol;cx.shadowBlur=6;
    cx.fillText(word,wx,wy+4);
    cx.shadowBlur=0;
    cx.restore();
  });

  // ── Faint neural lines from words toward brain center ──
  cx.save();
  INTRO_WORDS.forEach((w,i)=>{
    const a=appear*0.12;
    const angle=(i/INTRO_WORDS.length)*Math.PI*2+(t*0.18);
    const wx=bx+Math.cos(angle)*wordRx;
    const wy=by+Math.sin(angle)*wordRy;
    cx.globalAlpha=a;
    cx.strokeStyle='rgba(255,120,80,.6)';cx.lineWidth=0.5;
    cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(bx,by);cx.stroke();
  });
  cx.globalAlpha=1;cx.restore();

  // ── EMPTY brain in center (just the outline — no words, no water) ──
  drawBrainShape(bx,by,bw,bh,'rgba(79,195,247,0.80)',appear*0.92,1.6);

  if(tMs>IPH_DUR[2]-500){
    const fade=(tMs-(IPH_DUR[2]-500))/500;
    cx.globalAlpha=Math.min(1,fade);cx.fillStyle='#000';
    cx.fillRect(0,0,iW,iH);cx.globalAlpha=1;
  }
}

// ─── INTRO PHASE 3: Zoom in, hand grabs a word from OUTSIDE ─────────
// Brain zooms larger. Words orbit outside and CONVERGE inward.
// Giant hand finger descends and GRABS one word from outside the brain.
// Brain stays empty. No count labels.
function iDrawPhase3(tMs){
  const t=tMs/1000;
  const cx=iCX;
  cx.fillStyle='#030810';cx.fillRect(0,0,iW,iH);

  // Zoom: brain grows from 1× to 1.65× over the phase
  const zoomProg=Math.min(1,tMs/IPH_DUR[3]);
  const zoom=1+zoomProg*0.65;
  const bx=iW/2, by=iH*0.44;
  const bwBase=Math.min(iW*0.46,180);
  const bw=bwBase*zoom, bh=bwBase*0.82*zoom;

  // Word orbit shrinks with zoom (words close IN toward brain edges)
  // At zoom=1: orbit at 1.45× brain size; at zoom=1.65: 1.15× (closer)
  const orbitScale=1.45-zoomProg*0.30;
  const wordRx=bw*orbitScale, wordRy=bh*orbitScale;

  // Which word the hand grabs (word at top-right of orbit)
  const grabIdx=3; // "Perfectionism"
  const grabAngle=(grabIdx/INTRO_WORDS.length)*Math.PI*2+(t*0.18);
  const grabWx=bx+Math.cos(grabAngle)*wordRx;
  const grabWy=by+Math.sin(grabAngle)*wordRy;

  // Hand animation: appears at t=1000ms, descends to grabWx,grabWy, grabs at 2200ms
  const grabTime=2200;
  let handAlpha=0, handX=iW*0.5, handY=-150;
  if(tMs>800){
    handAlpha=Math.min(1,(tMs-800)/500);
    const descProg=Math.min(1,(tMs-800)/(grabTime-800));
    // Hand follows the grab word position
    handX=grabWx;
    handY=-150+(grabWy+50-(-150))*descProg;
  }
  const grabbed=tMs>grabTime;

  // ── Neural background lines ──
  cx.save();
  INTRO_WORDS.forEach((w,i)=>{
    if(i===grabIdx&&grabbed)return;
    const angle=(i/INTRO_WORDS.length)*Math.PI*2+(t*0.18);
    const wx=bx+Math.cos(angle)*wordRx, wy=by+Math.sin(angle)*wordRy;
    cx.globalAlpha=0.08;cx.strokeStyle='rgba(255,100,60,.6)';cx.lineWidth=0.5;
    cx.beginPath();cx.moveTo(wx,wy);cx.lineTo(bx,by);cx.stroke();
  });
  cx.globalAlpha=1;cx.restore();

  // ── EMPTY brain outline (no words inside) ──
  drawBrainShape(bx,by,bw,bh,'rgba(79,195,247,0.85)',0.92,1.8);

  // ── Words orbiting OUTSIDE ──
  INTRO_WORDS.forEach((word,i)=>{
    const isGrabbed=i===grabIdx&&grabbed;
    const angle=(i/INTRO_WORDS.length)*Math.PI*2+(t*0.18);
    let wx=bx+Math.cos(angle)*wordRx;
    let wy=by+Math.sin(angle)*wordRy;

    if(isGrabbed){
      // Grabbed word: yanked toward hand, glowing bright
      wx=handX; wy=handY+60;
    }

    // Fade out non-grabbed words near end of phase
    const fadeOut=zoomProg>0.80?1-(zoomProg-0.80)/0.20:0;
    const baseAlpha=isGrabbed?1:(1-fadeOut);
    if(baseAlpha<=0.01)return;

    const wCol=isGrabbed?'#FFC832':'#FF6B6B';
    cx.save();
    cx.globalAlpha=baseAlpha*(isGrabbed?1:0.85);
    cx.font=`bold ${Math.min(iW*0.024,10)}px monospace`;
    const tw=cx.measureText(word).width+10;
    cx.fillStyle=isGrabbed?'rgba(255,200,50,0.22)':'rgba(255,60,60,0.12)';
    cx.strokeStyle=wCol+(isGrabbed?'FF':'88');cx.lineWidth=isGrabbed?1.4:0.9;
    cx.shadowColor=wCol;cx.shadowBlur=isGrabbed?18:4;
    cx.beginPath();cx.roundRect(wx-tw/2,wy-8,tw,16,3);cx.fill();cx.stroke();
    cx.fillStyle=wCol;cx.textAlign='center';
    cx.shadowBlur=isGrabbed?12:4;
    cx.fillText(word,wx,wy+4);
    cx.shadowBlur=0;cx.restore();
  });

  // ── Hand cursor grabs the word from outside the brain ──
  if(tMs>800) drawHandCursor(handX,handY,handAlpha);

  // ── Bright glow on grabbed word spot ──
  if(grabbed){
    cx.save();
    cx.globalAlpha=Math.min(1,(tMs-grabTime)/300)*0.6;
    const g=cx.createRadialGradient(grabWx,grabWy,0,grabWx,grabWy,60);
    g.addColorStop(0,'rgba(255,200,50,.5)');
    g.addColorStop(1,'rgba(0,0,0,0)');
    cx.fillStyle=g;cx.fillRect(grabWx-60,grabWy-60,120,120);
    cx.restore();
  }

  if(tMs>IPH_DUR[3]-600){
    const fade=(tMs-(IPH_DUR[3]-600))/600;
    cx.globalAlpha=Math.min(1,fade);cx.fillStyle='#000';
    cx.fillRect(0,0,iW,iH);cx.globalAlpha=1;
  }
}


function iDrawPhase4(tMs){
  const t=tMs/1000;
  const cx=iCX;
  // Fade to black and then disappear → reveal category select
  const fadeOut=Math.min(1,tMs/800);
  cx.fillStyle=`rgba(0,0,0,${1-fadeOut*0.5})`;
  cx.fillRect(0,0,iW,iH);
  if(tMs>1200){
    // Start revealing the game canvas
    endIntro();
  }
}

function endIntro(){
  if(!iRunning)return;
  iRunning=false;
  cancelAnimationFrame(_iRAF);
  iCV.classList.add('gone');
  // Show category selection
  document.getElementById('intro').classList.remove('gone');
}

function introTick(now){
  if(!iRunning)return;
  const dt=Math.min(50,now-iPrev);
  iPrev=now;
  iT+=dt;
  // Phase advance
  if(iT>IPH_DUR[iPhase]){
    iPhase++;
    iT=0;
    iParts=[];
    if(iPhase>4){endIntro();return;}
  }
  // Draw current phase
  if(iPhase===0) iDrawPhase0(iT);
  else if(iPhase===1) iDrawPhase1(iT);
  else if(iPhase===2) iDrawPhase2(iT);
  else if(iPhase===3) iDrawPhase3(iT);
  else if(iPhase===4) iDrawPhase4(iT);
  _iRAF=requestAnimationFrame(introTick);
}

// Skip on tap
iCV.addEventListener('click',endIntro);
iCV.addEventListener('touchstart',endIntro,{passive:true});

// Kick off
resizeIntro();
addEventListener('resize',resizeIntro);
iPrev=performance.now();
_iRAF=requestAnimationFrame(introTick);
// ═══════════════════════════════════════════════════════════════
// END INTRO ENGINE
// ═══════════════════════════════════════════════════════════════

const cv=document.getElementById('g');
const cx=cv.getContext('2d');
let W=0,H=0,DPR=1;

// ---------- World layout (tall world, free scroll) ----------
const L={};
function resize(){
  DPR=Math.min(devicePixelRatio||1,2);
  W=innerWidth;H=innerHeight;
  cv.width=W*DPR;cv.height=H*DPR;
  cv.style.width=W+'px';cv.style.height=H+'px';
  cx.setTransform(DPR,0,0,DPR,0,0);
  // ── NEW SINGLE-SCREEN LAYOUT ──
  // Lightbulb + choices at very top. Brain fills the entire bottom.
  // No camera scrolling — everything visible on one screen.
  L.HC=H*0.06;     // Housing source (off-screen, unused visually)
  L.HW=Math.min(W*0.80,320);
  L.HH=Math.min(H*0.10,60);
  L.HEXIT=L.HC+L.HH*0.5;
  L.BY=H*0.13;     // Brain-bulb icon near very top
  L.BR=Math.min(W*0.055,32);  // Icon radius (bigger brain-in-bulb)
  // Brain container fills the entire bottom portion
  L.BT=H*0.24;     // Brain top — just below choices
  L.BB=H*0.91;     // Brain fills to near bottom of screen
  L.BCX=W/2;
  // Brain is WIDE — side boxes are 11% of screen each
  // Brain width: keep clear of side boxes (SBW + 14px gap on each side)
  L.BHW=Math.min(W/2-L.SBW-14, 175);
  // Side box geometry
  L.SBXL=4;
  L.SBXR=W-Math.min(W*0.115,68)-4;
  L.SBW=Math.min(W*0.115,68);
  L.WH=H;
  rebuildWalls();
  if(typeof initBgNeurons==='function')initBgNeurons();
}

// ---------- Camera ----------
const cam={y:0,vy:0};
function maxScroll(){return Math.max(0,L.WH-H);}
function clampCam(){if(cam.y<0)cam.y=0;const m=maxScroll();if(cam.y>m)cam.y=m;}

// ---------- Physics ----------
const eng=Engine.create();
eng.world.gravity.y=1.4;  // stronger gravity fills the bottom
eng.positionIterations=8;
let walls=[];
function rebuildWalls(){
  if(walls.length){walls.forEach(w=>Composite.remove(eng.world,w));}
  walls=[];
  const c=L.BCX,hw=L.BHW,t=80,top=L.BT,bot=L.BB;
  // ── FOLD RAMP PHYSICS ──────────────────────────────────────────────
  // Zigzag angled ramps matching the visual brain fold lines.
  // Words fall from ABOVE the brain, bounce off these ramps, and stack
  // at the bottom — exactly like the Tetris/brain images reference.
  // NO ceiling so words can freely enter from the top.
  const bh=bot-top;
  const rampOpts={isStatic:true,friction:0.65,restitution:0.35,label:'fold'};

  // Each entry: {yFrac, xOffsetFrac, widthFrac, angleDeg}
  // xOffset = 0 means centered; positive = shifted right, negative = left
  // Width covers a portion of brain width (gaps let words fall through)
  const FOLD_RAMPS=[
    // Steep angles for vacuum-tube cascade — words slide sharply downward
    {y:0.14, xOff:-0.10, w:0.55, deg: 22},  // steep rightward slope
    {y:0.28, xOff: 0.10, w:0.55, deg:-22},  // steep leftward slope
    {y:0.42, xOff:-0.08, w:0.52, deg: 18},
    {y:0.56, xOff: 0.08, w:0.52, deg:-18},
    {y:0.70, xOff: 0.00, w:0.46, deg:  9},  // center funnel, gentle slope
  ];

  state.pegPins=[];   // repurpose as fold ramp positions for visual
  state.pinFlashes={}; // flash tracking


  FOLD_RAMPS.forEach((r,i)=>{
    const ry=top+bh*r.y;
    const rx=c+hw*r.xOff;
    const rw=hw*r.w*2;
    const rh=10;
    const ang=r.deg*Math.PI/180;
    const rampBody=Bodies.rectangle(rx,ry,rw,rh,{...rampOpts,angle:ang});
    rampBody._pinIdx=i;
    walls.push(rampBody);
    state.pegPins.push({x:rx,y:ry,w:rw,h:rh,ang:ang,idx:i});
  });

  // ── SOLID CONTAINER: floor + side walls — NO words escape ──
  const containerOpts={isStatic:true,friction:0.80,restitution:0.04};
  walls.push(Bodies.rectangle(c,       bot+t*0.5, hw*3,        t,           {...containerOpts,label:'floor'}));
  walls.push(Bodies.rectangle(c-hw-t/2,(top+bot)/2,t,(bot-top)+t*2,          {...containerOpts,label:'wall'}));
  walls.push(Bodies.rectangle(c+hw+t/2,(top+bot)/2,t,(bot-top)+t*2,          {...containerOpts,label:'wall'}));

  // ═══ BASKETS: 2 per side, positioned between the side boxes ═══
  // Each basket = 3 static walls (U-shape opening upward toward brain center)
  const BK_W=38, BK_H=30, BK_T=5;  // basket width, depth, wall thickness
  const basketOpts={isStatic:true,friction:0.85,restitution:0.05,label:'basket'};
  const bkBH=bh;
  // Upper baskets at ~30% brain height, lower at ~62%
  const bkYs=[top+bkBH*0.30, top+bkBH*0.62];
  state.baskets=[];

  bkYs.forEach((by,bi)=>{
    const isTop=(bi===0);  // top baskets are open-bottomed (vacuum tube pass-through)
    const lbx=c-hw+2;
    const rbx=c+hw-BK_W-2;

    if(isTop){
      // ── TOP BASKETS: open bottom = vacuum-tube chute ──
      // Only 2 side walls (like a funnel/guide) — NO floor, words flow straight through.
      // Left: back wall + shorter front guide
      walls.push(Bodies.rectangle(lbx+BK_T/2,     by+BK_H/2,    BK_T, BK_H,   {...basketOpts}));
      walls.push(Bodies.rectangle(lbx+BK_W-BK_T/2,by+BK_H*0.35, BK_T, BK_H*0.7,{...basketOpts}));
      state.baskets.push({x:lbx,y:by,w:BK_W,h:BK_H,side:'L',idx:bi,open:true});
      // Right: back wall + shorter front guide
      walls.push(Bodies.rectangle(rbx+BK_W-BK_T/2,by+BK_H/2,    BK_T, BK_H,   {...basketOpts}));
      walls.push(Bodies.rectangle(rbx+BK_T/2,      by+BK_H*0.35, BK_T, BK_H*0.7,{...basketOpts}));
      state.baskets.push({x:rbx,y:by,w:BK_W,h:BK_H,side:'R',idx:bi,open:true});
    }else{
      // ── BOTTOM BASKETS: solid U-shape — words are caught and fill from here ──
      // Left
      walls.push(Bodies.rectangle(lbx+BK_T/2,     by+BK_H/2,       BK_T, BK_H,   {...basketOpts}));
      walls.push(Bodies.rectangle(lbx+BK_W/2,     by+BK_H-BK_T/2,  BK_W, BK_T,   {...basketOpts}));
      walls.push(Bodies.rectangle(lbx+BK_W-BK_T/2,by+BK_H/2+4,     BK_T, BK_H-8, {...basketOpts}));
      state.baskets.push({x:lbx,y:by,w:BK_W,h:BK_H,side:'L',idx:bi,open:false});
      // Right
      walls.push(Bodies.rectangle(rbx+BK_W-BK_T/2,by+BK_H/2,       BK_T, BK_H,   {...basketOpts}));
      walls.push(Bodies.rectangle(rbx+BK_W/2,     by+BK_H-BK_T/2,  BK_W, BK_T,   {...basketOpts}));
      walls.push(Bodies.rectangle(rbx+BK_T/2,     by+BK_H/2+4,     BK_T, BK_H-8, {...basketOpts}));
      state.baskets.push({x:rbx,y:by,w:BK_W,h:BK_H,side:'R',idx:bi,open:false});
    }
  });

  Composite.add(eng.world,walls);
}



// ---------- Word bank ----------
// 100 words per category, using exact wording from the master blueprint.
// Each entry: Name|emoji.  Categories are strictly isolated (no overlap).
// Fisher-Yates shuffle is used to randomize selection.

const CORE_POS=['drinking water','taking a deep breath','cleaning your space'];

// Parse a compact category list "Name|emoji\nName|emoji..."
function parseList(raw){
  return raw.trim().split('\n').map(line=>{
    const parts=line.split('|');
    return{name:parts[0].trim(),emoji:(parts[1]||'').trim()};
  });
}

