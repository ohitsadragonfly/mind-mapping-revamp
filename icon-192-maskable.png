const COL={line:'#fff',dim:'rgba(255,255,255,.4)',faint:'rgba(255,255,255,.15)',
  red:'#FF5252',water:'#4FC3F7',breath:'#B3E5FC',sand:'#C9A86A',sky:'#FFB347'};

// ---------- Helpers ----------
function bo(e){return Object.assign({restitution:.40,friction:.28,frictionAir:.022,density:.0012},e||{});}
function T(b,fn){cx.save();cx.translate(b.position.x,b.position.y);cx.rotate(b.angle);fn();cx.restore();}
function ns(){cx.strokeStyle=COL.line;cx.fillStyle='rgba(0,0,0,.7)';cx.lineWidth=1.6;}

// ---------- Positive shape drawers ----------
function dWater(b){T(b,()=>{
  cx.fillStyle='rgba(79,195,247,.7)';cx.strokeStyle=COL.water;cx.lineWidth=1.5;
  cx.beginPath();cx.moveTo(0,-14);cx.bezierCurveTo(11,-4,10,11,0,11);
  cx.bezierCurveTo(-10,11,-11,-4,0,-14);cx.closePath();cx.fill();cx.stroke();
  cx.beginPath();cx.arc(-3,1,2,0,Math.PI*2);cx.fillStyle='rgba(255,255,255,.5)';cx.fill();
});}
function dRipple(b){T(b,()=>{
  cx.strokeStyle=COL.breath;cx.lineWidth=1.2;
  for(let i=0;i<3;i++){
    const r=14+i*7+Math.sin(performance.now()*.005+i)*2;
    cx.globalAlpha=.7-i*.2;
    cx.beginPath();cx.ellipse(0,0,r,r*.45,0,0,Math.PI*2);cx.stroke();
  }
  cx.globalAlpha=1;
});}
function dSpark(b){T(b,()=>{
  cx.fillStyle='#fff';cx.beginPath();
  for(let i=0;i<8;i++){
    const a=(i/8)*Math.PI*2-Math.PI/2,rr=i%2===0?13:4;
    const x=Math.cos(a)*rr,y=Math.sin(a)*rr;
    i?cx.lineTo(x,y):cx.moveTo(x,y);
  }
  cx.closePath();cx.fill();
});}

// ---------- Negative shape drawers (compact set) ----------
function dClock(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-18,-28,36,56);cx.fill();cx.stroke();
  cx.beginPath();cx.arc(0,-12,9,0,Math.PI*2);cx.stroke();
  const t=performance.now()*.001;
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(Math.cos(t)*6,-12+Math.sin(t)*6);
  cx.moveTo(0,-12);cx.lineTo(Math.cos(t*10)*4,-12+Math.sin(t*10)*4);cx.stroke();
});}
function dLips(b){T(b,()=>{
  cx.strokeStyle=COL.red;cx.fillStyle='rgba(255,82,82,.35)';cx.lineWidth=1.6;
  cx.beginPath();cx.moveTo(-22,0);cx.bezierCurveTo(-14,-10,-4,-10,0,-3);
  cx.bezierCurveTo(4,-10,14,-10,22,0);cx.bezierCurveTo(14,-3,-14,-3,-22,0);
  cx.closePath();cx.fill();cx.stroke();
  cx.beginPath();cx.moveTo(-22,0);cx.bezierCurveTo(-14,9,14,9,22,0);
  cx.bezierCurveTo(14,3,-14,3,-22,0);cx.closePath();cx.fill();cx.stroke();
});}
function dBed(b){T(b,()=>{ns();
  // mattress
  cx.beginPath();cx.rect(-34,-7,68,11);cx.fill();cx.stroke();
  // pillow
  cx.beginPath();cx.rect(-28,-11,18,5);cx.stroke();
  // headboard
  cx.beginPath();cx.rect(-36,-16,4,12);cx.fill();cx.stroke();
  // 4 leg posts
  cx.lineWidth=1.6;
  cx.beginPath();
  cx.moveTo(-32,4);cx.lineTo(-32,12);
  cx.moveTo(-22,4);cx.lineTo(-22,11);
  cx.moveTo(22,4);cx.lineTo(22,11);
  cx.moveTo(32,4);cx.lineTo(32,12);
  cx.stroke();
  // small caps on posts
  cx.beginPath();
  cx.arc(-32,12,1.5,0,Math.PI*2);cx.arc(32,12,1.5,0,Math.PI*2);
  cx.fillStyle=COL.line;cx.fill();
});}
function dEmoji(b){T(b,()=>{
  // Phone being held with a thumb on the screen — represents doomscrolling
  ns();
  // Phone body (rounded rect, vertical)
  const phoneW=20,phoneH=36,r=4;
  cx.beginPath();
  cx.moveTo(-phoneW/2+r,-phoneH/2);
  cx.lineTo(phoneW/2-r,-phoneH/2);
  cx.arcTo(phoneW/2,-phoneH/2,phoneW/2,-phoneH/2+r,r);
  cx.lineTo(phoneW/2,phoneH/2-r);
  cx.arcTo(phoneW/2,phoneH/2,phoneW/2-r,phoneH/2,r);
  cx.lineTo(-phoneW/2+r,phoneH/2);
  cx.arcTo(-phoneW/2,phoneH/2,-phoneW/2,phoneH/2-r,r);
  cx.lineTo(-phoneW/2,-phoneH/2+r);
  cx.arcTo(-phoneW/2,-phoneH/2,-phoneW/2+r,-phoneH/2,r);
  cx.closePath();
  cx.fill();cx.stroke();
  // Notch
  cx.beginPath();cx.moveTo(-3,-phoneH/2+1.5);cx.lineTo(3,-phoneH/2+1.5);cx.stroke();
  // Screen content - faint scrolling feed lines
  cx.strokeStyle='rgba(255,255,255,.35)';
  cx.lineWidth=1;
  for(let i=0;i<5;i++){
    const yy=-phoneH/2+5+i*5;
    cx.beginPath();
    cx.moveTo(-phoneW/2+2,yy);
    cx.lineTo(phoneW/2-2,yy);
    cx.stroke();
  }
  // home indicator at bottom
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.4;
  cx.beginPath();cx.moveTo(-3,phoneH/2-2);cx.lineTo(3,phoneH/2-2);cx.stroke();
  // THUMB on screen (oval shape with nail line)
  cx.fillStyle='rgba(255,210,180,.85)';
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.2;
  cx.beginPath();
  // thumb pad (oval) - positioned near bottom right of phone, slightly off
  cx.ellipse(5,8,5,7,-0.3,0,Math.PI*2);
  cx.fill();cx.stroke();
  // thumb segment line
  cx.strokeStyle='rgba(0,0,0,.35)';
  cx.lineWidth=0.8;
  cx.beginPath();
  cx.moveTo(2,6);cx.lineTo(8,11);
  cx.stroke();
  // thumb nail crescent
  cx.fillStyle='rgba(255,235,210,.8)';
  cx.beginPath();
  cx.ellipse(6.5,5,1.8,2.2,-0.3,0,Math.PI*2);
  cx.fill();
  // Reset
  cx.fillStyle='rgba(0,0,0,.7)';
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.6;
});}
function dRedBar(b){T(b,()=>{
  cx.strokeStyle=COL.red;cx.fillStyle='rgba(255,82,82,.4)';cx.lineWidth=1.6;
  cx.beginPath();cx.rect(-36,-7,72,14);cx.fill();cx.stroke();
});}
function dCouch(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-32,0,64,15);cx.fill();cx.stroke();
  cx.beginPath();cx.rect(-32,-17,64,17);cx.fill();cx.stroke();
});}
function dStick(b){T(b,()=>{ns();
  // head with hair tuft
  cx.beginPath();cx.arc(0,-13,5,0,Math.PI*2);cx.fill();cx.stroke();
  cx.beginPath();cx.moveTo(-3,-17);cx.lineTo(-1,-19);cx.lineTo(2,-17);cx.stroke();
  // face dots (downcast)
  cx.fillStyle=COL.line;
  cx.beginPath();cx.arc(-2,-13,.6,0,Math.PI*2);cx.arc(2,-13,.6,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.moveTo(-2,-11);cx.lineTo(2,-10);cx.stroke();
  cx.fillStyle='rgba(0,0,0,.7)';
  // shoulders (slumped — wide trapezoid)
  cx.beginPath();
  cx.moveTo(-7,-7);cx.lineTo(7,-7);cx.lineTo(5,-3);cx.lineTo(-5,-3);cx.closePath();
  cx.fill();cx.stroke();
  // torso (slightly bent)
  cx.beginPath();cx.moveTo(-5,-3);cx.lineTo(-4,7);cx.lineTo(4,7);cx.lineTo(5,-3);
  cx.stroke();
  // arms hanging
  cx.beginPath();cx.moveTo(-7,-5);cx.lineTo(-9,5);cx.moveTo(7,-5);cx.lineTo(9,5);cx.stroke();
  // legs apart
  cx.beginPath();cx.moveTo(-4,7);cx.lineTo(-6,16);cx.moveTo(4,7);cx.lineTo(6,16);cx.stroke();
});}
function dTV(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-22,-13,44,26);cx.fill();cx.stroke();
  cx.beginPath();cx.rect(-18,-10,36,19);cx.stroke();
});}
function dChair(b){T(b,()=>{ns();
  // wheelchair: seat
  cx.beginPath();cx.rect(-12,-3,22,4);cx.fill();cx.stroke();
  // backrest
  cx.beginPath();cx.rect(-12,-19,4,16);cx.fill();cx.stroke();
  // armrest
  cx.beginPath();cx.moveTo(-12,-8);cx.lineTo(10,-8);cx.stroke();
  // large back wheel
  cx.beginPath();cx.arc(2,8,11,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(2,8,5,0,Math.PI*2);cx.stroke();
  // wheel spokes
  cx.lineWidth=1;
  cx.beginPath();
  cx.moveTo(-9,8);cx.lineTo(13,8);
  cx.moveTo(2,-3);cx.lineTo(2,19);
  cx.moveTo(-5,1);cx.lineTo(9,15);
  cx.moveTo(-5,15);cx.lineTo(9,1);
  cx.stroke();
  cx.lineWidth=1.6;
  // small front wheel
  cx.beginPath();cx.arc(-12,10,4,0,Math.PI*2);cx.fill();cx.stroke();
  cx.beginPath();cx.arc(-12,10,1.5,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.fillStyle='rgba(0,0,0,.7)';
  // footrest
  cx.beginPath();cx.moveTo(-12,2);cx.lineTo(-16,10);cx.lineTo(-13,12);cx.stroke();
  // push handle
  cx.beginPath();cx.moveTo(-12,-19);cx.lineTo(-16,-21);cx.stroke();
});}
function dBottle(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-5,-16,10,3);cx.fill();cx.stroke();
  cx.beginPath();
  cx.moveTo(-5,-13);cx.lineTo(-5,-7);cx.lineTo(-8,-4);cx.lineTo(-8,13);
  cx.lineTo(8,13);cx.lineTo(8,-4);cx.lineTo(5,-7);cx.lineTo(5,-13);
  cx.closePath();cx.fill();cx.stroke();
});}
function dPencil(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-3,-18,6,28);cx.fill();cx.stroke();
  cx.beginPath();cx.moveTo(-3,10);cx.lineTo(0,18);cx.lineTo(3,10);cx.closePath();cx.fill();cx.stroke();
});}
function dGate(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-32,-20,64,40);cx.fill();cx.stroke();
  for(let x=-22;x<=22;x+=11){cx.beginPath();cx.moveTo(x,-20);cx.lineTo(x,20);cx.stroke();}
});}
function dBinary(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-22,-10,44,20);cx.fill();cx.stroke();
  cx.fillStyle=COL.line;cx.font='500 8px monospace';cx.textAlign='center';
  cx.fillText('10101',0,-1);cx.fillText('01010',0,7);
});}
function dManual(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-20,-25,40,50);cx.fill();cx.stroke();
  cx.strokeStyle=COL.dim;
  for(let y=-16;y<=16;y+=7){cx.beginPath();cx.moveTo(-13,y);cx.lineTo(13,y);cx.stroke();}
});}
function dSpray(b){T(b,()=>{ns();
  // body (curved bottle)
  cx.beginPath();
  cx.moveTo(-9,-2);cx.lineTo(-12,-2);cx.lineTo(-12,16);cx.lineTo(9,16);cx.lineTo(9,-2);cx.lineTo(6,-2);
  cx.lineTo(6,-7);cx.lineTo(-6,-7);cx.lineTo(-6,-2);cx.closePath();
  cx.fill();cx.stroke();
  // liquid line
  cx.strokeStyle='rgba(79,195,247,.5)';
  cx.beginPath();cx.moveTo(-11,8);cx.lineTo(8,8);cx.stroke();
  cx.strokeStyle=COL.line;
  // neck (narrow piece on top)
  cx.beginPath();cx.rect(-4,-12,8,5);cx.fill();cx.stroke();
  // angled head/trigger housing (top of bottle)
  cx.beginPath();
  cx.moveTo(-3,-12);cx.lineTo(-3,-18);cx.lineTo(10,-18);cx.lineTo(14,-14);cx.lineTo(3,-12);
  cx.closePath();cx.fill();cx.stroke();
  // nozzle (pointing left)
  cx.beginPath();
  cx.moveTo(-3,-16);cx.lineTo(-9,-16);cx.lineTo(-9,-14);cx.lineTo(-3,-14);
  cx.fill();cx.stroke();
  // trigger (hook curving down)
  cx.beginPath();
  cx.moveTo(2,-13);cx.lineTo(2,-9);cx.lineTo(7,-7);cx.lineTo(8,-9);cx.lineTo(5,-12);
  cx.closePath();cx.fill();cx.stroke();
  // handle ridges
  cx.lineWidth=1;
  cx.beginPath();
  cx.moveTo(2,-11);cx.lineTo(6,-10);
  cx.moveTo(2,-9.5);cx.lineTo(6,-8.5);
  cx.stroke();
  cx.lineWidth=1.6;
});}
function dWings(b){T(b,()=>{ns();
  // Left wing outline
  cx.beginPath();
  cx.moveTo(0,0);
  cx.bezierCurveTo(-12,-10,-30,-7,-34,4);
  cx.bezierCurveTo(-30,8,-12,6,0,3);
  cx.closePath();cx.fill();cx.stroke();
  // Left feather detail lines
  cx.lineWidth=1;
  for(let i=0;i<5;i++){
    const t=i/4;
    const x1=-4-t*26, y1=-2-t*7;
    const x2=-6-t*22, y2=4+t*3;
    cx.beginPath();
    cx.moveTo(x1,y1);
    cx.lineTo(x2,y2);
    cx.stroke();
  }
  // Left tip feathers (curved)
  cx.beginPath();
  cx.moveTo(-34,4);cx.bezierCurveTo(-30,2,-26,3,-22,5);
  cx.moveTo(-32,6);cx.bezierCurveTo(-28,4,-24,5,-20,6);
  cx.stroke();
  
  // Right wing outline
  cx.lineWidth=1.6;
  cx.beginPath();
  cx.moveTo(0,0);
  cx.bezierCurveTo(12,-10,30,-7,34,4);
  cx.bezierCurveTo(30,8,12,6,0,3);
  cx.closePath();cx.fill();cx.stroke();
  // Right feather detail lines
  cx.lineWidth=1;
  for(let i=0;i<5;i++){
    const t=i/4;
    const x1=4+t*26, y1=-2-t*7;
    const x2=6+t*22, y2=4+t*3;
    cx.beginPath();
    cx.moveTo(x1,y1);
    cx.lineTo(x2,y2);
    cx.stroke();
  }
  // Right tip feathers
  cx.beginPath();
  cx.moveTo(34,4);cx.bezierCurveTo(30,2,26,3,22,5);
  cx.moveTo(32,6);cx.bezierCurveTo(28,4,24,5,20,6);
  cx.stroke();
  cx.lineWidth=1.6;
});}
function dCtrl(b){T(b,()=>{ns();
  // iPhone body (rounded rect, vertical)
  const w=20,h=34,r=4;
  cx.beginPath();
  cx.moveTo(-w/2+r,-h/2);
  cx.lineTo(w/2-r,-h/2);
  cx.arcTo(w/2,-h/2,w/2,-h/2+r,r);
  cx.lineTo(w/2,h/2-r);
  cx.arcTo(w/2,h/2,w/2-r,h/2,r);
  cx.lineTo(-w/2+r,h/2);
  cx.arcTo(-w/2,h/2,-w/2,h/2-r,r);
  cx.lineTo(-w/2,-h/2+r);
  cx.arcTo(-w/2,-h/2,-w/2+r,-h/2,r);
  cx.closePath();
  cx.fill();cx.stroke();
  // notch + speaker
  cx.beginPath();cx.moveTo(-3,-h/2+1);cx.lineTo(3,-h/2+1);cx.stroke();
  // screen area
  cx.lineWidth=1;
  cx.beginPath();cx.rect(-w/2+2,-h/2+3,w-4,h-8);cx.stroke();
  // home indicator
  cx.beginPath();cx.moveTo(-3,h/2-2.5);cx.lineTo(3,h/2-2.5);cx.stroke();
  // BRAIN on screen
  cx.lineWidth=1.2;
  cx.strokeStyle='#fff';
  cx.beginPath();
  // brain mini - two bumps
  cx.moveTo(-6,-4);
  cx.bezierCurveTo(-6,-8,-2,-9,0,-6);
  cx.bezierCurveTo(2,-9,6,-8,6,-4);
  cx.bezierCurveTo(7,2,4,6,0,5);
  cx.bezierCurveTo(-4,6,-7,2,-6,-4);
  cx.closePath();
  cx.stroke();
  // central line
  cx.beginPath();cx.moveTo(0,-6);cx.lineTo(0,5);cx.stroke();
  // CROSS-OUT (big red X)
  cx.strokeStyle=COL.red;
  cx.lineWidth=2;
  cx.beginPath();
  cx.moveTo(-9,-9);cx.lineTo(9,9);
  cx.moveTo(9,-9);cx.lineTo(-9,9);
  cx.stroke();
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.6;
});}
function dHeart(b){T(b,()=>{
  cx.strokeStyle=COL.red;cx.fillStyle='rgba(255,82,82,.3)';cx.lineWidth=1.6;
  cx.beginPath();cx.moveTo(0,16);
  cx.bezierCurveTo(-22,3,-22,-16,-9,-16);
  cx.bezierCurveTo(-3,-16,0,-11,0,-5);
  cx.bezierCurveTo(0,-11,3,-16,9,-16);
  cx.bezierCurveTo(22,-16,22,3,0,16);cx.closePath();cx.fill();cx.stroke();
  cx.strokeStyle='#000';cx.lineWidth=2;
  cx.beginPath();cx.moveTo(0,-5);cx.lineTo(-3,0);cx.lineTo(3,4);cx.lineTo(-1,10);cx.stroke();
});}
function dCig(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-16,-3,26,6);cx.fill();cx.stroke();
  cx.beginPath();cx.rect(8,-3,6,6);cx.fill();cx.stroke();
  cx.beginPath();cx.arc(-16,0,2,0,Math.PI*2);cx.fillStyle=COL.red;cx.fill();
});}
function dLoop(b){T(b,()=>{ns();
  // Oval (wider than tall)
  cx.beginPath();
  cx.ellipse(0,0,26,16,0,0,Math.PI*2);
  cx.stroke();
  cx.beginPath();
  cx.ellipse(0,0,16,9,0,0,Math.PI*2);
  cx.stroke();
  // Fill the donut region
  cx.fillStyle='rgba(0,0,0,.7)';
  cx.beginPath();
  cx.ellipse(0,0,26,16,0,0,Math.PI*2);
  cx.ellipse(0,0,16,9,0,0,Math.PI*2,true);
  cx.fill();
  // re-stroke for clarity
  cx.strokeStyle=COL.line;
  cx.beginPath();cx.ellipse(0,0,26,16,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(0,0,16,9,0,0,Math.PI*2);cx.stroke();
  // Arrows showing endless circulation
  // Right arrow (top of oval going right)
  cx.lineWidth=1.6;
  cx.beginPath();
  cx.moveTo(18,-12);cx.lineTo(24,-8);cx.lineTo(18,-4);
  cx.stroke();
  // Left arrow (bottom of oval going left)
  cx.beginPath();
  cx.moveTo(-18,12);cx.lineTo(-24,8);cx.lineTo(-18,4);
  cx.stroke();
});}
function dQ(b){T(b,()=>{ns();
  cx.font='700 36px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillStyle='rgba(0,0,0,.7)';cx.fillText('?',0,0);cx.strokeText('?',0,0);
});}
function dGravestone(b){T(b,()=>{ns();
  // Arched gravestone shape
  cx.beginPath();
  cx.moveTo(-13,12);cx.lineTo(-13,-4);
  cx.bezierCurveTo(-13,-14,13,-14,13,-4);
  cx.lineTo(13,12);
  cx.closePath();cx.fill();cx.stroke();
  // Base
  cx.beginPath();cx.rect(-16,12,32,4);cx.fill();cx.stroke();
  // R.I.P. text
  cx.fillStyle='rgba(255,255,255,.55)';
  cx.font='500 5px monospace';cx.textAlign='center';
  cx.fillText('R.I.P',0,2);
  // cross
  cx.lineWidth=1;
  cx.beginPath();cx.moveTo(0,-9);cx.lineTo(0,-3);cx.moveTo(-2,-7);cx.lineTo(2,-7);cx.stroke();
  cx.lineWidth=1.6;
});}
function dBag(b){T(b,()=>{ns();
  cx.beginPath();cx.rect(-16,-9,32,24);cx.stroke();
  cx.beginPath();cx.arc(-8,-9,4,Math.PI,0,false);cx.arc(8,-9,4,Math.PI,0,false);cx.stroke();
});}

// Large SAFE — represents 'playing it safe'
function dSafe(b){T(b,()=>{ns();
  // safe body
  cx.beginPath();cx.rect(-24,-22,48,44);cx.fill();cx.stroke();
  // inner panel
  cx.lineWidth=1.2;
  cx.beginPath();cx.rect(-20,-18,40,36);cx.stroke();
  // combination dial (circle with marks)
  cx.beginPath();cx.arc(-2,0,8,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(-2,0,5,0,Math.PI*2);cx.stroke();
  // dial knob
  cx.beginPath();cx.arc(-2,0,1.4,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.fillStyle='rgba(0,0,0,.7)';
  // dial tick marks around outside
  cx.lineWidth=1;
  for(let i=0;i<12;i++){
    const a=(i/12)*Math.PI*2;
    const x1=-2+Math.cos(a)*9, y1=Math.sin(a)*9;
    const x2=-2+Math.cos(a)*10, y2=Math.sin(a)*10;
    cx.beginPath();cx.moveTo(x1,y1);cx.lineTo(x2,y2);cx.stroke();
  }
  cx.lineWidth=1.6;
  // handle (lever on right side)
  cx.beginPath();
  cx.moveTo(14,-2);cx.lineTo(18,-2);cx.lineTo(18,2);cx.lineTo(14,2);
  cx.fill();cx.stroke();
  // hinges (left side)
  cx.beginPath();cx.rect(-23,-16,3,5);cx.fill();cx.stroke();
  cx.beginPath();cx.rect(-23,11,3,5);cx.fill();cx.stroke();
  // "SAFE" text on top
  cx.fillStyle=COL.line;
  cx.font='500 5px monospace';cx.textAlign='center';
  cx.fillText('SAFE',-2,-12);
  cx.fillStyle='rgba(0,0,0,.7)';
});}

// PLATE WITH MONEY — represents 'eating out'
function dPlate(b){T(b,()=>{ns();
  // plate (ellipse)
  cx.beginPath();
  cx.ellipse(0,2,24,8,0,0,Math.PI*2);
  cx.fill();cx.stroke();
  // plate rim
  cx.lineWidth=1;
  cx.beginPath();
  cx.ellipse(0,2,20,6,0,0,Math.PI*2);
  cx.stroke();
  // dollar bill on plate
  cx.fillStyle='#7FE57F';
  cx.strokeStyle='#5BB85B';
  cx.lineWidth=1.2;
  cx.beginPath();cx.rect(-10,-6,20,9);
  cx.fill();cx.stroke();
  // bill details
  cx.fillStyle='#5BB85B';
  cx.font='700 6px monospace';cx.textAlign='center';cx.textBaseline='middle';
  cx.fillText('$',0,-2);
  // bill corners
  cx.font='500 4px monospace';
  cx.fillText('1',-7,-3);cx.fillText('1',7,-3);
  cx.fillText('1',-7,1);cx.fillText('1',7,1);
  cx.textBaseline='alphabetic';
  // small coins beside
  cx.fillStyle='#D4AF37';
  cx.strokeStyle='#A0801F';
  cx.lineWidth=1;
  cx.beginPath();cx.arc(-14,4,2.5,0,Math.PI*2);cx.fill();cx.stroke();
  cx.beginPath();cx.arc(14,4,2.5,0,Math.PI*2);cx.fill();cx.stroke();
  cx.fillStyle='rgba(0,0,0,.7)';
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.6;
});}

// Generic "word block" - rectangle with the word written across it.
// Used as a fallback for new words that don't have a custom shape.
function dWordBlock(b,word,isPos){
  T(b,()=>{
    cx.strokeStyle=isPos?COL.water:COL.line;
    cx.fillStyle=isPos?'rgba(79,195,247,.12)':'rgba(0,0,0,.7)';
    cx.lineWidth=1.4;
    // Measure word for box width
    cx.font='500 7px monospace';
    const w=Math.max(cx.measureText(word.toUpperCase()).width+10,24);
    const h=14;
    // rounded rect
    const r=4;
    cx.beginPath();
    cx.moveTo(-w/2+r,-h/2);
    cx.arcTo(w/2,-h/2,w/2,0,r);
    cx.arcTo(w/2,h/2,0,h/2,r);
    cx.arcTo(-w/2,h/2,-w/2,0,r);
    cx.arcTo(-w/2,-h/2,0,-h/2,r);
    cx.closePath();
    cx.fill();cx.stroke();
    // word
    cx.fillStyle=isPos?COL.water:COL.line;
    cx.textAlign='center';cx.textBaseline='middle';
    cx.fillText(word.toUpperCase(),0,0);
    cx.textBaseline='alphabetic';
  });
}

// ---------- Shape registry ----------
const S={
  'drinking water':{kind:'pos',label:'pos:water',body:(x,y)=>Bodies.circle(x,y,11,bo({density:.0008,friction:.02,frictionAir:.02,restitution:.45,label:'pos:water'})),draw:dWater},
  'taking a deep breath':{kind:'pos',label:'pos:breath',body:(x,y)=>Bodies.circle(x,y,22,bo({density:.0002,friction:0,frictionAir:.05,restitution:.1,label:'pos:breath'})),draw:dRipple},
  'cleaning your space':{kind:'pos',label:'pos:spark',body:(x,y)=>Bodies.polygon(x,y,4,13,bo({density:.0015,restitution:.55,label:'pos:spark'})),draw:dSpark},
  'procrastinating':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,40,60,bo({label:'neg'})),draw:dClock},
  'complaining':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,46,22,bo({label:'neg'})),draw:dLips},
  'oversleeping':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,72,20,bo({label:'neg'})),draw:dBed},
  'poor sleep hygiene':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,72,20,bo({label:'neg'})),draw:dBed},
  'doomscrolling':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,22,38,bo({label:'neg'})),draw:dEmoji},
  'negative self-talk':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,76,14,bo({label:'neg'})),draw:dRedBar},
  'sedentary lifestyle':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,68,34,bo({label:'neg'})),draw:dCouch},
  'isolation':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,14,28,bo({label:'neg'})),draw:dStick},
  'passive tv watching':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,48,28,bo({label:'neg'})),draw:dTV},
  'skipping movement':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,30,35,bo({label:'neg'})),draw:dChair},
  'forgetting water':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,18,32,bo({label:'neg'})),draw:dBottle},
  'losing track of pills':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,30,24,bo({label:'neg'})),draw:dGravestone},
  'skipping testing':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,8,38,bo({friction:.1,restitution:.4,label:'neg'})),draw:dPencil},
  'siloing knowledge':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,68,42,bo({label:'neg'})),draw:dGate},
  'passive code approval':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,46,22,bo({label:'neg'})),draw:dBinary},
  'tutorial hell':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,44,52,bo({label:'neg'})),draw:dManual},
  'playing it safe':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,52,46,bo({density:0.0018,label:'neg'})),draw:dSafe},
  'avoiding cleaning':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,28,38,bo({label:'neg'})),draw:dSpray},
  'winging it':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,64,18,bo({label:'neg'})),draw:dWings},
  'passive screen time':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,22,36,bo({label:'neg'})),draw:dCtrl},
  'neglecting partnership':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,44,36,bo({label:'neg'})),draw:dHeart},
  'family autopilot':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,60,18,bo({label:'neg'})),draw:(b)=>dWordBlock(b,'autopilot',false)},
  'smoking':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,32,7,bo({label:'neg'})),draw:dCig},
  'repeating routines':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,52,32,bo({chamfer:{radius:14},label:'neg'})),draw:dLoop},
  'believing everything':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,28,40,bo({label:'neg'})),draw:dQ},
  'passive consumption':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,36,30,bo({density:.0006,label:'neg'})),draw:dBag},
  'clinging to past':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,40,28,bo({label:'neg'})),draw:(b)=>dWordBlock(b,'past',false)},
  // Standalone negatives
  'eating out':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,52,20,bo({label:'neg'})),draw:dPlate},
  'spending frivolously':{kind:'neg',body:(x,y)=>Bodies.rectangle(x,y,60,18,bo({label:'neg'})),draw:(b)=>dWordBlock(b,'spending',false)}
};

// Color palette indexed by emoji category for the colored shape backgrounds
// ---------- B&W LINE-ART SHAPE LIBRARY ----------
// Each function draws the emoji's shape in 2D black-and-white lines (no fills).
// Drawing area roughly ±18px around (0,0). White lines on transparent background.

function ld_boulder(){ // 🪨 rock
  cx.beginPath();
  cx.moveTo(-14,4);cx.bezierCurveTo(-18,-6,-8,-14,-2,-10);
  cx.bezierCurveTo(8,-14,16,-4,14,4);
  cx.bezierCurveTo(12,12,-12,12,-14,4);cx.closePath();cx.stroke();
  // crack
  cx.beginPath();cx.moveTo(-4,-6);cx.lineTo(-1,2);cx.lineTo(4,0);cx.stroke();
}
function ld_anvil(){ // 🔨 used for anvil/hammer
  cx.beginPath();
  cx.moveTo(-16,-2);cx.lineTo(16,-2);cx.lineTo(20,2);cx.lineTo(14,2);
  cx.lineTo(10,6);cx.lineTo(-10,6);cx.lineTo(-14,2);cx.lineTo(-20,2);cx.closePath();cx.stroke();
  cx.beginPath();cx.rect(-8,6,16,8);cx.stroke();
}
function ld_hammer(){ // 🔨 hammer
  cx.beginPath();cx.rect(-14,-10,18,8);cx.stroke();
  cx.beginPath();cx.moveTo(4,-6);cx.lineTo(4,14);cx.lineTo(-2,14);cx.lineTo(-2,-6);cx.stroke();
}
function ld_anchor(){ // ⚓
  cx.beginPath();cx.arc(0,-12,3,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,-9);cx.lineTo(0,12);cx.stroke();
  cx.beginPath();cx.moveTo(-7,-4);cx.lineTo(7,-4);cx.stroke();
  cx.beginPath();
  cx.moveTo(-12,6);cx.bezierCurveTo(-12,14,-4,14,-2,10);
  cx.moveTo(12,6);cx.bezierCurveTo(12,14,4,14,2,10);
  cx.stroke();
}
function ld_mask(){ // 🎭
  cx.beginPath();
  cx.moveTo(-12,-8);cx.bezierCurveTo(-14,4,-8,14,0,14);
  cx.bezierCurveTo(8,14,14,4,12,-8);
  cx.bezierCurveTo(8,-12,-8,-12,-12,-8);cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(-5,-2,1.5,0,Math.PI*2);cx.arc(5,-2,1.5,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.moveTo(-3,6);cx.bezierCurveTo(0,8,0,8,3,6);cx.stroke();
}
function ld_chain(){ // ⛓️
  cx.beginPath();cx.ellipse(-8,0,4,6,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(0,0,4,6,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(8,0,4,6,0,0,Math.PI*2);cx.stroke();
}
function ld_lock(){ // 🔒
  cx.beginPath();
  cx.moveTo(-6,-2);cx.lineTo(-6,-8);
  cx.bezierCurveTo(-6,-14,6,-14,6,-8);cx.lineTo(6,-2);cx.stroke();
  cx.beginPath();cx.rect(-9,-2,18,14);cx.stroke();
  cx.beginPath();cx.arc(0,5,1.5,0,Math.PI*2);cx.fill();
}
function ld_blindfold(){ // 🫣 🙈
  cx.beginPath();cx.rect(-14,-3,28,6);cx.stroke();
  cx.beginPath();cx.moveTo(-14,0);cx.lineTo(-18,2);
  cx.moveTo(14,0);cx.lineTo(18,2);cx.stroke();
}
function ld_bomb(){ // 💣
  cx.beginPath();cx.arc(0,4,10,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(6,-4);cx.bezierCurveTo(10,-10,14,-8,12,-4);cx.stroke();
  cx.beginPath();cx.arc(13,-6,1.5,0,Math.PI*2);cx.stroke();
}
function ld_vase(){ // 🏺
  cx.beginPath();
  cx.moveTo(-7,-10);cx.lineTo(7,-10);cx.lineTo(6,-7);
  cx.bezierCurveTo(12,-2,12,10,0,12);
  cx.bezierCurveTo(-12,10,-12,-2,-6,-7);cx.closePath();cx.stroke();
  // crack
  cx.beginPath();cx.moveTo(-2,-3);cx.lineTo(0,4);cx.lineTo(-3,9);cx.stroke();
}
function ld_cage(){ // 🕸️ cage/trap (vertical bars)
  cx.beginPath();cx.rect(-12,-12,24,24);cx.stroke();
  for(let i=-8;i<=8;i+=4){
    cx.beginPath();cx.moveTo(i,-12);cx.lineTo(i,12);cx.stroke();
  }
}
function ld_mirror(){ // 🪞
  cx.beginPath();cx.ellipse(0,-2,8,12,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,10);cx.lineTo(0,14);
  cx.moveTo(-4,14);cx.lineTo(4,14);cx.stroke();
}
function ld_crown(){ // 👑
  cx.beginPath();
  cx.moveTo(-14,8);cx.lineTo(-12,-8);cx.lineTo(-6,2);cx.lineTo(0,-10);
  cx.lineTo(6,2);cx.lineTo(12,-8);cx.lineTo(14,8);cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(-12,-8,1.5,0,Math.PI*2);
  cx.arc(0,-10,1.5,0,Math.PI*2);cx.arc(12,-8,1.5,0,Math.PI*2);cx.fill();
}
function ld_brick(){ // 🧱
  cx.beginPath();cx.rect(-12,-7,24,14);cx.stroke();
  cx.beginPath();cx.moveTo(-12,0);cx.lineTo(12,0);
  cx.moveTo(0,-7);cx.lineTo(0,0);
  cx.moveTo(-6,0);cx.lineTo(-6,7);
  cx.moveTo(6,0);cx.lineTo(6,7);cx.stroke();
}
function ld_shield(){ // 🛡️
  cx.beginPath();
  cx.moveTo(-10,-10);cx.lineTo(10,-10);
  cx.bezierCurveTo(10,4,6,12,0,14);
  cx.bezierCurveTo(-6,12,-10,4,-10,-10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,-6);cx.lineTo(0,8);cx.moveTo(-6,0);cx.lineTo(6,0);cx.stroke();
}
function ld_leash(){ // 🐕 leash
  cx.beginPath();cx.arc(-6,-6,3,0,Math.PI*2);cx.stroke(); // ring
  cx.beginPath();
  cx.moveTo(-3,-5);cx.bezierCurveTo(4,-2,8,4,12,12);cx.stroke();
}
function ld_shroud(){ // 🌫️ shroud/fog
  cx.beginPath();
  cx.moveTo(-14,-2);cx.bezierCurveTo(-16,4,16,4,14,-2);cx.stroke();
  cx.beginPath();
  cx.moveTo(-12,4);cx.bezierCurveTo(-14,10,14,10,12,4);cx.stroke();
  cx.beginPath();
  cx.moveTo(-10,10);cx.bezierCurveTo(-12,14,12,14,10,10);cx.stroke();
}
function ld_explosion(){ // 💥
  for(let i=0;i<8;i++){
    const a=(i/8)*Math.PI*2;
    cx.beginPath();
    cx.moveTo(Math.cos(a)*3,Math.sin(a)*3);
    cx.lineTo(Math.cos(a)*12,Math.sin(a)*12);
    cx.stroke();
  }
  cx.beginPath();cx.arc(0,0,3,0,Math.PI*2);cx.stroke();
}
function ld_dice(){ // 🎲
  cx.beginPath();cx.rect(-10,-10,20,20);cx.stroke();
  cx.beginPath();
  cx.arc(-5,-5,1.5,0,Math.PI*2);cx.arc(5,-5,1.5,0,Math.PI*2);
  cx.arc(0,0,1.5,0,Math.PI*2);
  cx.arc(-5,5,1.5,0,Math.PI*2);cx.arc(5,5,1.5,0,Math.PI*2);cx.fill();
}
function ld_earplugs(){ // 🔇 muted speaker
  cx.beginPath();
  cx.moveTo(-12,-4);cx.lineTo(-6,-4);cx.lineTo(0,-10);cx.lineTo(0,10);
  cx.lineTo(-6,4);cx.lineTo(-12,4);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(4,-6);cx.lineTo(14,6);
  cx.moveTo(14,-6);cx.lineTo(4,6);cx.stroke();
}
function ld_link(){ // 🔗
  cx.beginPath();cx.ellipse(-5,0,5,3,Math.PI/4,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(5,0,5,3,Math.PI/4,0,Math.PI*2);cx.stroke();
}
function ld_drain(){ // 🕳️ void/drain
  cx.beginPath();cx.ellipse(0,0,12,4,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(0,0,8,3,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(0,0,4,1.5,0,0,Math.PI*2);cx.stroke();
}
function ld_axe(){ // 🪓
  cx.beginPath();cx.moveTo(2,-12);cx.lineTo(2,14);cx.stroke();
  cx.beginPath();
  cx.moveTo(2,-10);cx.lineTo(-10,-8);cx.lineTo(-12,-2);cx.lineTo(2,-4);cx.closePath();cx.stroke();
}
function ld_crutch(){ // 🩼
  cx.beginPath();cx.moveTo(-6,-12);cx.lineTo(6,-12);cx.stroke();
  cx.beginPath();cx.moveTo(-6,-12);cx.lineTo(0,-4);cx.lineTo(6,-12);cx.stroke();
  cx.beginPath();cx.moveTo(0,-4);cx.lineTo(0,14);cx.stroke();
  cx.beginPath();cx.moveTo(-4,14);cx.lineTo(4,14);cx.stroke();
}
function ld_avalanche(){ // ❄️
  for(let i=0;i<6;i++){
    const a=(i/6)*Math.PI*2;
    cx.beginPath();
    cx.moveTo(0,0);cx.lineTo(Math.cos(a)*10,Math.sin(a)*10);
    cx.stroke();
  }
}
function ld_tombstone(){ // 🪦
  cx.beginPath();
  cx.moveTo(-10,12);cx.lineTo(-10,-4);
  cx.bezierCurveTo(-10,-12,10,-12,10,-4);cx.lineTo(10,12);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,-6);cx.lineTo(0,0);cx.moveTo(-3,-3);cx.lineTo(3,-3);cx.stroke();
}
function ld_cloud(){ // ☁️
  cx.beginPath();
  cx.arc(-6,2,5,Math.PI,0,false);
  cx.arc(0,-2,6,Math.PI*1.2,Math.PI*1.95,false);
  cx.arc(7,2,5,Math.PI*1.5,Math.PI*0.5,false);
  cx.lineTo(-6,7);cx.closePath();cx.stroke();
}
function ld_stone(){ // 🗿 face stone
  cx.beginPath();
  cx.moveTo(-9,12);cx.lineTo(-9,-8);
  cx.bezierCurveTo(-9,-14,9,-14,9,-8);cx.lineTo(9,12);cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(-3,-2,1,0,Math.PI*2);cx.arc(3,-2,1,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.moveTo(-3,4);cx.lineTo(3,4);cx.stroke();
}
function ld_muzzle(){ // 🤐
  cx.beginPath();cx.ellipse(0,0,12,7,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-3);cx.lineTo(10,-3);
  cx.moveTo(-10,3);cx.lineTo(10,3);cx.stroke();
  cx.beginPath();cx.moveTo(-8,0);cx.lineTo(8,0);cx.stroke();
}
function ld_collar(){ // 🐕 collar
  cx.beginPath();cx.ellipse(0,0,12,6,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,6,2.5,0,Math.PI*2);cx.stroke();
}
function ld_knot(){ // 🪢
  cx.beginPath();
  cx.moveTo(-12,-4);cx.bezierCurveTo(-4,4,4,-4,12,4);
  cx.moveTo(-12,4);cx.bezierCurveTo(-4,-4,4,4,12,-4);
  cx.stroke();
}
function ld_log(){ // 🪵
  cx.beginPath();cx.ellipse(0,0,16,5,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.ellipse(-12,0,3,5,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(-12,0,1.5,0,Math.PI*2);cx.stroke();
}
function ld_sack(){ // 🎒
  cx.beginPath();
  cx.moveTo(-9,-6);cx.bezierCurveTo(-12,8,12,8,9,-6);
  cx.lineTo(6,-10);cx.lineTo(-6,-10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-3,-10);cx.lineTo(3,-10);cx.stroke();
}
function ld_dart(){ // 🎯
  cx.beginPath();cx.arc(0,0,12,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,0,8,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,0,4,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,0,1.5,0,Math.PI*2);cx.fill();
}
function ld_wall(){ // 🧱 wall - similar to brick but bigger
  cx.beginPath();cx.rect(-14,-10,28,20);cx.stroke();
  for(let r=0;r<2;r++){
    const y=-10+r*10;
    cx.beginPath();cx.moveTo(-14,y+5);cx.lineTo(14,y+5);cx.stroke();
    const offset=r%2===0?0:7;
    for(let x=-14+offset;x<14;x+=10){
      cx.beginPath();cx.moveTo(x,y);cx.lineTo(x,y+5);cx.stroke();
    }
  }
}
function ld_box(){ // 📦
  cx.beginPath();cx.rect(-11,-9,22,18);cx.stroke();
  cx.beginPath();cx.moveTo(-11,-9);cx.lineTo(0,-3);cx.lineTo(11,-9);cx.stroke();
  cx.beginPath();cx.moveTo(0,-3);cx.lineTo(0,9);cx.stroke();
  // tape
  cx.beginPath();cx.moveTo(-6,-9);cx.lineTo(-6,9);
  cx.moveTo(6,-9);cx.lineTo(6,9);cx.stroke();
}
function ld_balloon(){ // 🎈
  cx.beginPath();cx.ellipse(0,-4,8,10,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,6);cx.lineTo(-2,8);cx.lineTo(2,8);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,8);cx.bezierCurveTo(4,12,-4,14,0,16);cx.stroke();
}
function ld_books(){ // 📚
  cx.beginPath();cx.rect(-12,-8,24,4);cx.stroke();
  cx.beginPath();cx.rect(-10,-4,20,4);cx.stroke();
  cx.beginPath();cx.rect(-12,0,24,4);cx.stroke();
  cx.beginPath();cx.rect(-10,4,20,4);cx.stroke();
}
function ld_mist(){ // 💨
  cx.beginPath();cx.moveTo(-12,-4);cx.bezierCurveTo(-8,-6,8,-6,12,-4);cx.stroke();
  cx.beginPath();cx.moveTo(-14,0);cx.bezierCurveTo(-8,-2,8,-2,14,0);cx.stroke();
  cx.beginPath();cx.moveTo(-12,4);cx.bezierCurveTo(-8,2,8,2,12,4);cx.stroke();
}
function ld_whisper(){ // 🤫 whisper - speech with finger
  cx.beginPath();cx.arc(0,0,9,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(0,12);cx.stroke();
  cx.beginPath();cx.arc(0,-4,1,0,Math.PI*2);cx.arc(0,4,1,0,Math.PI*2);cx.fill();
}
function ld_fence(){ // 🚧 barrier
  cx.beginPath();cx.rect(-14,-4,28,8);cx.stroke();
  cx.beginPath();
  cx.moveTo(-12,-4);cx.lineTo(-6,4);
  cx.moveTo(-6,-4);cx.lineTo(0,4);
  cx.moveTo(0,-4);cx.lineTo(6,4);
  cx.moveTo(6,-4);cx.lineTo(12,4);
  cx.stroke();
}
function ld_bubble(){ // 🫧
  cx.beginPath();cx.arc(-2,0,8,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(7,5,4,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(-5,-4,1.5,0,Math.PI*2);cx.stroke();
}
function ld_filecabinet(){ // 🗄️ archive/silo
  cx.beginPath();cx.rect(-10,-12,20,24);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-4);cx.lineTo(10,-4);
  cx.moveTo(-10,4);cx.lineTo(10,4);cx.stroke();
  cx.beginPath();cx.arc(0,-8,1,0,Math.PI*2);cx.arc(0,0,1,0,Math.PI*2);
  cx.arc(0,8,1,0,Math.PI*2);cx.fill();
}
function ld_slipper(){ // 🩴
  cx.beginPath();
  cx.moveTo(-10,4);cx.bezierCurveTo(-12,-6,12,-6,10,4);
  cx.bezierCurveTo(8,10,-8,10,-10,4);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,-3);cx.lineTo(-2,2);cx.moveTo(0,-3);cx.lineTo(2,2);cx.stroke();
}
function ld_tweezers(){ // 📐 tweezers
  cx.beginPath();cx.moveTo(-2,-12);cx.lineTo(-6,12);cx.stroke();
  cx.beginPath();cx.moveTo(2,-12);cx.lineTo(6,12);cx.stroke();
  cx.beginPath();cx.moveTo(-2,-12);cx.lineTo(2,-12);cx.stroke();
}
function ld_noose(){ // 🪢 noose
  cx.beginPath();cx.arc(0,4,7,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,-3);cx.lineTo(0,-14);cx.stroke();
  cx.beginPath();cx.moveTo(-2,-14);cx.lineTo(2,-14);cx.stroke();
}
function ld_ash(){ // ⚱️
  cx.beginPath();
  cx.moveTo(-8,-8);cx.lineTo(8,-8);cx.bezierCurveTo(12,0,12,8,8,12);
  cx.lineTo(-8,12);cx.bezierCurveTo(-12,8,-12,0,-8,-8);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-9,-8);cx.lineTo(9,-8);cx.stroke();
}
function ld_glass(){ // 🥛 fragile glass
  cx.beginPath();
  cx.moveTo(-7,-10);cx.lineTo(-5,12);cx.lineTo(5,12);cx.lineTo(7,-10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-7,-6);cx.lineTo(7,-6);cx.stroke();
}
function ld_gavel(){ // ⚖️ scales/gavel
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(0,12);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-8);cx.lineTo(10,-8);cx.stroke();
  cx.beginPath();cx.moveTo(-12,-4);cx.lineTo(-8,-4);cx.lineTo(-10,2);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(8,-4);cx.lineTo(12,-4);cx.lineTo(10,2);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-6,12);cx.lineTo(6,12);cx.stroke();
}
function ld_arrow(){ // 🏹
  cx.beginPath();cx.moveTo(-12,4);cx.bezierCurveTo(-8,-12,8,-12,12,4);cx.stroke();
  cx.beginPath();cx.moveTo(-12,4);cx.lineTo(12,4);cx.stroke();
}
function ld_ice(){ // 🧊 ice cube
  cx.beginPath();cx.rect(-10,-10,20,20);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-6);cx.lineTo(-4,-10);
  cx.moveTo(-10,0);cx.lineTo(0,-10);
  cx.stroke();
}
function ld_cement(){ // 🧱 cement
  cx.beginPath();cx.rect(-12,-8,24,16);cx.stroke();
  cx.beginPath();
  for(let i=0;i<8;i++){
    const x=-10+(i%4)*7, y=-5+Math.floor(i/4)*8;
    cx.arc(x,y,1.5,0,Math.PI*2);
  }
  cx.stroke();
}
function ld_warning(){ // ⚠️
  cx.beginPath();
  cx.moveTo(0,-12);cx.lineTo(12,10);cx.lineTo(-12,10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,-4);cx.lineTo(0,4);cx.stroke();
  cx.beginPath();cx.arc(0,7,1.2,0,Math.PI*2);cx.fill();
}
function ld_harness(){ // 🪢 harness
  cx.beginPath();cx.moveTo(-8,-10);cx.lineTo(-4,8);cx.lineTo(4,8);cx.lineTo(8,-10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-8,-2);cx.lineTo(8,-2);cx.stroke();
  cx.beginPath();cx.moveTo(0,8);cx.lineTo(0,14);cx.stroke();
}
function ld_dust(){ // 💨 dust same as mist - smaller wisps
  cx.beginPath();
  for(let i=0;i<4;i++){
    cx.beginPath();
    const y=-8+i*5;
    cx.moveTo(-12+i*2,y);cx.bezierCurveTo(-6,y-2,6,y+2,12-i*2,y);
    cx.stroke();
  }
}
function ld_ceiling(){ // 🔝 top arrow into bar
  cx.beginPath();cx.moveTo(-12,-8);cx.lineTo(12,-8);cx.stroke();
  cx.beginPath();
  cx.moveTo(0,-4);cx.lineTo(0,10);
  cx.moveTo(-6,2);cx.lineTo(0,-4);cx.lineTo(6,2);cx.stroke();
}
function ld_boomerang(){ // 🪃
  cx.beginPath();
  cx.moveTo(-12,4);cx.lineTo(-2,-8);cx.lineTo(8,-2);
  cx.lineTo(2,-2);cx.lineTo(-6,8);cx.closePath();cx.stroke();
}
function ld_weight(){ // 🪨 / weight
  cx.beginPath();cx.moveTo(-10,-6);cx.lineTo(10,-6);cx.lineTo(12,8);cx.lineTo(-12,8);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-6,-6);cx.lineTo(-6,-10);cx.lineTo(6,-10);cx.lineTo(6,-6);cx.stroke();
}
function ld_hourglass(){ // ⏳
  cx.beginPath();
  cx.moveTo(-9,-10);cx.lineTo(9,-10);
  cx.lineTo(2,0);cx.lineTo(9,10);cx.lineTo(-9,10);cx.lineTo(-2,0);cx.closePath();cx.stroke();
  // sand
  cx.beginPath();cx.moveTo(-6,-8);cx.lineTo(6,-8);cx.lineTo(1,-2);cx.lineTo(-1,-2);cx.closePath();cx.fill();
}
function ld_locket(){ // 💝 locket
  cx.beginPath();
  cx.moveTo(0,10);cx.bezierCurveTo(-12,2,-12,-8,-6,-8);
  cx.bezierCurveTo(-2,-8,0,-4,0,-2);
  cx.bezierCurveTo(0,-4,2,-8,6,-8);
  cx.bezierCurveTo(12,-8,12,2,0,10);cx.closePath();cx.stroke();
}
function ld_trap(){ // 🪤
  cx.beginPath();cx.rect(-12,-2,24,8);cx.stroke();
  cx.beginPath();cx.moveTo(-12,-2);cx.lineTo(-8,-12);cx.lineTo(8,-12);cx.lineTo(12,-2);cx.stroke();
}
function ld_megaphone(){ // 📢
  cx.beginPath();
  cx.moveTo(-12,-6);cx.lineTo(8,-10);cx.lineTo(8,10);cx.lineTo(-12,6);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(8,-4);cx.lineTo(12,-4);cx.lineTo(12,4);cx.lineTo(8,4);cx.stroke();
}
function ld_brake(){ // 🛑 stop sign / brake
  cx.beginPath();
  for(let i=0;i<8;i++){
    const a=(i/8)*Math.PI*2-Math.PI/8;
    const x=Math.cos(a)*11,y=Math.sin(a)*11;
    if(i===0)cx.moveTo(x,y);else cx.lineTo(x,y);
  }
  cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-6,0);cx.lineTo(6,0);cx.stroke();
}
function ld_coin(){ // 🪙
  cx.beginPath();cx.arc(0,0,10,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,0,7,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-3,-3);cx.lineTo(3,3);cx.moveTo(3,-3);cx.lineTo(-3,3);cx.stroke();
}
function ld_carbon(){ // 📄
  cx.beginPath();cx.rect(-10,-12,16,24);cx.stroke();
  cx.beginPath();cx.rect(-6,-8,16,24);cx.stroke();
}
function ld_treadmill(){ // 🏃 treadmill
  cx.beginPath();cx.ellipse(0,4,14,4,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-12,0);cx.lineTo(-14,8);cx.moveTo(12,0);cx.lineTo(14,8);cx.stroke();
}
function ld_spike(){ // 🦔 / spikes
  cx.beginPath();
  for(let i=0;i<7;i++){
    const x=-12+i*4;
    cx.moveTo(x,4);cx.lineTo(x+2,-8);cx.lineTo(x+4,4);
  }
  cx.stroke();
  cx.beginPath();cx.moveTo(-14,4);cx.lineTo(14,4);cx.stroke();
}
function ld_gear(){ // ⚙️
  const teeth=10;
  cx.beginPath();
  for(let i=0;i<teeth;i++){
    const a=(i/teeth)*Math.PI*2;
    const r1=11,r2=14;
    const a2=a+Math.PI/teeth;
    cx.lineTo(Math.cos(a)*r1,Math.sin(a)*r1);
    cx.lineTo(Math.cos(a)*r2,Math.sin(a)*r2);
    cx.lineTo(Math.cos(a2)*r2,Math.sin(a2)*r2);
    cx.lineTo(Math.cos(a2)*r1,Math.sin(a2)*r1);
  }
  cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(0,0,4,0,Math.PI*2);cx.stroke();
}
function ld_pipe(){ // 🧻
  cx.beginPath();cx.ellipse(0,-8,10,3,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-8);cx.lineTo(-10,10);cx.moveTo(10,-8);cx.lineTo(10,10);cx.stroke();
  cx.beginPath();cx.ellipse(0,10,10,3,0,0,Math.PI*2);cx.stroke();
}
function ld_mat(){ // 🧹 mat/broom
  cx.beginPath();cx.rect(-12,4,24,4);cx.stroke();
  cx.beginPath();
  for(let i=-10;i<=10;i+=3){
    cx.moveTo(i,8);cx.lineTo(i,12);
  }
  cx.stroke();
}
function ld_disc(){ // 💿
  cx.beginPath();cx.arc(0,0,12,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(0,0,3,0,Math.PI*2);cx.stroke();
  // scratch
  cx.beginPath();cx.moveTo(-8,-4);cx.lineTo(8,6);cx.stroke();
}
function ld_pillow(){ // 🛌
  cx.beginPath();
  cx.moveTo(-12,-6);cx.bezierCurveTo(-14,2,14,2,12,-6);
  cx.bezierCurveTo(14,6,-14,6,-12,-6);cx.stroke();
}
function ld_thimble(){ // 🧵 thimble
  cx.beginPath();
  cx.moveTo(-7,10);cx.lineTo(-7,-4);cx.bezierCurveTo(-7,-12,7,-12,7,-4);
  cx.lineTo(7,10);cx.closePath();cx.stroke();
  cx.beginPath();
  for(let i=-4;i<=4;i+=2){
    cx.arc(i,-2,0.8,0,Math.PI*2);cx.moveTo(i+2,-2);
  }
  cx.stroke();
}
function ld_cup(){ // 🥤 empty cup
  cx.beginPath();
  cx.moveTo(-8,-10);cx.lineTo(-6,12);cx.lineTo(6,12);cx.lineTo(8,-10);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(-8,-6);cx.lineTo(8,-6);cx.stroke();
}
function ld_battery(){ // 🪫 dead battery
  cx.beginPath();cx.rect(-12,-6,22,12);cx.stroke();
  cx.beginPath();cx.rect(10,-3,3,6);cx.stroke();
  cx.beginPath();cx.moveTo(-10,-2);cx.lineTo(-6,2);cx.moveTo(-6,-2);cx.lineTo(-10,2);cx.stroke();
}
function ld_gate(){ // 🚧 gate
  cx.beginPath();cx.rect(-14,-10,28,20);cx.stroke();
  cx.beginPath();
  cx.moveTo(-14,-10);cx.lineTo(14,10);
  cx.moveTo(14,-10);cx.lineTo(-14,10);cx.stroke();
}
function ld_straw(){ // 🥤 straw - bendy
  cx.beginPath();cx.moveTo(-3,-12);cx.lineTo(-3,0);cx.lineTo(8,12);cx.stroke();
  cx.beginPath();cx.moveTo(3,-12);cx.lineTo(3,0);cx.lineTo(14,12);cx.stroke();
}
function ld_island(){ // 🏝️
  cx.beginPath();cx.ellipse(0,8,12,3,0,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(0,8);cx.lineTo(2,-4);cx.stroke();
  cx.beginPath();
  cx.moveTo(-4,-4);cx.bezierCurveTo(-6,-8,8,-10,4,-4);
  cx.bezierCurveTo(8,-2,-6,-2,-4,-4);cx.stroke();
}
function ld_hook(){ // 🪝
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(0,4);cx.stroke();
  cx.beginPath();cx.arc(-4,4,4,Math.PI*1.7,Math.PI*1,true);cx.stroke();
  cx.beginPath();cx.moveTo(-2,-12);cx.lineTo(2,-12);cx.stroke();
}
function ld_abacus(){ // 🧮
  cx.beginPath();cx.rect(-12,-10,24,20);cx.stroke();
  for(let r=0;r<3;r++){
    const y=-6+r*6;
    cx.beginPath();cx.moveTo(-12,y);cx.lineTo(12,y);cx.stroke();
    for(let i=0;i<4;i++){
      cx.beginPath();cx.arc(-9+i*6,y,1.6,0,Math.PI*2);cx.stroke();
    }
  }
}
function ld_match(){ // 🧨 firework/match
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(0,8);cx.stroke();
  cx.beginPath();cx.ellipse(0,10,4,3,0,0,Math.PI*2);cx.stroke();
  // sparks
  cx.beginPath();
  cx.moveTo(0,-12);cx.lineTo(-3,-15);
  cx.moveTo(0,-12);cx.lineTo(3,-15);
  cx.moveTo(0,-12);cx.lineTo(0,-16);cx.stroke();
}
function ld_sponge(){ // 🧽
  cx.beginPath();cx.rect(-12,-8,24,16);cx.stroke();
  for(let i=0;i<6;i++){
    cx.beginPath();
    cx.arc(-9+(i%3)*9,-4+Math.floor(i/3)*8,1.5,0,Math.PI*2);
    cx.stroke();
  }
}
function ld_sail(){ // ⛵
  cx.beginPath();cx.moveTo(-12,8);cx.lineTo(12,8);cx.lineTo(8,12);cx.lineTo(-8,12);cx.closePath();cx.stroke();
  cx.beginPath();cx.moveTo(0,8);cx.lineTo(0,-12);cx.stroke();
  cx.beginPath();cx.moveTo(0,-12);cx.lineTo(10,6);cx.lineTo(0,6);cx.closePath();cx.stroke();
}
function ld_bandage(){ // 🩹
  cx.beginPath();cx.save();cx.rotate(-Math.PI/6);
  cx.rect(-14,-4,28,8);cx.stroke();
  for(let x=-10;x<=10;x+=5){
    cx.beginPath();cx.arc(x,-4,0.8,0,Math.PI*2);cx.arc(x,4,0.8,0,Math.PI*2);cx.fill();
  }
  cx.restore();
}
function ld_vine(){ // 🌿
  cx.beginPath();
  cx.moveTo(-10,10);cx.bezierCurveTo(-2,4,-2,-4,10,-10);cx.stroke();
  // leaves
  cx.beginPath();
  cx.ellipse(-6,4,3,2,Math.PI/4,0,Math.PI*2);cx.stroke();
  cx.beginPath();
  cx.ellipse(4,-2,3,2,-Math.PI/4,0,Math.PI*2);cx.stroke();
}
function ld_snail(){ // 🐌
  cx.beginPath();cx.arc(-2,2,8,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(-2,2,4,0,Math.PI*2);cx.stroke();
  cx.beginPath();
  cx.moveTo(-10,10);cx.lineTo(10,10);cx.lineTo(8,6);cx.stroke();
  // antennas
  cx.beginPath();cx.moveTo(8,6);cx.lineTo(10,-2);
  cx.moveTo(10,-2);cx.arc(10,-3,1,0,Math.PI*2);
  cx.moveTo(12,6);cx.lineTo(14,-1);cx.stroke();
}
function ld_wishbone(){ // 🦴
  cx.beginPath();
  cx.moveTo(-8,12);cx.bezierCurveTo(-12,4,-6,-8,0,-8);
  cx.bezierCurveTo(6,-8,12,4,8,12);cx.stroke();
  cx.beginPath();cx.arc(-8,12,2,0,Math.PI*2);
  cx.arc(8,12,2,0,Math.PI*2);cx.stroke();
}
function ld_shell(){ // 🐚
  cx.beginPath();
  cx.moveTo(0,12);cx.bezierCurveTo(-14,8,-14,-8,0,-12);
  cx.bezierCurveTo(14,-8,14,8,0,12);cx.stroke();
  for(let i=0;i<5;i++){
    const t=i/4;
    cx.beginPath();
    cx.moveTo(0,-12+t*4);cx.lineTo(0,12);
    cx.stroke();
  }
}
function ld_lure(){ // 🪱 / lure
  cx.beginPath();
  cx.moveTo(-12,-2);cx.bezierCurveTo(-8,4,8,-4,12,2);cx.stroke();
  cx.beginPath();cx.arc(-12,-2,1.5,0,Math.PI*2);cx.fill();
  cx.beginPath();cx.arc(12,2,2,0,Math.PI*2);cx.stroke();
}
function ld_scissors(){ // ✂️
  cx.beginPath();cx.arc(-6,4,4,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(6,4,4,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-3,1);cx.lineTo(8,-12);cx.stroke();
  cx.beginPath();cx.moveTo(3,1);cx.lineTo(-8,-12);cx.stroke();
}
function ld_couch(){ // 🛋️
  cx.beginPath();cx.rect(-14,-4,28,10);cx.stroke();
  cx.beginPath();cx.rect(-14,-10,28,8);cx.stroke();
  cx.beginPath();cx.rect(-16,-6,4,12);cx.stroke();
  cx.beginPath();cx.rect(12,-6,4,12);cx.stroke();
}
function ld_shovel(){ // 🪚 / shovel
  cx.beginPath();cx.moveTo(0,-14);cx.lineTo(0,4);cx.stroke();
  cx.beginPath();cx.moveTo(-2,-14);cx.lineTo(2,-14);cx.stroke();
  cx.beginPath();
  cx.moveTo(-6,4);cx.lineTo(6,4);cx.lineTo(8,10);cx.lineTo(-8,10);cx.closePath();cx.stroke();
}
function ld_paperweight(){ // 📎 paperclip / paperweight
  cx.beginPath();
  cx.moveTo(-4,-12);cx.lineTo(-4,8);cx.bezierCurveTo(-4,12,4,12,4,8);
  cx.lineTo(4,-8);cx.bezierCurveTo(4,-12,-2,-12,-2,-8);cx.lineTo(-2,6);
  cx.stroke();
}
function ld_leak(){ // 🚰 leak
  cx.beginPath();cx.rect(-8,-12,16,8);cx.stroke();
  cx.beginPath();cx.moveTo(-3,-4);cx.lineTo(-3,2);cx.lineTo(3,2);cx.lineTo(3,-4);cx.stroke();
  // drips
  cx.beginPath();cx.arc(0,8,2,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.arc(-5,12,1.5,0,Math.PI*2);cx.stroke();
}
function ld_bell(){ // 🔔
  cx.beginPath();
  cx.moveTo(-9,6);cx.bezierCurveTo(-9,-10,9,-10,9,6);cx.lineTo(11,6);cx.lineTo(11,9);cx.lineTo(-11,9);cx.lineTo(-11,6);cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(0,12,1.5,0,Math.PI*2);cx.stroke();
}
function ld_bucket(){ // 🪣
  cx.beginPath();
  cx.moveTo(-10,-8);cx.lineTo(-8,10);cx.lineTo(8,10);cx.lineTo(10,-8);cx.closePath();cx.stroke();
  cx.beginPath();cx.arc(0,-8,10,0,Math.PI,true);cx.stroke();
}
function ld_plug(){ // 🔌
  cx.beginPath();cx.rect(-8,-2,16,12);cx.stroke();
  cx.beginPath();cx.moveTo(-4,-2);cx.lineTo(-4,-8);cx.moveTo(4,-2);cx.lineTo(4,-8);cx.stroke();
  cx.beginPath();cx.moveTo(0,10);cx.lineTo(0,14);cx.stroke();
}
function ld_cliff(){ // ⚠️ cliff
  cx.beginPath();
  cx.moveTo(-14,12);cx.lineTo(0,12);cx.lineTo(0,-8);cx.lineTo(14,-8);cx.stroke();
}
function ld_badge(){ // 🪪
  cx.beginPath();cx.rect(-12,-8,24,16);cx.stroke();
  cx.beginPath();cx.arc(-6,-2,2,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(-2,-3);cx.lineTo(8,-3);
  cx.moveTo(-2,1);cx.lineTo(8,1);
  cx.moveTo(-2,5);cx.lineTo(8,5);cx.stroke();
}
function ld_rust(){ // ⚙️ rust - gear with marks
  ld_gear();
  cx.beginPath();
  cx.moveTo(-6,-2);cx.lineTo(-2,2);cx.moveTo(2,-2);cx.lineTo(6,2);cx.stroke();
}
function ld_pill(){ // 💊
  cx.beginPath();
  cx.moveTo(-12,0);cx.bezierCurveTo(-12,-6,-2,-6,-2,0);cx.lineTo(-2,0);
  cx.moveTo(12,0);cx.bezierCurveTo(12,6,2,6,2,0);
  cx.stroke();
  cx.beginPath();
  cx.rect(-12,-4,12,8);cx.stroke();
  cx.beginPath();
  cx.rect(0,-4,12,8);cx.stroke();
}
function ld_bridge(){ // 🌉
  cx.beginPath();cx.moveTo(-14,8);cx.lineTo(14,8);cx.stroke();
  cx.beginPath();
  cx.moveTo(-12,8);cx.bezierCurveTo(-8,-4,8,-4,12,8);cx.stroke();
  // cables
  cx.beginPath();
  for(let x=-10;x<=10;x+=4){
    cx.moveTo(x,2);cx.lineTo(x,8);
  }
  cx.stroke();
}
function ld_brokenlock(){ // 🔓 broken/open lock
  cx.beginPath();
  cx.moveTo(-6,-2);cx.lineTo(-6,-8);
  cx.bezierCurveTo(-6,-14,6,-14,6,-8);cx.stroke();
  // Shackle broken — gap at bottom right
  cx.beginPath();cx.rect(-9,-2,18,14);cx.stroke();
  // Crack line through body
  cx.beginPath();cx.moveTo(-7,2);cx.lineTo(7,6);cx.stroke();
}
function ld_trophy(){ // 🏆
  // Cup body
  cx.beginPath();
  cx.moveTo(-7,-10);cx.lineTo(7,-10);
  cx.lineTo(7,0);cx.bezierCurveTo(7,6,-7,6,-7,0);cx.closePath();cx.stroke();
  // Handles
  cx.beginPath();cx.arc(-9,-5,3,Math.PI/2,Math.PI*1.5,false);cx.stroke();
  cx.beginPath();cx.arc(9,-5,3,Math.PI*1.5,Math.PI/2,false);cx.stroke();
  // Stem and base
  cx.beginPath();cx.moveTo(0,6);cx.lineTo(0,10);cx.stroke();
  cx.beginPath();cx.moveTo(-5,12);cx.lineTo(5,12);cx.stroke();
  cx.beginPath();cx.rect(-7,10,14,2);cx.stroke();
}
function ld_fog(){ // 🌁 fog/mist horizontal bands
  cx.beginPath();
  cx.moveTo(-13,-6);cx.bezierCurveTo(-6,-9,6,-3,13,-6);cx.stroke();
  cx.beginPath();
  cx.moveTo(-13,-1);cx.bezierCurveTo(-6,-4,6,2,13,-1);cx.stroke();
  cx.beginPath();
  cx.moveTo(-13,4);cx.bezierCurveTo(-6,1,6,7,13,4);cx.stroke();
  cx.beginPath();
  cx.moveTo(-13,9);cx.bezierCurveTo(-6,6,6,12,13,9);cx.stroke();
}
function ld_topArrow(){ // 🔝 arrow pointing up with TOP bar
  // Horizontal bar at top
  cx.beginPath();cx.moveTo(-12,-10);cx.lineTo(12,-10);cx.stroke();
  // Vertical shaft
  cx.beginPath();cx.moveTo(0,-6);cx.lineTo(0,10);cx.stroke();
  // Arrowhead
  cx.beginPath();
  cx.moveTo(-6,0);cx.lineTo(0,-6);cx.lineTo(6,0);cx.stroke();
}
function ld_phone(){ // 📱
  // Phone body
  cx.beginPath();cx.rect(-7,-12,14,24);cx.stroke();
  // Screen inside
  cx.beginPath();cx.rect(-5,-9,10,17);cx.stroke();
  // Home button at bottom
  cx.beginPath();cx.arc(0,10,1.2,0,Math.PI*2);cx.stroke();
  // Speaker at top
  cx.beginPath();cx.moveTo(-2,-11);cx.lineTo(2,-11);cx.stroke();
}

// Master emoji -> drawing function map
const EMOJI_DRAW={
  '🪨':ld_boulder,'🔨':ld_anvil,'⚓':ld_anchor,'🎭':ld_mask,'⛓️':ld_chain,
  '🔒':ld_lock,'🔐':ld_lock,'🫣':ld_blindfold,'🙈':ld_blindfold,
  '💣':ld_bomb,'🏺':ld_vase,'🕸️':ld_cage,'🪞':ld_mirror,'👑':ld_crown,
  '🧱':ld_brick,'🛡️':ld_shield,'🐕':ld_leash,'🌫️':ld_shroud,
  '💥':ld_explosion,'🎲':ld_dice,'🔇':ld_earplugs,'🔗':ld_link,
  '🕳️':ld_drain,'🪓':ld_axe,'🩼':ld_crutch,'❄️':ld_avalanche,
  '🪦':ld_tombstone,'☁️':ld_cloud,'🗿':ld_stone,'🤐':ld_muzzle,
  '📿':ld_collar,'🪢':ld_knot,'🪵':ld_log,'🎒':ld_sack,'🎯':ld_dart,
  '📦':ld_box,'🎈':ld_balloon,'📚':ld_books,'💨':ld_dust,
  '🤫':ld_whisper,'🚧':ld_fence,'🫧':ld_bubble,'🗄️':ld_filecabinet,
  '🩴':ld_slipper,'📐':ld_tweezers,'⚱️':ld_ash,'🥛':ld_glass,
  '⚖️':ld_gavel,'🏹':ld_arrow,'🧊':ld_ice,'⚠️':ld_warning,
  '💝':ld_locket,'🪤':ld_trap,'📢':ld_megaphone,'🛑':ld_brake,
  '🪙':ld_coin,'📄':ld_carbon,'🏃':ld_treadmill,'🦔':ld_spike,
  '⚙️':ld_gear,'🧻':ld_pipe,'⏳':ld_hourglass,'🧹':ld_mat,
  '💿':ld_disc,'🛌':ld_pillow,'🧵':ld_thimble,'🥤':ld_cup,
  '🪫':ld_battery,'🚧':ld_gate,'🏝️':ld_island,'🪝':ld_hook,
  '🧮':ld_abacus,'🧨':ld_match,'🧽':ld_sponge,'⛵':ld_sail,
  '🩹':ld_bandage,'🌿':ld_vine,'🐌':ld_snail,'🦴':ld_wishbone,
  '🐚':ld_shell,'🪱':ld_lure,'✂️':ld_scissors,'🛋️':ld_couch,
  '🪚':ld_shovel,'📎':ld_paperweight,'🚰':ld_leak,'🔔':ld_bell,
  '🪣':ld_bucket,'🔌':ld_plug,'🪪':ld_badge,'💊':ld_pill,
  '🌉':ld_bridge,'🐂':ld_anvil,'⏰':ld_hourglass,'🪛':ld_anvil,
  '📋':ld_carbon,'📒':ld_books,
  '🔝':ld_topArrow,'🪃':ld_boomerang,'🌁':ld_fog,
  '🏆':ld_trophy,'🔓':ld_brokenlock,'📱':ld_phone
};

// Draw the shape in B&W lines. No fills, no color.
function dShapeLine(b,emoji,kind){
  T(b,()=>{
    // Color shapes by kind: cyan glow for positives, red glow for negatives
    const isPos=kind==='pos';
    const col=isPos?'#4FC3F7':'#FF5252';
    const glow=isPos?'rgba(79,195,247,.85)':'rgba(255,82,82,.85)';
    cx.shadowColor=glow;
    cx.shadowBlur=10;
    cx.strokeStyle=col;
    cx.fillStyle=col;
    cx.lineWidth=1.6;
    cx.lineCap='round';
    cx.lineJoin='round';
    const fn=EMOJI_DRAW[emoji];
    if(fn){
      fn();
    }else{
      // Fallback: simple circle
      cx.beginPath();cx.arc(0,0,10,0,Math.PI*2);cx.stroke();
      cx.beginPath();cx.moveTo(-4,-2);cx.lineTo(4,-2);
      cx.moveTo(-4,2);cx.lineTo(4,2);cx.stroke();
    }
    cx.shadowBlur=0;
  });
}

// Auto-register shapes for every word in every category
function registerLineShape(word,emoji,isPos){
  if(S[word])return;
  // Body sized to roughly match the line drawing
  const bodyW=28,bodyH=28;
  S[word]={
    kind:isPos?'pos':'neg',
    label:isPos?'pos:water':'neg',
    body:(x,y)=>Bodies.rectangle(x,y,bodyW,bodyH,
      bo(isPos?
        {density:.0008,friction:.05,frictionAir:.02,restitution:.4,label:'pos:water'}:
        {label:'neg'})),
    draw:(b)=>dShapeLine(b,emoji,isPos?'pos':'neg'),
    emoji:emoji
  };
}
// Register positive words with effect-specific bodies
function registerPosShape(word,effect){
  if(S[word])return;
  // Each effect type uses different physics + visual
  let body, label;
  if(effect==='water'){
    // Water drop - small circle, denser, splashes
    body=(x,y)=>Bodies.circle(x,y,9,bo({density:.0008,friction:.02,frictionAir:.02,restitution:.45,label:'pos:water'}));
    label='pos:water';
  }else if(effect==='wave'){
    // Wave burst - medium circle, very light, ripples wide
    body=(x,y)=>Bodies.circle(x,y,18,bo({density:.0003,friction:0,frictionAir:.05,restitution:.15,label:'pos:breath'}));
    label='pos:breath';
  }else{ // shock
    // Shock - diamond shape, pushes neighbors strongly
    body=(x,y)=>Bodies.polygon(x,y,4,12,bo({density:.0015,restitution:.55,label:'pos:spark'}));
    label='pos:spark';
  }
  S[word]={
    kind:'pos',
    label:label,
    effect:effect,
    body:body,
    draw:(b)=>dPositive(b,word,effect)
  };
}

// Draw positives - water drop, wave burst, or shock star
function dPositive(b,word,effect){
  T(b,()=>{
    cx.strokeStyle='#fff';
    cx.fillStyle='#fff';
    cx.lineWidth=1.5;
    cx.lineCap='round';
    cx.lineJoin='round';
    if(effect==='water'){
      // Water drop - teardrop shape
      cx.beginPath();
      cx.moveTo(0,-9);
      cx.bezierCurveTo(7,-3,7,7,0,8);
      cx.bezierCurveTo(-7,7,-7,-3,0,-9);
      cx.closePath();
      cx.stroke();
      // highlight
      cx.beginPath();
      cx.arc(-2,2,2,0,Math.PI*2);
      cx.stroke();
    }else if(effect==='wave'){
      // Wave burst - concentric ripples
      cx.globalAlpha=0.5;
      cx.beginPath();cx.arc(0,0,16,0,Math.PI*2);cx.stroke();
      cx.globalAlpha=0.7;
      cx.beginPath();cx.arc(0,0,11,0,Math.PI*2);cx.stroke();
      cx.globalAlpha=1;
      cx.beginPath();cx.arc(0,0,6,0,Math.PI*2);cx.stroke();
    }else{
      // Shock - 4-pointed star
      cx.beginPath();
      cx.moveTo(0,-12);cx.lineTo(3,-3);cx.lineTo(12,0);cx.lineTo(3,3);
      cx.lineTo(0,12);cx.lineTo(-3,3);cx.lineTo(-12,0);cx.lineTo(-3,-3);
      cx.closePath();
      cx.stroke();
      // inner star
      cx.beginPath();
      cx.moveTo(0,-5);cx.lineTo(1,-1);cx.lineTo(5,0);cx.lineTo(1,1);
      cx.lineTo(0,5);cx.lineTo(-1,1);cx.lineTo(-5,0);cx.lineTo(-1,-1);
      cx.closePath();
      cx.fill();
    }
  });
}

// Register all words from all categories with their emojis
Object.values(CATEGORY_DATA).forEach(d=>{
  d.words.forEach(w=>registerLineShape(w.name,w.emoji,false));
  d.pos.forEach(p=>registerPosShape(p.name,p.effect));
});

// ---------- Game state ----------
const PH={INTRO:'intro',SHOW:'show',EJECT:'eject',FALL:'fall',CHOICE:'choice',DRAG:'drag',SETTLE:'settle',FULL:'full'};
const state={
  phase:PH.INTRO,t:0,category:'self',
  housing:[],       // {word,x,y,vx,vy,kind} list for animated housing decorations
  falling:[],       // words traveling from housing to lightbulb
  choice:[],        // words at the lightbulb
  drag:null,        // {word,kind,x,y,vx,vy,px,py} attached to finger
  shapes:[],        // physics shapes inside the brain
  fx:[],            // visual effects (waves, sparks)
  flow:0,           // overall flow level (water level) 0..1
  hitWater:0,       // water from hits (3 hits worth = 0.15)
  missWater:0,      // water from misses (1 drop worth = 0.02)
  round:0,
  burnoutIntensity:0,  // 0..1 — red overload tint strength during PH.FULL
  burnoutShake:0,      // 0..1 — screen-shake amount, decays each frame
  brainShake:0,        // 0..1 — HUD brain icon red-shake when negative spawns, decays fast
  erases:0,            // running tally of negatives the player has cleared
  procCooldown:0,      // ms before procrastinate button can be tapped again
  procBonus:false,     // true after procrastinate: next CHOICE forces 2 positives
  positiveStreak:0,    // counts positives consumed; every 3 fires an auto-zap
  zapPending:false,    // true between streak hitting 3 and zap firing
  // Personality judgment — fills based on choice patterns
  personality:{
    fighter:0,   // positives chosen + zaps fired
    dreamer:0,   // core mindfulness habits (water, breathing, cleaning)
    quitter:0,   // negatives accepted into the brain
    rebel:0      // procrastinate presses + chaos-seeking
  }
};

// ---------- Round flow ----------
function pickPair(){
  // Fisher-Yates shuffle pool. Targets a 5:1 negative-to-positive ratio
  // so positive water drops appear ~1/5 as often as negative items.
  // Per category: 100 negs + 100 pos + 3 core pos.
  // Weights: negs ×5 (500 instances), category pos ×1 (100 instances),
  //          core pos ×3 (9 instances). Total pos ≈ 109. Ratio ≈ 4.6:1 ≈ 5:1.
  const d=CATEGORY_DATA[state.category];
  const pool=[];
  d.words.forEach(w=>{for(let i=0;i<5;i++)pool.push(w.name);});
  d.pos.forEach(p=>{pool.push(p.name);});
  CORE_POS.forEach(w=>{for(let i=0;i<3;i++)pool.push(w);});
  shuffleArray(pool);
  const w1=pool[0];
  let w2=pool[1];
  let k=2;
  while(w2===w1&&k<pool.length){w2=pool[k++];}
  return [w1,w2];
}

function kindOf(w){
  return WORD_KIND.get(w)||'neg';
}

function emojiOf(w){
  return WORD_EMOJI.get(w)||'';
}

function populateHousing(){
  const d=CATEGORY_DATA[state.category];
  const all=d.words.map(w=>w.name);
  // Only show a SAMPLE of 12 words per round (not all 100) so the housing
  // doesn't overwhelm the eye and animations remain visible
  const shuffled=shuffleArray([...all]);
  const sample=shuffled.slice(0,12);
  // Loose grid: 4 cols × 3 rows
  const N=sample.length;
  const cols=4,rows=Math.ceil(N/cols);
  state.housing=sample.map((word,i)=>{
    const col=i%cols, row=Math.floor(i/cols);
    const baseX=(col-cols/2+0.5)*(L.HW*0.85/cols);
    const baseY=(row-rows/2+0.5)*(L.HH*0.85/rows);
    return{
      word,
      kind:'neg',
      main:i<5,
      bx:baseX+(Math.random()-0.5)*4,
      by:baseY+(Math.random()-0.5)*3,
      phase:Math.random()*Math.PI*2,
      speed:0.3+Math.random()*0.4
    };
  });
}

function startRound(){
  state.round++;
  populateHousing();
  let w1,w2;
  if(state.procBonus){
    // After PROCRASTINATE: reward player with 2 positive words to help fight back
    state.procBonus=false;
    const d=CATEGORY_DATA[state.category];
    const posPool=[];
    d.pos.forEach(p=>posPool.push(p.name));
    CORE_POS.forEach(w=>posPool.push(w));
    shuffleArray(posPool);
    w1=posPool[0];
    w2=posPool[1]||posPool[0]; // fallback if pool tiny
    // Flash a "2x BOOST" popup
    const sp=document.getElementById('streakPopup');
    if(sp){
      sp.textContent='2× BOOST!';
      sp.style['-webkit-text-fill-color']='#4FC3F7';
      sp.style.filter='drop-shadow(0 0 16px rgba(79,195,247,.9))';
      sp.style.opacity='1';
      sp.style.transform='translateX(-50%) scale(1.1)';
      setTimeout(()=>{
        sp.style.opacity='0';sp.style.transform='translateX(-50%) scale(0.8)';
        sp.style['-webkit-text-fill-color']='';sp.style.filter='';
      },1200);
    }
  }else{
    [w1,w2]=pickPair();
  }
  // Both start from housing exit, then split toward left/right of bulb (wide spread)
  state.falling=[
    {word:w1,kind:kindOf(w1),x:W*0.5,y:L.HEXIT,vy:0,target:W*0.27},
    {word:w2,kind:kindOf(w2),x:W*0.5,y:L.HEXIT,vy:0,target:W*0.73}
  ];
  state.choice=[];state.drag=null;
  state.phase=PH.SHOW;state.t=0;
  updHUD();
}

function updHUD(){
  document.getElementById('cat').textContent=CATEGORY_DATA[state.category].label;
  // Color HUD label to match the active brain network
  const _nCol={quantum:'#FF69B4',self:'#B464FF',parenting:'#40C4FF',engineer:'#64E682',senior:'#FFC832'};
  document.getElementById('cat').style.color=_nCol[state.category]||'rgba(79,195,247,.7)';
  document.getElementById('cat').style.textShadow=`0 0 12px ${_nCol[state.category]||'#4FC3F7'}88`;
  document.getElementById('ph').textContent={intro:'pick',show:'thinking',eject:'releasing',
    fall:'falling',choice:'choose',drag:'drag to brain',settle:'settling',full:'overflow'}[state.phase]||'·';
  const flowPct=Math.min(100,Math.round(state.flow*100));
  document.getElementById('pct').textContent=flowPct+'%';
  document.getElementById('fill').style.width=flowPct+'%';
  // Erase counter — number of negatives cleared, formatted as 4-digit pad
  const ec=document.getElementById('eraseCount');
  if(ec)ec.textContent='CLEARED '+String(state.erases).padStart(4,'0');
  // Show or hide procrastinate button based on phase
  const pb=document.getElementById('procBtn');
  if(pb&&pb.classList&&pb.classList.toggle){
    const active=state.phase!==PH.INTRO&&state.phase!==PH.FULL;
    pb.classList.toggle('show',active);
  }
  // Position the flow bar just below the brain
  const hudBot=document.getElementById('hudBot');
  if(L.BB){
    hudBot.style.top=(L.BB+8)+'px';
  }
}

// ---------- Streak popup (addictive feedback for chained positive hits) ----------
let streakPopTimer=null;
function showStreakPopup(n){
  const el=document.getElementById('streakPopup');
  if(!el)return;
  // Big COMBO X[n] style label
  let label;
  if(n===2)label='COMBO X2';
  else if(n===3)label='COMBO X3';
  else if(n===4)label='MINDFUL X4';
  else if(n===5)label='ZEN X5';
  else if(n>=6)label='ENLIGHTENED X'+n;
  else return;
  el.textContent=label;
  el.classList.remove('pop');
  // force reflow so animation restarts even if already showing
  void el.offsetWidth;
  el.classList.add('pop');
  if(streakPopTimer)clearTimeout(streakPopTimer);
  streakPopTimer=setTimeout(()=>{el.classList.remove('pop');},900);
}

// ---------- Progress persistence (localStorage) ----------
// Tracks which categories the player has reached flow state in.
function loadProgress(){
  try{
    const raw=localStorage.getItem('mre_progress_v1');
    if(!raw)return{cleared:[]};
    return JSON.parse(raw);
  }catch(e){return{cleared:[]};}
}
function saveProgress(p){
  try{localStorage.setItem('mre_progress_v1',JSON.stringify(p));}catch(e){}
}
function markCategoryCleared(cat){
  const p=loadProgress();
  if(!p.cleared.includes(cat)){
    p.cleared.push(cat);
    saveProgress(p);
  }
  refreshIntroBadges();
}
function refreshIntroBadges(){
  const p=loadProgress();
  document.querySelectorAll('.gallery-frame[data-cat]').forEach(btn=>{
    if(p.cleared.includes(btn.dataset.cat)){
      btn.classList.add('cleared');
    }else{
      btn.classList.remove('cleared');
    }
  });
}

// ---------- Phase ticker ----------
function tickPhase(dt){
  state.t+=dt;
  if(state.phase===PH.SHOW){
    // very short pre-fall display
    if(state.t>200){state.phase=PH.EJECT;state.t=0;}
  }else if(state.phase===PH.EJECT){
    if(state.t>150){state.phase=PH.FALL;state.t=0;}
  }else if(state.phase===PH.FALL){
    const targetY=L.BY+L.BR*.3;
    state.falling.forEach(f=>{
      f.vy+=1.4*(dt/16.67);
      f.y+=f.vy*(dt/16.67);
      f.x+=(f.target-f.x)*0.12;
      // Track motion trail (last 5 positions for ghosting effect)
      if(!f.trail)f.trail=[];
      f.trail.push({x:f.x,y:f.y});
      if(f.trail.length>6)f.trail.shift();
    });
    if(state.falling.every(f=>f.y>=targetY)){
      state.falling.forEach(f=>{f.y=targetY;f.vy=0;});
      state.phase=PH.CHOICE;state.t=0;
      state.choice=state.falling.map(f=>({word:f.word,kind:f.kind,x:f.x,y:f.y,vanish:0}));
      state.falling=[];
      updHUD();
    }
  }else if(state.phase===PH.SETTLE){
    const allSettled=state.shapes.length===0||state.shapes.every(s=>{
      if(s.dead)return true;
      return Math.hypot(s.body.velocity.x,s.body.velocity.y)<0.55;
    });
    if(allSettled&&state.t>1800){  // longer wait lets Peggle bouncing fully settle
      // Check for overflow
      const overflow=state.shapes.some(s=>!s.dead&&s.body.position.y<L.BT-10);
      if(overflow){triggerFull();}else{startRound();}
    }
  }
}

// ---------- Water level update ----------
function updateFlow(){
  // 3 hits = 0.15, missed = 0.02 each
  state.flow=Math.min(1,state.hitWater+state.missWater*0.4);
  updHUD();
  if(state.flow>=1&&state.phase!==PH.FULL){
    triggerFull();
  }
}

// ---------- Shape spawning ----------
// Negatives drift weightlessly around the container. Positives never enter physics
// at all — they are handled by consumePositive() instead, which adds water and
// counts toward the auto-zap streak.
function spawnShape(word,x,y,vx,vy){
  const def=S[word];if(!def)return null;
  if(def.kind==='pos'){
    // PEGGLE: positives also become falling physics balls.
    // They bounce through the pins and consume when they hit a negative OR reach the floor.
    const pBody=Bodies.circle(x,y,9,{density:.0014,friction:.12,frictionAir:.018,
      restitution:.55,label:'pos:fall'});
    pBody.gravityScale=1;
    Body.setVelocity(pBody,{x:(Math.random()-0.5)*1.4, y:0.8+(vy||0)*0.15});
    Composite.add(eng.world,pBody);
    const POS_BLOCK_COLS=['#00ACC1','#43A047','#1E88E5','#FDD835','#00897B','#7CB342','#0288D1','#26A69A'];
    const posColor=POS_BLOCK_COLS[Math.floor(Math.random()*POS_BLOCK_COLS.length)];
    const ps={body:pBody,def,word,hits:0,dead:false,kind:'pos',
              age:0,floatPhase:0,floatSpeed:0,color:posColor};
    state.shapes.push(ps);
    sparkBgAt(x,y,80);
    // Increment fighter personality
    state.personality.fighter+=0.5;
    return ps;
  }
  // ── HEXAGON BODY — rolls and tumbles as it bounces off brain fold lines ──
  // Hexagons spin naturally, creating a rolling cascade effect that fills the bottom.
  // Icosagon size scales with word length — longer/heavier negatives are bigger
  const wordLen=(word||'').length;
  const HEX_R=wordLen<=7?10:wordLen<=13?15:20;  // light/medium/heavy weight
  const body=Bodies.polygon(x,y,20,HEX_R,{
    density:0.003,       // heavy enough to fall fast and stack solidly
    friction:0.60,       // grips fold ramps well
    frictionAir:0.015,   // light air drag — falls firmly
    restitution:0.20,    // very little bounce so words settle at bottom
    label:'neg'
  });
  body.gravityScale=1;
  // Give a slight random spin so each word tumbles differently
  Body.setVelocity(body,{x:(Math.random()-0.5)*1.8, y:0.5});
  Body.setAngularVelocity(body,(Math.random()-0.5)*0.12);
  Composite.add(eng.world,body);
  const NEG_COLS=['#E53935','#C62828','#AD1457','#7B1FA2','#F57C00','#BF360C','#6A1B9A','#D32F2F','#880E4F','#E64A19'];
  const blockColor=NEG_COLS[Math.floor(Math.random()*NEG_COLS.length)];
  const s={body,def,word,hits:0,dead:false,kind:'neg',age:0,
           floatPhase:0,floatSpeed:0,color:blockColor,hexR:HEX_R,wordSev:HEX_R};
  state.shapes.push(s);
  sparkBgAt(x,y,100);
  // Pulse the HUD brain icon red — gives tactile feedback that the brain took a hit
  state.brainShake=Math.min(1.0, (state.brainShake||0)+0.55);
  // --- Personality scoring ---
  state.personality.quitter+=1;
  // Negatives still nudge the missWater so a brain stuffed with them flirts with overflow
  state.missWater=Math.min(1,state.missWater+0.025);
  updateFlow();
  return s;
}

// ---------- Positive consumption (new mechanic) ----------
// Called when the player drops a positive word over the container. Adds water,
// emits a splash burst, and counts toward the every-three-positives auto-zap.
function consumePositive(word,x,y){
  // Add a bigger chunk of water than the old per-hit amount, since each positive
  // is "spent" entirely rather than slowly chipping at negatives.
  state.hitWater=Math.min(1,state.hitWater+0.10);
  updateFlow();
  // Splash particles — cyan droplets bursting outward from the drop point
  for(let i=0;i<18;i++){
    const a=Math.random()*Math.PI*2,sp=1.5+Math.random()*3;
    state.fx.push({type:'burst',x,y,
      vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-1.5,
      life:700,maxLife:700,c:'#4FC3F7',size:2+Math.random()*2});
  }
  // Twin cyan shockwave rings
  state.fx.push({type:'ring',x,y,r:0,maxR:55,life:500,maxLife:500,c:'#4FC3F7',lw:2});
  state.fx.push({type:'ring',x,y,r:0,maxR:95,life:700,maxLife:700,c:'#B3E5FC',lw:1.2});
  sparkBgAt(x,y,160);
  // Streak progression — every third positive arms a lightning zap
  state.positiveStreak++;
  if(state.positiveStreak>=3&&!state.zapPending){
    state.zapPending=true;
    setTimeout(triggerZap,260); // brief beat so the player feels the build-up
  }
  // --- Personality scoring ---
  state.personality.fighter+=1;
  // Dreamer: core mindfulness habits score extra
  if(CORE_POS.includes(word)) state.personality.dreamer+=2.5;
  else state.personality.dreamer+=0.4;
}

// ---------- Auto-zap (lightbulb shoots at a floating negative) ----------
function triggerZap(){
  state.zapPending=false;
  state.positiveStreak=0;
  // Find a living negative to zap (closest to the lightbulb gets priority for visual clarity)
  const lives=state.shapes.filter(s=>!s.dead&&s.kind==='neg');
  if(lives.length===0)return;
  // Sort by distance from bulb so the zap doesn't traverse the whole screen
  const bx=W/2,by=L.BY;
  lives.sort((a,b)=>{
    const da=Math.hypot(a.body.position.x-bx,a.body.position.y-by);
    const db=Math.hypot(b.body.position.x-bx,b.body.position.y-by);
    return da-db;
  });
  // Take a random target from the top-3 closest (gives a bit of variety)
  const target=lives[Math.floor(Math.random()*Math.min(3,lives.length))];
  const tx=target.body.position.x,ty=target.body.position.y;
  // Spawn the lightning beam FX
  state.fx.push({type:'zap',x1:bx,y1:by,x2:tx,y2:ty,
    life:520,maxLife:520,segments:buildLightningSegments(bx,by,tx,ty)});
  // Brief screen pulse + spark on impact
  state.screenPulse=(state.screenPulse||0)+0.6;
  sparkBgAt(tx,ty,180);
  // --- Personality scoring: zapping is a fighter move ---
  state.personality.fighter+=0.8;
  // Dissolve the target after the beam has had a moment to draw
  setTimeout(()=>{
    if(!target.dead)dissolve(target);
  },220);
}

// Build a jagged lightning path between two points (used by the zap FX)
function buildLightningSegments(x1,y1,x2,y2){
  const segs=[{x:x1,y:y1}];
  const steps=10;
  const dx=x2-x1,dy=y2-y1;
  const len=Math.hypot(dx,dy)||1;
  const nx=-dy/len,ny=dx/len; // perpendicular for jitter
  for(let i=1;i<steps;i++){
    const tt=i/steps;
    const offset=(Math.random()-0.5)*22*(1-Math.abs(tt-0.5)*1.4); // tapers at endpoints
    segs.push({
      x:x1+dx*tt+nx*offset,
      y:y1+dy*tt+ny*offset
    });
  }
  segs.push({x:x2,y:y2});
  return segs;
}

function dissolve(s){
  if(s.dead)return;
  s.dead=true;
  // Tally cleared negatives for the HUD counter
  if(s.kind==='neg')state.erases++;
  const sx=s.body.position.x,sy=s.body.position.y;
  // DRAMATIC NEON BURST: 28 colored fragments shooting outward
  for(let i=0;i<28;i++){
    const a=(i/28)*Math.PI*2+Math.random()*0.3;
    const sp=2+Math.random()*5;
    state.fx.push({type:'burst',x:sx,y:sy,
      vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-1,
      life:900,maxLife:900,c:'#FF5252',size:2+Math.random()*2});
  }
  // SHIMMER particles - smaller, longer life, drift slowly
  for(let i=0;i<14;i++){
    const a=Math.random()*Math.PI*2,sp=0.4+Math.random()*1.2;
    state.fx.push({type:'shimmer',x:sx,y:sy,
      vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-0.3,
      life:1400,maxLife:1400,c:'#FFB3B3',size:1+Math.random()*1.5});
  }
  // TWO STACKED SHOCKWAVE RINGS — one cyan inner, one red outer
  state.fx.push({type:'ring',x:sx,y:sy,r:0,maxR:80,life:600,maxLife:600,c:'#FF5252',lw:2.5});
  state.fx.push({type:'ring',x:sx,y:sy,r:0,maxR:130,life:800,maxLife:800,c:'#4FC3F7',lw:1.5});
  // Bigger background spark on dissolve - cleansing wave through neurons
  sparkBgAt(sx,sy,200);
  Composite.remove(eng.world,s.body);
  state.hitWater=Math.min(1,state.hitWater+0.05);
  updateFlow();
}

function explodeAround(x,y,radius,strength,color){
  // Push every non-dead body outward from (x,y)
  state.shapes.forEach(o=>{
    if(o.dead)return;
    const dx=o.body.position.x-x,dy=o.body.position.y-y;
    const d=Math.hypot(dx,dy)||1;
    if(d<radius){
      const falloff=1-d/radius;
      const f=strength*falloff*o.body.mass;
      Body.applyForce(o.body,o.body.position,{x:dx/d*f,y:dy/d*f-0.001*falloff});
    }
  });
  // visual burst
  for(let i=0;i<22;i++){
    const a=Math.random()*Math.PI*2;
    state.fx.push({type:'burst',x,y,vx:Math.cos(a)*(2+Math.random()*3),vy:Math.sin(a)*(2+Math.random()*3),life:600,c:color||'#fff'});
  }
  state.fx.push({type:'wave',x,y,r:0,life:600,c:color||'#fff'});
}

// ---------- Collisions ----------
Events.on(eng,'collisionStart',(ev)=>{
  ev.pairs.forEach(p=>{
    const A=p.bodyA,B=p.bodyB;

    // ── FOLD RAMP FLASH: light up brain fold line on block impact ──
    if(A.label==='fold'||B.label==='fold'){
      const fold=A.label==='fold'?A:B;
      if(fold._pinIdx!==undefined) state.pinFlashes[fold._pinIdx]=performance.now();
    }


    // ── POSITIVE BALL hits NEGATIVE → consume positive, dissolve negative ──
    const isPA=A.label==='pos:fall', isPB=B.label==='pos:fall';
    const isNA=A.label==='neg',      isNB=B.label==='neg';
    if((isPA&&isNB)||(isPB&&isNA)){
      const posBody=isPA?A:B, negBody=isNA?A:B;
      const posS=state.shapes.find(s=>s.body===posBody&&!s.dead);
      const negS=state.shapes.find(s=>s.body===negBody&&!s.dead);
      if(posS&&negS){
        posS.dead=true;negS.dead=true;
        Composite.remove(eng.world,posBody);Composite.remove(eng.world,negBody);
        const px=negBody.position.x,py=negBody.position.y;
        consumePositive(posS.word,px,py);
        state.erases=(state.erases||0)+1;
        if(typeof addStreakDrop==='function')addStreakDrop();
        // Big flash at collision point
        state.fx.push({type:'ring',x:px,y:py,r:0,maxR:70,life:500,maxLife:500,c:'#4FC3F7',lw:2.5});
        state.screenPulse=(state.screenPulse||0)+0.4;
        sparkBgAt(px,py,200);
      }
    }

    // ── POSITIVE BALL hits FLOOR → consume (it fell through without hitting anything) ──
    if((isPA||isPB)&&(A.label==='floor'||B.label==='floor')){
      const posBody=isPA?A:B;
      const posS=state.shapes.find(s=>s.body===posBody&&!s.dead);
      if(posS){
        posS.dead=true;
        Composite.remove(eng.world,posBody);
        // Still add some water (smaller benefit since it missed)
        consumePositive(posS.word,posBody.position.x,posBody.position.y);
      }
    }
  });
});
function handlePair(a,b){
  if(!a.label||!a.label.startsWith('pos:'))return;
  const ps=state.shapes.find(s=>s.body===a);
  if(!ps||ps.dead)return;
  
  if(b.label==='neg'){
    const ng=state.shapes.find(s=>s.body===b);
    if(!ng||ng.dead)return;
    // All positives crack negatives the same (1 hit each, 3 hits dissolves)
    ng.hits+=1;
    // STREAK SYSTEM - consecutive hits without missing
    state.streak=(state.streak||0)+1;
    if(state.streak>=2){
      showStreakPopup(state.streak);
      // Bonus water on streak (small reward to incentivize chains)
      state.hitWater=Math.min(1,state.hitWater+0.01*Math.min(state.streak,5));
      // Screen pulse flash on big combos (3+) — that shockwave feeling
      if(state.streak>=3){
        state.screenPulse=Math.min(1,(state.screenPulse||0)+0.5);
      }
    }
    // Wave at impact - PARENTING gets triple-size wave for breath (shock wave rumbles brain)
    const col=a.label==='pos:water'?COL.water:(a.label==='pos:breath'?COL.breath:'#fff');
    const waveLife=(state.category==='parenting'&&a.label==='pos:breath')?1500:500;
    state.fx.push({type:'wave',x:a.position.x,y:a.position.y,r:0,life:waveLife,c:col,
      tripleSize:state.category==='parenting'&&a.label==='pos:breath'});
    // Water from successful hit
    state.hitWater=Math.min(1,state.hitWater+0.05);
    updateFlow();
    if(ng.hits>=3)dissolve(ng);
    // Space-creators explode on impact (breath + spark)
    // PARENTING triples the wave/explosion radius for breath
    const breathRadius=(state.category==='parenting')?480:160;
    const breathStrength=(state.category==='parenting')?0.045:0.022;
    if(a.label==='pos:breath'){
      explodeAround(a.position.x,a.position.y,breathRadius,breathStrength,COL.breath);
    }else if(a.label==='pos:spark'){
      explodeAround(a.position.x,a.position.y,130,0.020,'#fff');
    }
    // Consume the positive
    Composite.remove(eng.world,a);
    ps.dead=true;
  }else if(b.label==='floor'){
    // Missed - hit the floor - break the streak
    state.streak=0;
    const col=a.label==='pos:water'?COL.water:(a.label==='pos:breath'?COL.breath:'#fff');
    state.fx.push({type:'wave',x:a.position.x,y:a.position.y,r:0,life:400,c:col,small:true});
    state.missWater=Math.min(1,state.missWater+0.05);
    updateFlow();
    Composite.remove(eng.world,a);
    ps.dead=true;
  }
}

// Negative-negative collisions: now JUST a visual ripple — no size changes.
function handleNegNeg(a,b){
  if(a.label!=='neg'||b.label!=='neg')return;
  const sa=state.shapes.find(s=>s.body===a);
  const sb=state.shapes.find(s=>s.body===b);
  if(!sa||!sb||sa.dead||sb.dead||sa===sb)return;
  // Cooldown so we don't spam effects every frame they're touching
  const now=performance.now();
  if((sa.lastTouch&&now-sa.lastTouch<800)||(sb.lastTouch&&now-sb.lastTouch<800))return;
  sa.lastTouch=now;sb.lastTouch=now;
  // Light ripple at midpoint - no scaling happens
  const mx=(sa.body.position.x+sb.body.position.x)/2;
  const my=(sa.body.position.y+sb.body.position.y)/2;
  state.fx.push({type:'wave',x:mx,y:my,r:0,life:400,c:'rgba(255,180,180,.5)',small:true});
}

// ---------- Sway and breath force ----------
let _lastOverloadCount=0; // track when count first crosses 10
function tickForces(dt){
  // OVERLOAD GRAVITY — if the brain has 10+ floating negatives, gravity progressively
  // returns to them so they sink and stack at the bottom row as a visible warning state.
  const liveNegs=state.shapes.filter(s=>!s.dead&&s.kind==='neg');
  const negCount=liveNegs.length;
  const overloadG=negCount>=10?Math.min(1,(negCount-9)*0.22):0;

  // Fire the overload popup + effects ONCE when count first hits exactly 10
  if(negCount>=10&&_lastOverloadCount<10){
    // Streak popup reused as OVERLOAD alert
    const sp=document.getElementById('streakPopup');
    if(sp){
      sp.textContent='⚠ BRAIN SATURATED';
      sp.style.background='none';
      sp.style['-webkit-background-clip']='unset';
      sp.style['-webkit-text-fill-color']='#FF5252';
      sp.style.filter='drop-shadow(0 0 18px rgba(255,60,60,.9)) drop-shadow(0 0 36px rgba(255,60,60,.5))';
      sp.style.opacity='1';
      sp.style.transform='translateX(-50%) scale(1.1)';
      setTimeout(()=>{
        sp.style.opacity='0';
        sp.style.transform='translateX(-50%) scale(0.8)';
        sp.style.filter='';sp.style['-webkit-text-fill-color']='';
      },1400);
    }
    // Big screen shake burst
    state.burnoutShake=Math.min(1,state.burnoutShake+0.7);
    // Suddenly slam ALL floating negatives downward with a jolt so they stack
    liveNegs.forEach(s=>{
      Body.setVelocity(s.body,{x:(Math.random()-0.5)*2,y:2+Math.random()*3});
    });
    // Bright red flash
    state.screenPulse=(state.screenPulse||0)+0.5;
    state.burnoutIntensity=Math.min(1,(state.burnoutIntensity||0)+0.4);
  }
  _lastOverloadCount=negCount;
  state.shapes.forEach(s=>{
    if(s.dead)return;
    s.age=(s.age||0)+dt;
    // FLOATING NEGATIVE DRIFT — apply two tiny sinusoidal forces (X and Y) so each
    // negative wanders in a slow lazy orbit. Each shape has its own phase so they
    // PEGGLE FALLING: negatives fall with full gravity, bounce off pins
    // No drift forces — they fall naturally. Off-screen cleanup only.
    if(s.kind==='neg'){
      // Ensure gravity is always on (override any old gravityScale=0)
      if(s.body.gravityScale!==1) s.body.gravityScale=1;
    }
    // OFF-SCREEN CLEANUP: if a shape escapes the container, remove it
    if(s.kind==='neg'&&!s.respawned){
      const py=s.body.position.y;
      if(py>L.BB+150||py<L.BT-150){
        s.respawned=true;
        Composite.remove(eng.world,s.body);
        s.dead=true;
      }
    }
  });
}

function tickFx(dt){
  const k=dt/16.67;
  for(let i=state.fx.length-1;i>=0;i--){
    const e=state.fx[i];e.life-=dt;
    if(e.life<=0){state.fx.splice(i,1);continue;}
    if(e.type==='burst'){
      e.x+=e.vx*k;e.y+=e.vy*k;e.vy+=.18*k;e.vx*=0.96;
    }else if(e.type==='shimmer'){
      e.x+=e.vx*k;e.y+=e.vy*k;e.vy+=.04*k;e.vx*=0.97;e.vy*=0.97;
    }else if(e.type==='ring'){
      // Ring expands outward with eased curve
      const t=1-(e.life/e.maxLife);
      e.r=e.maxR*(1-Math.pow(1-t,3));
    }else if(e.type==='wave'){
      e.r+=k*(e.small?1.5:(e.tripleSize?6:2.5));
    }
  }
  for(let i=state.shapes.length-1;i>=0;i--){
    if(state.shapes[i].dead)state.shapes.splice(i,1);
  }
}

// ---------- Rendering ----------
// Animated background neural network - bright cyan synapses (Gemini concept aesthetic)
const bgNeurons=[];
function initBgNeurons(){
  bgNeurons.length=0;
  const count=Math.min(48,Math.floor(W*H/11000));
  for(let i=0;i<count;i++){
    bgNeurons.push({
      x:Math.random()*W,
      y:Math.random()*L.WH,
      vx:(Math.random()-0.5)*0.06,
      vy:(Math.random()-0.5)*0.06,
      r:Math.random()*1.6+0.8,
      a:Math.random()*0.28+0.12,
      pulseSpeed:0.018+Math.random()*0.022,
      pulsePhase:Math.random()*Math.PI*2,
      glow:0
    });
  }
}
function bg(){
  cx.fillStyle='#000';cx.fillRect(0,0,W,H);
  cx.save();cx.translate(0,-cam.y);
  // Bright neural dots with cyan tint
  bgNeurons.forEach(n=>{
    n.pulsePhase+=n.pulseSpeed;
    n.x+=n.vx;n.y+=n.vy;
    if(n.x<-10)n.x=W+10;if(n.x>W+10)n.x=-10;
    if(n.y<-10)n.y=L.WH+10;if(n.y>L.WH+10)n.y=-10;
    const alpha=Math.max(0,n.a+Math.sin(n.pulsePhase)*0.08+n.glow);
    // Subtle cyan-blue tint for all neurons (matches Gemini aesthetic)
    const tintB=180+Math.floor(Math.sin(n.pulsePhase)*40+40);
    cx.fillStyle=n.glow>0?`rgba(79,195,247,${alpha})`:`rgba(180,220,255,${alpha*.85})`;
    // Glow halo around each neuron
    cx.shadowColor=n.glow>0?'rgba(79,195,247,.9)':'rgba(150,200,255,.5)';
    cx.shadowBlur=n.glow>0?12:5;
    cx.beginPath();cx.arc(n.x,n.y,n.r+n.glow*2,0,Math.PI*2);cx.fill();
    if(n.glow>0)n.glow=Math.max(0,n.glow-0.008);
  });
  cx.shadowBlur=0;
  // Connecting synapse lines — brighter and bluer
  cx.lineWidth=0.7;
  for(let i=0;i<bgNeurons.length;i++){
    const a=bgNeurons[i];
    for(let j=i+1;j<bgNeurons.length;j++){
      const b=bgNeurons[j];
      const dx=a.x-b.x,dy=a.y-b.y,d=Math.hypot(dx,dy);
      if(d<110){
        const alpha=(1-d/110)*0.18;
        const glowing=a.glow>0||b.glow>0;
        cx.strokeStyle=glowing?`rgba(79,195,247,${Math.min(.9,alpha*4)})`:`rgba(120,180,240,${alpha})`;
        cx.beginPath();cx.moveTo(a.x,a.y);cx.lineTo(b.x,b.y);cx.stroke();
      }
    }
  }
  cx.restore();
}
function sparkBgAt(x,y,radius){
  radius=radius||120;
  bgNeurons.forEach(n=>{
    if(Math.hypot(n.x-x,n.y-y)<radius){
      n.glow=Math.min(0.7,n.glow+0.35);
      const dx=n.x-x,dy=n.y-y,d=Math.hypot(dx,dy)||1;
      n.vx+=(dx/d)*0.4;n.vy+=(dy/d)*0.4;
    }
  });
}


function hLabel(x,y,l){
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText(l.toUpperCase(),x,y);
}
// Wrap a word/phrase into multiple lines, breaking at spaces if longer than max chars per line
function wrapWord(word,maxChars){
  if(word.length<=maxChars)return [word];
  const parts=word.split(' ');
  const lines=[];
  let cur='';
  parts.forEach(p=>{
    if(!cur){cur=p;}
    else if((cur+' '+p).length<=maxChars){cur+=' '+p;}
    else{lines.push(cur);cur=p;}
  });
  if(cur)lines.push(cur);
  return lines;
}

function drawHousingWord(hw,bx,by,extraAlpha){
  const t=performance.now()*.001;
  const x=W/2+hw.bx+Math.sin(t*hw.speed+hw.phase)*3;
  const y=L.HC+hw.by+Math.cos(t*hw.speed*0.7+hw.phase)*2;
  cx.globalAlpha=(extraAlpha||1)*(hw.main?1:0.75);
  cx.fillStyle=hw.kind==='pos'?COL.water:'rgba(255,255,255,.85)';
  cx.font=(hw.main?'500':'400')+' 7px monospace';
  cx.textAlign='center';
  // Full word stacked across multiple lines if long
  const lines=wrapWord(hw.word.toUpperCase(),14);
  const lineH=8;
  const startY=y-(lines.length-1)*lineH/2;
  lines.forEach((ln,i)=>{
    cx.fillText(ln,x,startY+i*lineH);
  });
  cx.globalAlpha=1;
}

// ---------- UNIFIED HOUSING (all 5 categories use the same emoji-grid layout) ----------
function drawHousing(){
  // Only show housing visuals during the intro word-float phase; hide during active gameplay
  // to prevent decorative category boxes from cluttering the brain visualization area.
  if(state.phase!==PH.SHOW && state.phase!==PH.EJECT) return;
  const c=W/2,cy=L.HC,w=L.HW,h=L.HH;
  if(state.category==='self')hSelf(c,cy,w,h);
  else if(state.category==='parenting')hParent(c,cy,w,h);
  else if(state.category==='engineer')hSoft(c,cy,w,h);
  else if(state.category==='senior')hSenior(c,cy,w,h);
  else if(state.category==='quantum')hQuantum(c,cy,w,h);
}

// Minimal decorative frames
function drawSelfFrame(c,cy,w,h){
  const y=cy-h*.5;
  cx.strokeStyle='rgba(255,255,255,.18)';cx.lineWidth=1;
  cx.beginPath();cx.rect(c-w*.49,y+2,w*.98,h*.96);cx.stroke();
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText(CATEGORY_DATA[state.category].label.toUpperCase(),c,y-4);
}
function drawHouseFrame(c,cy,w,h){
  cx.strokeStyle='rgba(255,255,255,.30)';cx.lineWidth=1.2;
  const x=c-w/2,y=cy-h/2;
  cx.beginPath();
  cx.moveTo(x+10,y+h*.20);cx.lineTo(c,y+5);cx.lineTo(x+w-10,y+h*.20);cx.stroke();
  cx.beginPath();cx.rect(x+10,y+h*.20,w-20,h*.78);cx.stroke();
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText('PARENTING',c,y-2);
}
function drawGearFrame(c,cy,w,h){
  const t=performance.now()*.0008;
  cx.strokeStyle='rgba(255,255,255,.25)';cx.lineWidth=1.1;
  [[c-w*.35,cy-h*.30,18],[c+w*.35,cy-h*.30,15],[c-w*.35,cy+h*.30,15],[c+w*.35,cy+h*.30,18]].forEach((g,i)=>{
    cx.save();cx.translate(g[0],g[1]);cx.rotate(t*(i%2?1:-1));
    cx.beginPath();
    for(let j=0;j<10;j++){
      const a=(j/10)*Math.PI*2,r1=g[2],r2=g[2]+3;
      cx.lineTo(Math.cos(a)*r1,Math.sin(a)*r1);
      cx.lineTo(Math.cos(a)*r2,Math.sin(a)*r2);
    }
    cx.closePath();cx.stroke();
    cx.beginPath();cx.arc(0,0,g[2]*.4,0,Math.PI*2);cx.stroke();
    cx.restore();
  });
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText('ENGINEERING',c,cy-h*.5-2);
}
function drawHorizonFrame(c,cy,w,h){
  // Ocean theme with rolling waves spread across full width
  const horizonY=cy-h*0.30;
  const oceanBot=cy+h*0.50;
  const tt=performance.now()*.001;
  // sun
  cx.strokeStyle='rgba(255,180,80,.5)';cx.lineWidth=1.2;
  cx.beginPath();cx.arc(c,horizonY,22,Math.PI,0,false);cx.stroke();
  for(let i=0;i<7;i++){
    const a=Math.PI+(i+.5)/7*Math.PI;
    const r1=28,r2=36+Math.sin(tt*2+i)*3;
    cx.beginPath();
    cx.moveTo(c+Math.cos(a)*r1,horizonY+Math.sin(a)*r1);
    cx.lineTo(c+Math.cos(a)*r2,horizonY+Math.sin(a)*r2);
    cx.stroke();
  }
  cx.strokeStyle='rgba(255,255,255,.30)';
  cx.beginPath();cx.moveTo(c-w/2,horizonY);cx.lineTo(c+w/2,horizonY);cx.stroke();
  // Rolling waves
  cx.lineWidth=1;
  for(let row=0;row<6;row++){
    const t2=row/5;
    const yy=horizonY+15+t2*(oceanBot-horizonY-15);
    cx.strokeStyle='rgba(79,195,247,'+(0.18+t2*0.30)+')';
    cx.beginPath();
    const wobAmp=2+t2*4,wobFreq=0.05+t2*0.02,wobPhase=tt*(1+t2*0.6);
    for(let xx=c-w/2;xx<=c+w/2;xx+=3){
      const wave=Math.sin(xx*wobFreq+wobPhase+row*0.5)*wobAmp;
      if(xx===c-w/2)cx.moveTo(xx,yy+wave);
      else cx.lineTo(xx,yy+wave);
    }
    cx.stroke();
  }
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText('RETIREMENT',c,horizonY-30);
}
function drawQuantumFrame(c,cy,w,h){
  const t=performance.now()*.001;
  cx.strokeStyle='rgba(180,150,255,.30)';cx.lineWidth=1;
  // Two orbiting dots representing quantum nodes
  for(let i=0;i<2;i++){
    const a=t*(i?1.3:-0.9)+i*Math.PI;
    const dx=Math.cos(a)*w*.40, dy=Math.sin(a)*h*.30;
    cx.beginPath();cx.arc(c+dx,cy+dy,4,0,Math.PI*2);
    cx.fillStyle='rgba(180,150,255,.6)';cx.fill();
  }
  // central node
  cx.beginPath();cx.arc(c,cy,3,0,Math.PI*2);
  cx.fillStyle=COL.water;cx.fill();
  cx.fillStyle=COL.dim;cx.font='300 9px monospace';cx.textAlign='center';
  cx.fillText('QUANTUM LEAP',c,cy-h*.5-2);
}

// SELF: figure with floating words it "grabs"
function hSelf(c,cy,w,h){
  const y=cy-h*.5;
  // floating words drift around the figure
  state.housing.forEach((hw)=>{
    drawHousingWord(hw);
  });
  // FIGURE with more character — slight breathing + walking
  const t=performance.now()*.002;
  const breath=Math.sin(t)*1;
  const armSwing=Math.sin(t*1.4);
  const legShift=Math.sin(t*1.4);
  cx.strokeStyle=COL.line;cx.lineWidth=1.5;
  cx.fillStyle='rgba(0,0,0,.6)';
  
  // grad cap with tassel
  cx.beginPath();
  cx.moveTo(c-14,y+22);cx.lineTo(c,y+14);cx.lineTo(c+14,y+22);cx.lineTo(c,y+30);
  cx.closePath();cx.fill();cx.stroke();
  cx.beginPath();cx.moveTo(c,y+22);cx.lineTo(c+12,y+27);cx.lineTo(c+12,y+38);cx.stroke();
  cx.beginPath();cx.arc(c+12,y+39,1.5,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.fillStyle='rgba(0,0,0,.6)';
  
  // HEAD with chin
  cx.beginPath();
  cx.arc(c,y+42+breath*0.5,8,0,Math.PI*2);
  cx.fill();cx.stroke();
  // ear hint
  cx.beginPath();cx.arc(c+7,y+43,1.3,0,Math.PI*2);cx.stroke();
  // FACE - eyes + determined mouth
  cx.fillStyle=COL.line;
  cx.beginPath();cx.arc(c-3,y+41,1,0,Math.PI*2);cx.arc(c+2,y+41,1,0,Math.PI*2);cx.fill();
  cx.lineWidth=1.2;
  cx.beginPath();cx.moveTo(c-2,y+45);cx.lineTo(c+2,y+45);cx.stroke();
  // brow
  cx.beginPath();cx.moveTo(c-5,y+38);cx.lineTo(c-1,y+39);
  cx.moveTo(c+0,y+39);cx.lineTo(c+4,y+38);cx.stroke();
  cx.lineWidth=1.5;
  cx.fillStyle='rgba(0,0,0,.6)';
  
  // NECK
  cx.beginPath();cx.moveTo(c-2,y+50);cx.lineTo(c-2,y+53);
  cx.lineTo(c+2,y+53);cx.lineTo(c+2,y+50);cx.stroke();
  
  // TORSO (slightly tapered jacket shape)
  cx.beginPath();
  cx.moveTo(c-9,y+54);cx.lineTo(c-8,y+88);cx.lineTo(c+8,y+88);cx.lineTo(c+9,y+54);
  cx.closePath();cx.fill();cx.stroke();
  // jacket lapel
  cx.lineWidth=1;
  cx.beginPath();
  cx.moveTo(c,y+54);cx.lineTo(c-4,y+62);cx.lineTo(c,y+70);cx.lineTo(c+4,y+62);cx.lineTo(c,y+54);
  cx.stroke();
  cx.lineWidth=1.5;
  
  // ARMS — one reaches up (grabbing words), other swings
  cx.save();
  cx.translate(c-9,y+57);
  cx.rotate(-0.9+armSwing*0.4);
  cx.beginPath();cx.moveTo(0,0);cx.lineTo(0,18);cx.lineTo(3,28);cx.stroke();
  // hand grabbing
  cx.beginPath();cx.arc(3,30,2.5,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.restore();
  // flex arm with bicep
  cx.save();
  cx.translate(c+9,y+57);
  cx.rotate(0.5-armSwing*0.3);
  cx.beginPath();cx.moveTo(0,0);cx.lineTo(0,12);cx.lineTo(-7,20);cx.stroke();
  // bicep bulge
  cx.beginPath();cx.ellipse(-2,8,3.5,2.5,-0.3,0,Math.PI*2);cx.stroke();
  cx.restore();
  
  // LEGS (walking)
  cx.beginPath();
  cx.moveTo(c-4,y+88);cx.lineTo(c-6+legShift*2,y+102);cx.lineTo(c-7+legShift*2,y+112);cx.stroke();
  cx.beginPath();
  cx.moveTo(c+4,y+88);cx.lineTo(c+6-legShift*2,y+102);cx.lineTo(c+7-legShift*2,y+112);cx.stroke();
  // shoes
  cx.beginPath();cx.ellipse(c-7+legShift*2,y+113,3,1.5,0,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.beginPath();cx.ellipse(c+7-legShift*2,y+113,3,1.5,0,0,Math.PI*2);cx.fill();
  cx.fillStyle='rgba(0,0,0,.6)';
  
  // MONEY IN POCKET
  cx.strokeStyle='#7FE57F';
  cx.lineWidth=1.3;
  cx.beginPath();cx.rect(c+1,y+74,8,12);cx.stroke();
  cx.fillStyle='#7FE57F';cx.font='500 7px monospace';cx.textAlign='center';
  cx.fillText('$',c+5,y+82);
  
  hLabel(c,y+6,'ascent');
}

// PARENTING: house with words as family members bouncing inside, door opens on eject
function hParent(c,cy,w,h){
  cx.strokeStyle=COL.line;cx.lineWidth=1.4;
  const x=c-w/2,y=cy-h/2;
  const roofY=y+h*.28;
  
  // CHIMNEY (top right)
  cx.beginPath();cx.rect(c+w*.18,y+8,12,18);cx.fill();cx.stroke();
  // smoke puffs
  const t=performance.now()*.001;
  cx.strokeStyle='rgba(255,255,255,.3)';
  for(let i=0;i<3;i++){
    const sy=y+8-i*6-Math.sin(t+i)*2;
    cx.beginPath();cx.arc(c+w*.18+6+Math.cos(t+i)*3,sy,3-i*0.5,0,Math.PI*2);cx.stroke();
  }
  cx.strokeStyle=COL.line;
  
  // ROOF (peaked) with shingle lines
  cx.beginPath();cx.moveTo(x+6,roofY);cx.lineTo(c,y+10);cx.lineTo(x+w-6,roofY);cx.stroke();
  cx.strokeStyle='rgba(255,255,255,.25)';
  cx.lineWidth=1;
  for(let i=1;i<4;i++){
    const t2=i/4;
    cx.beginPath();
    cx.moveTo(x+6+t2*((c-x-6)),roofY-t2*(roofY-y-10));
    cx.lineTo(x+w-6-t2*((x+w-6-c)),roofY-t2*(roofY-y-10));
    cx.stroke();
  }
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.4;
  
  // WALLS with brick texture
  cx.beginPath();cx.rect(x+10,roofY,w-20,h*.68);cx.stroke();
  cx.strokeStyle='rgba(255,255,255,.15)';
  cx.lineWidth=1;
  for(let row=0;row<6;row++){
    const yy=roofY+8+row*((h*.68-8)/6);
    cx.beginPath();cx.moveTo(x+10,yy);cx.lineTo(x+w-10,yy);cx.stroke();
    // staggered vertical lines
    const offset=row%2===0?0:14;
    for(let xx=x+10+offset;xx<x+w-10;xx+=28){
      cx.beginPath();cx.moveTo(xx,yy);cx.lineTo(xx,yy+((h*.68-8)/6));cx.stroke();
    }
  }
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.4;
  
  // WINDOWS (left & right with crossbars and shutters)
  [c-w*.26,c+w*.26].forEach(wx=>{
    const wy=roofY+18;
    cx.beginPath();cx.rect(wx-10,wy,20,18);cx.stroke();
    cx.strokeStyle='rgba(255,255,255,.4)';
    cx.lineWidth=1;
    cx.beginPath();
    cx.moveTo(wx,wy);cx.lineTo(wx,wy+18);
    cx.moveTo(wx-10,wy+9);cx.lineTo(wx+10,wy+9);
    cx.stroke();
    // shutters
    cx.strokeStyle=COL.line;cx.lineWidth=1;
    cx.beginPath();cx.rect(wx-14,wy,3,18);cx.stroke();
    cx.beginPath();cx.rect(wx+11,wy,3,18);cx.stroke();
    cx.lineWidth=1.4;
  });
  
  // DOOR (animates open during eject/fall)
  const doorOpen=(state.phase===PH.EJECT||state.phase===PH.FALL)?Math.min(1,state.t/300):0;
  cx.save();
  cx.translate(c-12,y+h-28);
  cx.rotate(-doorOpen*0.7);
  cx.beginPath();cx.rect(0,0,24,26);cx.fill();cx.stroke();
  // door knob
  cx.beginPath();cx.arc(20,13,1.3,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.fillStyle='rgba(0,0,0,.6)';
  // door panels
  cx.strokeStyle='rgba(255,255,255,.35)';cx.lineWidth=1;
  cx.beginPath();cx.rect(3,3,18,9);cx.stroke();
  cx.beginPath();cx.rect(3,14,18,9);cx.stroke();
  cx.strokeStyle=COL.line;cx.lineWidth=1.4;
  cx.restore();
  
  // STEPS at door
  cx.beginPath();
  cx.moveTo(c-16,y+h-2);cx.lineTo(c+16,y+h-2);cx.stroke();
  cx.beginPath();
  cx.moveTo(c-19,y+h+1);cx.lineTo(c+19,y+h+1);cx.stroke();
  
  // WORDS as family inside, running around — SPREAD OUT, not congested
  cx.font='500 7.5px monospace';cx.textAlign='center';
  state.housing.forEach(hw=>{
    const tt=performance.now()*.001;
    // Use full grid position with light bob, no big movement that causes overlap
    const wx=c+(hw.bx*0.95)+Math.sin(tt*hw.speed+hw.phase)*5;
    const wy=cy+(hw.by*0.80)+Math.cos(tt*hw.speed*1.2+hw.phase)*3;
    // Clamp to inside house
    const cxp=Math.max(x+24,Math.min(x+w-24,wx));
    const cyp=Math.max(roofY+12,Math.min(y+h-36,wy));
    cx.fillStyle=hw.kind==='pos'?COL.water:COL.line;
    cx.globalAlpha=hw.main?1:0.7;
    cx.fillText(hw.word.toUpperCase(),cxp,cyp);
    cx.globalAlpha=1;
    // small running legs (shorter so less visual clutter)
    cx.strokeStyle=hw.kind==='pos'?COL.water:COL.line;
    cx.lineWidth=0.8;
    const lp=tt*5+hw.phase;
    cx.beginPath();
    cx.moveTo(cxp-2,cyp+2);cx.lineTo(cxp-2.5+Math.sin(lp)*1.5,cyp+5);
    cx.moveTo(cxp+2,cyp+2);cx.lineTo(cxp+2.5+Math.sin(lp+Math.PI)*1.5,cyp+5);
    cx.stroke();
  });
  cx.lineWidth=1.4;
  hLabel(c,y-2,'home');
}

// SOFTWARE: gears with words written on them, jam during eject
function hSoft(c,cy,w,h){
  cx.strokeStyle=COL.line;cx.lineWidth=1.3;
  const isJam=state.phase===PH.EJECT;
  const t=performance.now()*.0008;
  const gs=[
    {x:c-42,y:cy-16,r:28,sp:1,word:state.housing[0]},
    {x:c+36,y:cy-4,r:24,sp:-1.3,word:state.housing[1]},
    {x:c-6,y:cy+30,r:22,sp:1.5,word:state.housing[2]},
    {x:c+40,y:cy+34,r:18,sp:-1.0,word:state.housing[3]}
  ];
  gs.forEach((g,gi)=>{
    if(!g.word)return;
    const rot=isJam?Math.sin(performance.now()*.04)*0.05:t*g.sp;
    cx.save();cx.translate(g.x,g.y);cx.rotate(rot);
    cx.beginPath();
    for(let i=0;i<12;i++){
      const a=(i/12)*Math.PI*2,r1=g.r,r2=g.r+4,a2=a+Math.PI/12;
      cx.lineTo(Math.cos(a)*r1,Math.sin(a)*r1);cx.lineTo(Math.cos(a)*r2,Math.sin(a)*r2);
      cx.lineTo(Math.cos(a2)*r2,Math.sin(a2)*r2);cx.lineTo(Math.cos(a2)*r1,Math.sin(a2)*r1);
    }
    cx.closePath();cx.stroke();
    cx.beginPath();cx.arc(0,0,g.r*.5,0,Math.PI*2);cx.stroke();
    // counter-rotate text for legibility
    cx.rotate(-rot);
    cx.fillStyle=g.word.kind==='pos'?COL.water:COL.line;
    cx.font='500 7px monospace';cx.textAlign='center';
    cx.fillText(g.word.word.toUpperCase(),0,2);
    cx.restore();
  });
  // sparks when jamming
  if(isJam){
    for(let i=0;i<3;i++){
      const sx=c+(Math.random()-0.5)*60;
      const sy=cy+(Math.random()-0.5)*40;
      cx.fillStyle='#FFD86B';
      cx.beginPath();cx.arc(sx,sy,1.5,0,Math.PI*2);cx.fill();
    }
  }
  // extra words floating around
  for(let i=4;i<state.housing.length;i++){
    drawHousingWord(state.housing[i]);
  }
  hLabel(c,cy-h*.5,'engineering');
}

// SENIOR: sunrise + beach with letters; tide takes words on eject
function hSenior(c,cy,w,h){
  // OCEAN VIEW with rolling waves; words bob on the water surface, well-spaced
  const horizonY=cy-h*0.30;
  const oceanTop=horizonY;
  const oceanBot=cy+h*0.45;
  const tt=performance.now()*.001;
  
  // Sky background gradient suggestion
  cx.fillStyle='rgba(255,180,80,.06)';
  cx.fillRect(c-w/2,cy-h/2,w,horizonY-(cy-h/2));
  
  // Rising sun on horizon
  cx.strokeStyle=COL.line;cx.lineWidth=1.4;
  cx.beginPath();
  cx.arc(c,horizonY,24,Math.PI,0,false);
  cx.stroke();
  // sun rays
  cx.strokeStyle='rgba(255,180,80,.4)';
  cx.lineWidth=1;
  for(let i=0;i<7;i++){
    const a=Math.PI+(i+.5)/7*Math.PI;
    const r1=30,r2=38+Math.sin(tt*2+i)*3;
    cx.beginPath();
    cx.moveTo(c+Math.cos(a)*r1,horizonY+Math.sin(a)*r1);
    cx.lineTo(c+Math.cos(a)*r2,horizonY+Math.sin(a)*r2);
    cx.stroke();
  }
  
  // Horizon line
  cx.strokeStyle=COL.line;
  cx.lineWidth=1.2;
  cx.beginPath();cx.moveTo(c-w/2,horizonY);cx.lineTo(c+w/2,horizonY);cx.stroke();
  
  // OCEAN — multiple rolling wave lines, animated
  cx.lineWidth=1;
  for(let row=0;row<6;row++){
    const t2=row/5;
    const yy=horizonY+15+t2*(oceanBot-horizonY-15);
    const alpha=0.18+t2*0.30;
    cx.strokeStyle='rgba(79,195,247,'+alpha+')';
    cx.beginPath();
    const wobAmp=2+t2*5;
    const wobFreq=0.05+t2*0.02;
    const wobPhase=tt*(1+t2*0.6);
    for(let xx=c-w/2;xx<=c+w/2;xx+=3){
      const wave=Math.sin(xx*wobFreq+wobPhase+row*0.5)*wobAmp;
      const y2=yy+wave;
      if(xx===c-w/2)cx.moveTo(xx,y2);
      else cx.lineTo(xx,y2);
    }
    cx.stroke();
  }
  
  // Foam ripples here and there
  cx.fillStyle='rgba(255,255,255,.35)';
  for(let i=0;i<8;i++){
    const fx=c-w/2+((i/8)*w)+Math.sin(tt+i)*10;
    const fy=horizonY+20+(i%3)*((oceanBot-horizonY-20)/3)+Math.cos(tt*2+i)*3;
    cx.beginPath();cx.arc(fx,fy,1.2,0,Math.PI*2);cx.fill();
  }
  
  // WORDS bobbing on the ocean surface — well spread
  // Use bx/by grid positions but constrain to ocean area
  cx.font='500 8px monospace';cx.textAlign='center';
  state.housing.forEach((hw,i)=>{
    const baseX=c+hw.bx*1.05;
    // Map y position to ocean band, distribute evenly through ocean
    const oceanH=oceanBot-horizonY-10;
    const yT=((hw.by/(L.HH*0.5))+1)/2; // normalize to 0..1
    const baseY=horizonY+15+yT*oceanH;
    // bob on the wave
    const localWave=Math.sin(baseX*0.05+tt*1.2+hw.phase)*4;
    const xWob=Math.cos(tt*0.5+hw.phase)*4;
    const xp=baseX+xWob;
    const yp=baseY+localWave;
    cx.fillStyle=hw.kind==='pos'?COL.water:COL.line;
    cx.globalAlpha=hw.main?1:0.75;
    cx.fillText(hw.word.toUpperCase(),xp,yp);
    cx.globalAlpha=1;
    // tiny ripple under each word
    cx.strokeStyle='rgba(79,195,247,.3)';
    cx.lineWidth=0.8;
    cx.beginPath();
    cx.ellipse(xp,yp+5,12,1.5,0,0,Math.PI*2);
    cx.stroke();
  });
  cx.lineWidth=1.3;
  hLabel(c,horizonY-26,'horizon');
}

// QUANTUM: words sliding side to side between dots
function hQuantum(c,cy,w,h){
  cx.strokeStyle=COL.line;cx.lineWidth=1.3;
  const lx=c-w*.32,rx=c+w*.32;
  // dots
  cx.beginPath();cx.arc(lx,cy,6,0,Math.PI*2);cx.fillStyle=COL.line;cx.fill();
  cx.beginPath();cx.arc(rx,cy,6,0,Math.PI*2);cx.fill();
  // central node
  cx.beginPath();cx.arc(c,cy,4,0,Math.PI*2);cx.fillStyle=COL.water;cx.fill();
  // tubes (curved)
  cx.strokeStyle=COL.line;
  cx.beginPath();cx.moveTo(c-22,cy-h*.32);
  cx.bezierCurveTo(lx,cy-30,lx-12,cy-15,lx-3,cy-7);cx.stroke();
  cx.beginPath();cx.moveTo(c+22,cy+h*.32);
  cx.bezierCurveTo(rx,cy+30,rx+12,cy+15,rx+3,cy+7);cx.stroke();
  // particle flow
  const tt=performance.now()*.002;
  for(let i=0;i<4;i++){
    const p=(tt+i/4)%1;
    const x1=(c-22)+(lx-(c-22))*p,y1=(cy-h*.32)+(cy-(cy-h*.32))*(p*p);
    cx.beginPath();cx.arc(x1,y1,1.4,0,Math.PI*2);cx.fillStyle=COL.water;cx.fill();
    const x2=(c+22)+(rx-(c+22))*p,y2=(cy+h*.32)+(cy-(cy+h*.32))*(p*p);
    cx.beginPath();cx.arc(x2,y2,1.4,0,Math.PI*2);cx.fillStyle=COL.red;cx.fill();
  }
  // words sliding side to side
  cx.font='500 8px monospace';cx.textAlign='center';
  state.housing.forEach((hw,i)=>{
    const t=performance.now()*.0006;
    // moves left-right, wraps
    const phase=(t*hw.speed+hw.phase)%(Math.PI*2);
    const xx=c+Math.sin(phase)*(w*.32);
    const yy=cy+hw.by*0.4;
    cx.fillStyle=hw.kind==='pos'?COL.water:COL.line;
    cx.globalAlpha=0.85+Math.cos(phase)*0.15;
    cx.fillText(hw.word.toUpperCase(),xx,yy);
    cx.globalAlpha=1;
  });
  hLabel(c,cy-h*.5,'quantum');
}

// ---------- LIGHTBULB (always-on bright glow like Gemini concept) ----------
function drawBulb(){
  const c=W/2,cy=L.BY,r=L.BR;
  const active=(state.phase===PH.CHOICE||state.phase===PH.DRAG);
  const t=performance.now()*.001;
  const pulse=1+Math.sin(t*2.8)*.07;
  const haloI=active?1.0:0.55;

  cx.save();
  // ── BRAIN-IN-LIGHTBULB (Image 5 reference) ──
  // The glass globe
  const globeR=r*1.05;
  const globeY=cy-r*0.15;  // globe slightly above cy

  // Outer warm glow corona
  const corona=cx.createRadialGradient(c,globeY,r*0.3,c,globeY,r*3.2*pulse);
  corona.addColorStop(0,`rgba(255,120,40,${0.35*haloI})`);
  corona.addColorStop(0.3,`rgba(255,80,30,${0.15*haloI})`);
  corona.addColorStop(0.6,`rgba(220,40,20,${0.06*haloI})`);
  corona.addColorStop(1,'rgba(0,0,0,0)');
  cx.fillStyle=corona;
  cx.fillRect(c-r*4,cy-r*4,r*8,r*8);

  // Glass globe fill (red-orange warm interior)
  const globeG=cx.createRadialGradient(c-globeR*0.25,globeY-globeR*0.30,globeR*0.05,c,globeY,globeR);
  globeG.addColorStop(0,'rgba(255,240,200,.90)');  // bright white-orange center
  globeG.addColorStop(0.30,'rgba(255,160,60,.75)');
  globeG.addColorStop(0.60,'rgba(220,60,20,.50)');
  globeG.addColorStop(1,'rgba(140,20,10,.20)');
  cx.fillStyle=globeG;
  cx.beginPath();cx.arc(c,globeY,globeR,0,Math.PI*2);cx.fill();

  // Brain silhouette INSIDE the bulb
  const bsz=globeR*0.68;
  cx.save();
  cx.beginPath();cx.arc(c,globeY,globeR*0.92,0,Math.PI*2);cx.clip(); // clip to globe
  cx.strokeStyle=`rgba(255,240,200,${0.70+Math.sin(t*3)*0.15})`;
  cx.lineWidth=1.4;
  cx.shadowColor='rgba(255,220,150,.9)';cx.shadowBlur=8;
  // Brain outline (miniature anatomical brain inside the bulb)
  cx.beginPath();
  cx.moveTo(c-bsz*0.14,globeY+bsz*0.82);
  cx.bezierCurveTo(c-bsz*0.20,globeY+bsz,c-bsz*0.65,globeY+bsz*0.78,c-bsz*0.92,globeY+bsz*0.22);
  cx.bezierCurveTo(c-bsz*1.06,globeY-bsz*0.08,c-bsz*1.00,globeY-bsz*0.76,c-bsz*0.62,globeY-bsz*0.96);
  cx.bezierCurveTo(c-bsz*0.40,globeY-bsz*1.08,c-bsz*0.12,globeY-bsz*1.10,c,globeY-bsz*1.06);
  cx.bezierCurveTo(c+bsz*0.12,globeY-bsz*1.10,c+bsz*0.40,globeY-bsz*1.08,c+bsz*0.62,globeY-bsz*0.96);
  cx.bezierCurveTo(c+bsz*1.00,globeY-bsz*0.76,c+bsz*1.06,globeY-bsz*0.08,c+bsz*0.92,globeY+bsz*0.22);
  cx.bezierCurveTo(c+bsz*0.65,globeY+bsz*0.78,c+bsz*0.20,globeY+bsz,c+bsz*0.14,globeY+bsz*0.82);
  cx.bezierCurveTo(c+bsz*0.10,globeY+bsz*0.94,c-bsz*0.10,globeY+bsz*0.94,c-bsz*0.14,globeY+bsz*0.82);
  cx.closePath(); cx.stroke();
  // 4 gyri fold lines inside the brain
  cx.strokeStyle=`rgba(255,220,140,${0.55+Math.sin(t*2)*0.1})`;cx.lineWidth=0.9;cx.shadowBlur=4;
  cx.beginPath();cx.moveTo(c-bsz*0.80,globeY-bsz*0.55);cx.quadraticCurveTo(c-bsz*0.42,globeY-bsz*0.72,c-bsz*0.06,globeY-bsz*0.56);cx.stroke();
  cx.beginPath();cx.moveTo(c-bsz*0.86,globeY-bsz*0.18);cx.quadraticCurveTo(c-bsz*0.46,globeY-bsz*0.36,c-bsz*0.06,globeY-bsz*0.18);cx.stroke();
  cx.beginPath();cx.moveTo(c+bsz*0.06,globeY-bsz*0.56);cx.quadraticCurveTo(c+bsz*0.42,globeY-bsz*0.72,c+bsz*0.80,globeY-bsz*0.53);cx.stroke();
  cx.beginPath();cx.moveTo(c+bsz*0.06,globeY-bsz*0.18);cx.quadraticCurveTo(c+bsz*0.46,globeY-bsz*0.36,c+bsz*0.86,globeY-bsz*0.16);cx.stroke();
  // Brain stem wire
  cx.strokeStyle='rgba(220,140,80,.60)';cx.lineWidth=1.8;cx.shadowBlur=2;
  cx.beginPath();cx.moveTo(c,globeY+bsz*0.94);cx.lineTo(c,globeY+globeR*0.96);cx.stroke();
  cx.restore();

  // Glass globe border
  cx.strokeStyle=active?'rgba(255,160,60,.90)':'rgba(200,100,50,.60)';
  cx.lineWidth=2;
  cx.shadowColor='rgba(255,120,40,.8)';cx.shadowBlur=active?18:8;
  cx.beginPath();cx.arc(c,globeY,globeR,0,Math.PI*2);cx.stroke();

  // Glass highlight (lens flare top-left)
  cx.fillStyle='rgba(255,255,255,.28)';
  cx.beginPath();cx.ellipse(c-globeR*0.30,globeY-globeR*0.32,globeR*0.28,globeR*0.16,-0.5,0,Math.PI*2);cx.fill();

  // ── NECK (tapering glass tube below globe) ──
  const neckTop=globeY+globeR;
  const neckH=r*0.45;
  const neckW=r*0.38;
  cx.strokeStyle='rgba(180,100,50,.55)';cx.lineWidth=1.5;cx.shadowBlur=4;
  cx.beginPath();
  cx.moveTo(c-neckW,neckTop);
  cx.lineTo(c-neckW*0.85,neckTop+neckH);
  cx.moveTo(c+neckW,neckTop);
  cx.lineTo(c+neckW*0.85,neckTop+neckH);
  cx.stroke();

  // ── BRASS BASE ──
  const baseY=neckTop+neckH;
  const baseH=r*0.38, baseW=neckW*1.1;
  const brassG=cx.createLinearGradient(c-baseW,baseY,c+baseW,baseY);
  brassG.addColorStop(0,'rgba(150,110,40,.80)');
  brassG.addColorStop(0.5,'rgba(220,180,80,.90)');
  brassG.addColorStop(1,'rgba(150,110,40,.80)');
  cx.fillStyle=brassG;
  cx.beginPath();cx.roundRect(c-baseW,baseY,baseW*2,baseH,3);cx.fill();
  // Thread lines on brass
  cx.strokeStyle='rgba(100,75,25,.60)';cx.lineWidth=1;
  for(let i=1;i<4;i++){
    const ty=baseY+baseH*(i/4);
    cx.beginPath();cx.moveTo(c-baseW+2,ty);cx.lineTo(c+baseW-2,ty);cx.stroke();
  }
  cx.restore();
}


function drawBrain(){
  const c=L.BCX,top=L.BT,bot=L.BB,hw=L.BHW,h=bot-top;
  const cy=(top+bot)/2;
  const t=performance.now()*.001;
  const liveNegs=state.shapes.filter(s=>!s.dead&&s.kind==='neg').length;
  const isOverload=liveNegs>=10;
  const flowFrac=Math.min(1,state.flow);

  // ── OUTER AMBIENT GLOW ──
  const glowCol=isOverload?'rgba(255,60,30,.18)':'rgba(79,195,247,.10)';
  cx.shadowColor=isOverload?'#FF3020':'#4FC3F7';
  cx.shadowBlur=isOverload?30:16;

  // ── ANATOMICAL BRAIN SHAPE (Image 4 reference) ──
  // Wide, boxy overall outline with lobed top and tapered bottom
  // Clip the entire brain area first for water + fold containment
  cx.save();

  // Draw the brain OUTLINE as a wide anatomical shape
  function anatomyPath(){
    // Outer brain profile — wide and rectangular with lobed bumps at top
    const lx=c-hw, rx=c+hw;
    const midY=(top+bot)*0.5;
    cx.beginPath();
    // Bottom-left start
    cx.moveTo(lx+hw*0.10, bot-4);
    // Bottom edge (flat-ish)
    cx.lineTo(rx-hw*0.10, bot-4);
    // Right side going up with temporal lobe bump
    cx.bezierCurveTo(rx+hw*0.06, bot-h*0.08, rx+hw*0.08, bot-h*0.25, rx, bot-h*0.38);
    cx.bezierCurveTo(rx+hw*0.04, bot-h*0.50, rx+hw*0.02, midY-h*0.10, rx-hw*0.06, top+h*0.18);
    // Right upper — parietal-occipital bump
    cx.bezierCurveTo(rx+hw*0.02, top+h*0.06, rx-hw*0.14, top-h*0.04, rx-hw*0.28, top+h*0.01);
    // Central sulcus dip (walnut notch at top)
    cx.bezierCurveTo(rx-hw*0.42, top-h*0.06, c+hw*0.12, top-h*0.08, c, top-h*0.06);
    cx.bezierCurveTo(c-hw*0.12, top-h*0.08, lx+hw*0.42, top-h*0.06, lx+hw*0.28, top+h*0.01);
    // Left upper — frontal lobe bump
    cx.bezierCurveTo(lx+hw*0.14, top-h*0.04, lx-hw*0.02, top+h*0.06, lx+hw*0.06, top+h*0.18);
    // Left side down
    cx.bezierCurveTo(lx-hw*0.02, midY-h*0.10, lx-hw*0.04, bot-h*0.50, lx, bot-h*0.38);
    cx.bezierCurveTo(lx-hw*0.08, bot-h*0.25, lx-hw*0.06, bot-h*0.08, lx+hw*0.10, bot-4);
    cx.closePath();
  }

  // ── BRAIN INTERIOR: dark sulcus background + organic gyri texture ──
  // Matches the real brain fold appearance from reference images.
  anatomyPath();
  // Deep dark sulcus fill (the valleys between folds)
  const bgG=cx.createLinearGradient(c,top,c,bot);
  bgG.addColorStop(0,isOverload?'rgba(40,8,8,.82)':'rgba(6,14,36,.84)');
  bgG.addColorStop(0.5,isOverload?'rgba(30,5,5,.86)':'rgba(4,10,28,.88)');
  bgG.addColorStop(1,isOverload?'rgba(40,8,8,.82)':'rgba(8,14,36,.84)');
  cx.fillStyle=bgG;cx.fill();

    // ── WATER LEVEL (clipped to brain outline) ──
  cx.save();
  anatomyPath();cx.clip();
  if(flowFrac>0){
    const waterTop=bot-h*flowFrac;
    const waterG=cx.createLinearGradient(c,bot,c,waterTop);
    waterG.addColorStop(0,isOverload?'rgba(200,30,20,.55)':'rgba(79,195,247,.48)');
    waterG.addColorStop(0.6,isOverload?'rgba(220,50,30,.38)':'rgba(100,210,255,.32)');
    waterG.addColorStop(1,isOverload?'rgba(220,60,40,.15)':'rgba(140,230,255,.10)');
    cx.fillStyle=waterG;
    cx.fillRect(c-hw*1.1,waterTop,hw*2.2,bot-waterTop+10);
    // Water surface shimmer
    cx.strokeStyle=isOverload?'rgba(255,100,60,.50)':'rgba(79,195,247,.55)';
    cx.lineWidth=1.2;
    cx.beginPath();
    for(let px=0;px<=hw*2;px+=3){
      const wx=c-hw+px;
      const wy=waterTop+Math.sin(px/12+t*2.2)*2.4+Math.cos(px/8+t*1.5)*1.4;
      px===0?cx.moveTo(wx,wy):cx.lineTo(wx,wy);
    }
    cx.stroke();
  }

  cx.restore();  // end water clip

  // ── FOLD RAMP VISUAL LINES (match physics ramp positions exactly) ──
  // Bold 3D-style curved lines at the same positions as the physics ramps.
  // When blocks bounce off a ramp, they're bouncing off what you see here.
  const foldBase=isOverload?'rgba(255,110,80,':'rgba(79,195,247,';

  // Each ramp position: {y:fraction, xOff:fraction, w:fraction, deg}
  const VISUAL_FOLDS=[
    {y:0.14,xOff:-0.10,w:0.55,deg: 22},
    {y:0.28,xOff: 0.10,w:0.55,deg:-22},
    {y:0.42,xOff:-0.08,w:0.52,deg: 18},
    {y:0.56,xOff: 0.08,w:0.52,deg:-18},
    {y:0.70,xOff: 0.00,w:0.46,deg:  9},
  ];

  // ── BRAIN-FOLD GYRUS CURVES (S-shaped, same angle as physics ramps) ──
  // Each line is drawn as a series of bezier gyri (brain folds) at the same angle.
  // The physics stays as straight ramps; only the visual is wavy.
  VISUAL_FOLDS.forEach((r,ri)=>{
    const ry=top+h*r.y;
    const rxCenter=c+hw*r.xOff;
    const halfW=hw*r.w;
    const ang=r.deg*Math.PI/180;
    const hitFlash=state.pinFlashes&&state.pinFlashes[ri]?
      Math.max(0,1-(performance.now()-state.pinFlashes[ri])/550):0;

    cx.save();
    cx.translate(rxCenter,ry);
    cx.rotate(ang);

    // ── Draw the fold as 3 gyrus bumps (bezier S-curves) ──
    // A brain gyrus looks like repeating rounded ridges, alternating up/down.
    const numGyri=3;
    const segW=(halfW*2)/numGyri;
    const gH=9+hitFlash*4;  // gyrus amplitude

    // Shadow pass (depth)
    cx.strokeStyle=`rgba(0,0,0,${0.50+hitFlash*0.20})`;
    cx.lineWidth=8+hitFlash*3;
    cx.lineCap='round';cx.lineJoin='round';
    cx.beginPath();cx.moveTo(-halfW,3);
    for(let g=0;g<numGyri;g++){
      const x0=-halfW+g*segW, x3=x0+segW;
      const dir=g%2===0?-1:1;
      const x1=x0+segW*0.28, x2=x0+segW*0.72;
      cx.bezierCurveTo(x1,dir*gH*1.3, x1,dir*gH*1.3, x0+segW*0.5,dir*gH*0.5);
      cx.bezierCurveTo(x2,-dir*gH*0.5, x2,-dir*gH*0.5, x3,0);
    }
    cx.stroke();

    // Main gyrus line (lit) — thinner since the brain texture is now the background
    const la=0.48+hitFlash*0.45;
    cx.strokeStyle=foldBase+la+')';
    cx.lineWidth=3.5+hitFlash*5;
    cx.shadowColor=isOverload?'rgba(255,80,40,.90)':'rgba(79,195,247,.90)';
    cx.shadowBlur=12+hitFlash*24;
    cx.beginPath();cx.moveTo(-halfW,0);
    for(let g=0;g<numGyri;g++){
      const x0=-halfW+g*segW, x3=x0+segW;
      const dir=g%2===0?-1:1;
      const x1=x0+segW*0.28, x2=x0+segW*0.72;
      cx.bezierCurveTo(x1,dir*gH*1.3, x1,dir*gH*1.3, x0+segW*0.5,dir*gH*0.5);
      cx.bezierCurveTo(x2,-dir*gH*0.5, x2,-dir*gH*0.5, x3,0);
    }
    cx.stroke();

    // Bright ridge highlight on top edge of each gyrus
    cx.strokeStyle=`rgba(255,255,255,${0.35+hitFlash*0.35})`;
    cx.lineWidth=1.8;cx.shadowBlur=5+hitFlash*8;
    cx.beginPath();cx.moveTo(-halfW,-3);
    for(let g=0;g<numGyri;g++){
      const x0=-halfW+g*segW, x3=x0+segW;
      const dir=g%2===0?-1:1;
      const x1=x0+segW*0.28, x2=x0+segW*0.72;
      cx.bezierCurveTo(x1,dir*gH*1.3-2, x1,dir*gH*1.3-2, x0+segW*0.5,dir*gH*0.5-2);
      cx.bezierCurveTo(x2,-dir*gH*0.5-2, x2,-dir*gH*0.5-2, x3,-2);
    }
    cx.stroke();
    cx.shadowBlur=0;

    // Flash ripple burst when hit
    if(hitFlash>0.06){
      cx.strokeStyle=`rgba(255,255,255,${hitFlash*0.45})`;
      cx.lineWidth=1.0;
      cx.beginPath();cx.ellipse(0,0,halfW*0.45,8+hitFlash*14,0,0,Math.PI*2);cx.stroke();
    }
    cx.restore();

    });

  // ── BASKETS: glowing brackets — top=open-tube chutes, bottom=catch ──
  if(state.baskets){
    state.baskets.forEach(bk=>{
      const bkCol=bk.side==='L'?'rgba(79,195,247,':'rgba(255,200,60,';
      const shadowC=bk.side==='L'?'rgba(79,195,247,.7)':'rgba(255,200,60,.7)';
      cx.save();
      cx.lineWidth=4;cx.lineCap='round';cx.lineJoin='round';
      cx.shadowColor=shadowC;cx.shadowBlur=8;
      const BK_W=38,BK_H=30;
      const x=bk.x,y=bk.y;

      if(bk.open){
        // ── TOP BASKET = vacuum tube guide (no floor, two side walls only) ──
        cx.strokeStyle=bkCol+'0.80)';
        if(bk.side==='L'){
          // Back wall (left side, full height)
          cx.beginPath();cx.moveTo(x+4,y);cx.lineTo(x+4,y+BK_H);cx.stroke();
          // Front guide (right side, shorter — arrows hint at flow)
          cx.beginPath();cx.moveTo(x+BK_W,y);cx.lineTo(x+BK_W,y+BK_H*0.65);cx.stroke();
          // Flow arrows — suggest vacuum downward motion
          cx.strokeStyle=bkCol+'0.45)';cx.lineWidth=1.5;
          for(let ay=y+6;ay<y+BK_H-4;ay+=7){
            cx.beginPath();cx.moveTo(x+BK_W*0.5,ay);cx.lineTo(x+BK_W*0.5-4,ay+4);cx.moveTo(x+BK_W*0.5,ay);cx.lineTo(x+BK_W*0.5+4,ay+4);cx.stroke();
          }
        }else{
          cx.beginPath();cx.moveTo(x+BK_W-4,y);cx.lineTo(x+BK_W-4,y+BK_H);cx.stroke();
          cx.beginPath();cx.moveTo(x,y);cx.lineTo(x,y+BK_H*0.65);cx.stroke();
          cx.strokeStyle=bkCol+'0.45)';cx.lineWidth=1.5;
          for(let ay=y+6;ay<y+BK_H-4;ay+=7){
            cx.beginPath();cx.moveTo(x+BK_W*0.5,ay);cx.lineTo(x+BK_W*0.5-4,ay+4);cx.moveTo(x+BK_W*0.5,ay);cx.lineTo(x+BK_W*0.5+4,ay+4);cx.stroke();
          }
        }
      }else{
        // ── BOTTOM BASKET = solid U-catch ──
        cx.strokeStyle=bkCol+'0.78)';
        cx.beginPath();
        if(bk.side==='L'){
          cx.moveTo(x+4,y);
          cx.lineTo(x+4,y+BK_H);       // back wall down
          cx.lineTo(x+BK_W,y+BK_H);    // floor right
          cx.lineTo(x+BK_W,y+BK_H*0.3);// front wall up (shorter opening)
        }else{
          cx.moveTo(x+BK_W-4,y);
          cx.lineTo(x+BK_W-4,y+BK_H);
          cx.lineTo(x,y+BK_H);
          cx.lineTo(x,y+BK_H*0.3);
        }
        cx.stroke();
        // Glow fill tint inside
        cx.fillStyle=bkCol+'0.06)';
        cx.fill();
      }
      cx.shadowBlur=0;cx.restore();
    });
  }

  // Central longitudinal fissure (vertical split between hemispheres)
  cx.strokeStyle=foldBase+'0.22)';cx.lineWidth=2;cx.shadowBlur=6;
  cx.setLineDash([4,8]);
  cx.beginPath();cx.moveTo(c,top+h*0.02);cx.lineTo(c,bot-h*0.10);cx.stroke();
  cx.setLineDash([]);
  cx.shadowBlur=0;

  // Overload glitch bands
  if(isOverload){
    const glitchA=0.15+Math.random()*0.10;
    for(let g=0;g<3;g++){
      const gy=top+Math.random()*h;
      cx.fillStyle=`rgba(255,60,30,${glitchA})`;
      cx.fillRect(c-hw,gy,hw*2,2+Math.random()*4);
    }
    cx.fillStyle=`rgba(255,40,20,${0.06+Math.sin(t*8)*0.03})`;
    cx.fillRect(c-hw,top,hw*2,h);
  }

  cx.restore();

  // ── OUTER BRAIN BORDER (with glow) ──
  anatomyPath();
  cx.strokeStyle=isOverload?`rgba(255,80,40,${0.7+Math.sin(t*6)*0.2})`:`rgba(79,195,247,${0.45+Math.sin(t*1.5)*0.08})`;
  cx.lineWidth=isOverload?2.5:1.8;
  cx.shadowColor=isOverload?'#FF3020':'#4FC3F7';
  cx.shadowBlur=isOverload?24:10;
  cx.stroke();
  cx.shadowBlur=0;

  // ── OVERLOAD LABEL ──
  if(isOverload){
    cx.fillStyle=`rgba(255,100,60,${0.80+Math.sin(t*8)*0.20})`;
    cx.font=`bold ${Math.min(W*0.04,16)}px monospace`;
    cx.textAlign='center';
    cx.shadowColor='rgba(255,60,30,.9)';cx.shadowBlur=16;
    cx.fillText(`CORTEX OVERLOAD [${liveNegs}]`,c,cy+h*0.40);
    cx.shadowBlur=0;
  }

  // ── PEGGLE PINS — glowing circles, flash on hit ──
  if(state.pegPins&&state.pegPins.length){
    const now=performance.now();
    state.pegPins.forEach((p,i)=>{
      const flashAge=state.pinFlashes&&state.pinFlashes[i]?(now-state.pinFlashes[i]):Infinity;
      const flashFrac=flashAge<500?1-(flashAge/500):0;  // 0..1, 1 = just hit
      const pinAlpha=0.30+flashFrac*0.60;
      const pinR=p.r*(0.85+flashFrac*0.55);             // grows on hit
      const pinGlow=4+flashFrac*22;
      const pinColor=isOverload?
        `rgba(255,100,60,${pinAlpha})`:
        `rgba(79,195,247,${pinAlpha})`;
      const rimColor=isOverload?
        `rgba(255,150,100,${pinAlpha+0.25})`:
        `rgba(140,225,255,${pinAlpha+0.25})`;
      cx.save();
      cx.shadowColor=isOverload?'rgba(255,80,40,.9)':'rgba(79,195,247,.9)';
      cx.shadowBlur=pinGlow;
      // Filled glow circle
      cx.fillStyle=pinColor;
      cx.beginPath();cx.arc(p.x,p.y,pinR,0,Math.PI*2);cx.fill();
      // Bright rim
      cx.strokeStyle=rimColor;
      cx.lineWidth=1.4+flashFrac*1.2;
      cx.beginPath();cx.arc(p.x,p.y,pinR,0,Math.PI*2);cx.stroke();
      // Extra pulse ring if just hit
      if(flashFrac>0.05){
        cx.globalAlpha=flashFrac*0.4;
        cx.beginPath();cx.arc(p.x,p.y,pinR*1.8+flashFrac*10,0,Math.PI*2);cx.stroke();
        cx.globalAlpha=1;
      }
      cx.restore();
    });
  }

  // ── CORNER BRACKETS ──
  const bkL=c-hw,bkR=c+hw,bkT=top,bkB=bot,bkS=12;
  cx.strokeStyle='rgba(79,195,247,.35)';cx.lineWidth=1.5;
  [[bkL,bkT,1,1],[bkR,bkT,-1,1],[bkL,bkB,1,-1],[bkR,bkB,-1,-1]].forEach(([bx,by,dx,dy])=>{
    cx.beginPath();cx.moveTo(bx+dx*bkS,by);cx.lineTo(bx,by);cx.lineTo(bx,by+dy*bkS);cx.stroke();
  });
}


function drawWordBox(x,y,word,kind,scale){
  scale=scale||1;
  const lines=wrapWord(word.toUpperCase(),14);
  const lineH=11;
  const isPos=kind==='pos';
  const col=isPos?'#4FC3F7':'#FF5252';
  const glow=isPos?'rgba(79,195,247,.9)':'rgba(255,82,82,.85)';
  // Measure widest line
  cx.font=`700 ${10*scale}px monospace`;
  let maxW=0;
  lines.forEach(ln=>{const w=cx.measureText(ln).width;if(w>maxW)maxW=w;});
  const boxW=maxW+18*scale;
  const boxH=lines.length*lineH*scale+10*scale;
  // Glow halo behind box
  cx.shadowColor=glow;
  cx.shadowBlur=14*scale;
  // Box fill (translucent dark)
  cx.fillStyle=isPos?'rgba(79,195,247,.12)':'rgba(255,82,82,.16)';
  cx.fillRect(x-boxW/2,y-boxH/2,boxW,boxH);
  // Bright colored border
  cx.shadowBlur=8*scale;
  cx.strokeStyle=col;
  cx.lineWidth=1.4*scale;
  cx.strokeRect(x-boxW/2,y-boxH/2,boxW,boxH);
  // Inner corner accents (cyberpunk HUD detail)
  cx.shadowBlur=0;
  cx.beginPath();
  const cs=4*scale;
  cx.moveTo(x-boxW/2,y-boxH/2+cs);cx.lineTo(x-boxW/2+cs,y-boxH/2);
  cx.moveTo(x+boxW/2,y-boxH/2+cs);cx.lineTo(x+boxW/2-cs,y-boxH/2);
  cx.moveTo(x-boxW/2,y+boxH/2-cs);cx.lineTo(x-boxW/2+cs,y+boxH/2);
  cx.moveTo(x+boxW/2,y+boxH/2-cs);cx.lineTo(x+boxW/2-cs,y+boxH/2);
  cx.strokeStyle='#fff';cx.lineWidth=1.2*scale;cx.stroke();
  // Glowing text
  cx.shadowColor=glow;
  cx.shadowBlur=10*scale;
  cx.fillStyle='#fff';
  cx.textAlign='center';
  const startY=y-(lines.length-1)*lineH*scale/2+3*scale;
  lines.forEach((ln,i)=>{
    cx.fillText(ln,x,startY+i*lineH*scale);
  });
  cx.shadowBlur=0;
}

function drawFalling(){
  state.falling.forEach(f=>{
    // Motion trail - faded ghosts behind the word as it falls
    if(f.trail&&f.trail.length>1){
      cx.save();
      cx.globalCompositeOperation='lighter';
      f.trail.forEach((t,i)=>{
        const a=(i/f.trail.length)*0.25;
        const r=14-(f.trail.length-i)*1.5;
        if(r>2){
          const col=f.kind==='pos'?`rgba(79,195,247,${a})`:`rgba(255,82,82,${a})`;
          const g=cx.createRadialGradient(t.x,t.y,0,t.x,t.y,r*2);
          g.addColorStop(0,col);
          g.addColorStop(1,'rgba(0,0,0,0)');
          cx.fillStyle=g;
          cx.fillRect(t.x-r*2,t.y-r*2,r*4,r*4);
        }
      });
      cx.restore();
    }
    drawWordBox(f.x,f.y,f.word,f.kind,1);
  });
}
function drawChoice(){
  if(state.phase!==PH.CHOICE)return;
  const cy=L.BY;
  state.choice.forEach(c=>{
    cx.globalAlpha=1-c.vanish;
    // Scale 1.35 so text is clearly readable without straining
    const br=1.55+Math.sin(performance.now()*.003+c.x)*.07;
    drawWordBox(c.x,cy+L.BR*.3,c.word,c.kind,br);
    cx.globalAlpha=1;
  });
  // Instruction text — brighter, larger, centered below the two words
  cx.save();
  cx.fillStyle='rgba(180,220,255,.80)';
  cx.font='400 9px monospace';
  cx.textAlign='center';
  cx.shadowColor='rgba(79,195,247,.5)';
  cx.shadowBlur=6;
  cx.fillText('TAP · DRAG INTO BRAIN',W/2,cy+L.BR*.3-44);
  cx.restore();
}
function drawDragWord(){
  if(state.phase!==PH.DRAG||!state.drag)return;
  const d=state.drag;
  drawWordBox(d.x,d.y,d.word,d.kind,1.1);
  cx.strokeStyle='rgba(255,255,255,.15)';
  cx.lineWidth=1;
  cx.setLineDash([2,3]);
  cx.beginPath();cx.moveTo(W/2,L.BY+L.BR*.4);cx.lineTo(d.x,d.y);cx.stroke();
  cx.setLineDash([]);
  // Ghost hand below the word — translucent pointing finger that follows the drag
  drawDragHand(d.x,d.y+18);
}

// Stylized pointing hand drawn below the dragged word. The index finger reaches
// up toward the word and the whole shape glows cyan, matching the Gemini concept.
function drawDragHand(x,y){
  cx.save();
  cx.translate(x,y);
  cx.shadowColor='rgba(120,200,255,.85)';
  cx.shadowBlur=14;
  cx.strokeStyle='rgba(200,230,255,.9)';
  cx.fillStyle='rgba(120,180,240,.18)';
  cx.lineWidth=1.5;
  cx.lineJoin='round';
  cx.beginPath();
  // Index finger (pointing up toward the word)
  cx.moveTo(-3,2);
  cx.lineTo(-3,-14);
  cx.quadraticCurveTo(-3,-19,1,-19);
  cx.quadraticCurveTo(5,-19,5,-14);
  cx.lineTo(5,0);
  // Middle finger knuckle bump
  cx.quadraticCurveTo(9,-1,11,3);
  cx.quadraticCurveTo(12,7,11,11);
  // Ring/pinky bumps
  cx.quadraticCurveTo(14,12,14,16);
  cx.quadraticCurveTo(14,22,9,24);
  // Wrist
  cx.lineTo(-7,24);
  cx.quadraticCurveTo(-12,24,-12,18);
  cx.lineTo(-12,8);
  // Thumb
  cx.quadraticCurveTo(-12,2,-9,0);
  cx.lineTo(-6,2);
  cx.closePath();
  cx.fill();cx.stroke();
  // Inner highlight line on the index finger (gives a wire-frame feel)
  cx.beginPath();
  cx.strokeStyle='rgba(220,240,255,.55)';
  cx.lineWidth=1;
  cx.moveTo(1,-17);cx.lineTo(1,-2);cx.stroke();
  cx.restore();
}
function drawShapes(){
  const t=performance.now()*.001;

  // ── 1. ADDITIVE GLOW HALOS (drawn first) ──
  cx.save();cx.globalCompositeOperation='lighter';
  state.shapes.forEach(s=>{
    if(s.dead)return;
    const verts=s.body.vertices;
    if(!verts||!verts.length)return;
    const px=s.body.position.x,py=s.body.position.y;
    const col=s.color||(s.kind==='pos'?'#00ACC1':'#E53935');
    const r=(s.hexR||30)*1.5;
    const g=cx.createRadialGradient(px,py,0,px,py,r);
    g.addColorStop(0,col+'60');g.addColorStop(1,col+'00');
    cx.fillStyle=g;cx.fillRect(px-r,py-r,r*2,r*2);
  });
  cx.restore();

  // ── 2. MAIN DRAW PASS ──
  state.shapes.forEach(s=>{
    if(s.dead)return;
    const col=s.color||(s.kind==='pos'?'#00ACC1':'#E53935');
    const word=(s.word||'').toUpperCase();
    const verts=s.body.vertices;
    const px=s.body.position.x,py=s.body.position.y;
    const ang=s.body.angle;

    // ── POSITIVE BALL (cyan glowing circle) ──
    if(s.body.label==='pos:fall'){
      cx.save();
      cx.translate(px,py);
      cx.shadowColor=col;cx.shadowBlur=18;
      const bg=cx.createRadialGradient(-4,-4,1,0,0,11);
      bg.addColorStop(0,'rgba(220,250,255,.98)');
      bg.addColorStop(0.5,col+'DD');
      bg.addColorStop(1,col+'60');
      cx.fillStyle=bg;cx.beginPath();cx.arc(0,0,11,0,Math.PI*2);cx.fill();
      cx.strokeStyle='rgba(200,245,255,.85)';cx.lineWidth=1.8;cx.shadowBlur=6;
      cx.beginPath();cx.arc(0,0,11,0,Math.PI*2);cx.stroke();
      cx.fillStyle='rgba(255,255,255,.90)';
      cx.font=`bold ${Math.min(W*0.018,8)}px monospace`;cx.textAlign='center';
      cx.shadowBlur=0;cx.fillText(word.substring(0,8),0,3);
      cx.restore();
      return;
    }

    // ── HEXAGON WORD BLOCK ──
    if(!verts||verts.length<3)return;

    cx.save();

    // Draw hexagon using body vertices (world coordinates — handles rotation natively)
    cx.beginPath();
    verts.forEach((v,i)=>{ i===0?cx.moveTo(v.x,v.y):cx.lineTo(v.x,v.y); });
    cx.closePath();

    // Main fill
    cx.shadowColor=col;cx.shadowBlur=10;
    cx.fillStyle=col;cx.fill();

    // Top-face highlight (3D brightness — lighter on upper portion of hex)
    cx.shadowBlur=0;
    cx.fillStyle='rgba(255,255,255,.30)';
    cx.save();
    // Clip to top half of the hexagon for highlight
    const cy2=s.body.position.y;
    cx.beginPath();
    verts.forEach((v,i)=>{ i===0?cx.moveTo(v.x,v.y):cx.lineTo(v.x,v.y); });
    cx.closePath();cx.clip();
    const hexR=s.hexR||30;
    cx.fillRect(px-hexR*1.3,cy2-hexR*1.3,hexR*2.6,hexR);
    cx.restore();

    // Bottom shadow (3D depth)
    cx.fillStyle='rgba(0,0,0,.30)';
    cx.save();
    cx.beginPath();
    verts.forEach((v,i)=>{ i===0?cx.moveTo(v.x,v.y):cx.lineTo(v.x,v.y); });
    cx.closePath();cx.clip();
    cx.fillRect(px-hexR*1.3,py,hexR*2.6,hexR*1.3);
    cx.restore();

    // Bright hexagon border
    cx.strokeStyle='rgba(255,255,255,.50)';cx.lineWidth=2.0;
    cx.beginPath();
    verts.forEach((v,i)=>{ i===0?cx.moveTo(v.x,v.y):cx.lineTo(v.x,v.y); });
    cx.closePath();cx.stroke();

    // Inner edge highlight (top-left rim — gives gem-like 3D feel)
    cx.strokeStyle='rgba(255,255,255,.22)';cx.lineWidth=1.0;
    if(verts.length>=6){
      cx.beginPath();
      cx.moveTo(verts[4].x,verts[4].y);
      cx.lineTo(verts[5].x,verts[5].y);
      cx.lineTo(verts[0].x,verts[0].y);
      cx.lineTo(verts[1].x,verts[1].y);
      cx.stroke();
    }

    // Crack marks if the block was hit
    if(s.hits>0){
      cx.strokeStyle=`rgba(255,255,255,${0.40+s.hits*0.15})`;cx.lineWidth=0.9;
      for(let i=0;i<1+s.hits;i++){
        const a=i*1.8+ang;
        const r0=hexR*0.1, r1=hexR*(0.5+Math.random()*0.3);
        cx.beginPath();
        cx.moveTo(px+Math.cos(a)*r0,py+Math.sin(a)*r0);
        cx.lineTo(px+Math.cos(a+0.3)*r1,py+Math.sin(a+0.3)*r1);
        cx.stroke();
      }
    }

    // Word text — centered, rotates with the hex
    cx.save();
    cx.translate(px,py);cx.rotate(ang);
    const hexR2=s.hexR||30;
    const fz=Math.max(7,Math.min(hexR2*0.28,10));
    cx.fillStyle='rgba(255,255,255,.95)';
    cx.font=`bold ${fz}px monospace`;cx.textAlign='center';
    cx.shadowColor='rgba(0,0,0,.55)';cx.shadowBlur=3;
    // Show word in 1-2 lines if it fits
    const maxW=hexR2*1.2;
    const full=word.substring(0,13);
    if(cx.measureText(full).width<=maxW){
      cx.fillText(full,0,fz*0.38);
    }else{
      const mid=Math.floor(full.length/2);
      cx.fillText(full.substring(0,mid),0,-fz*0.3);
      cx.fillText(full.substring(mid),0,fz*0.8);
    }
    cx.shadowBlur=0;
    cx.restore();

    cx.restore();
  });
}


function drawFx(){
  state.fx.forEach(e=>{
    if(e.type==='burst'){
      const a=Math.max(0,e.life/(e.maxLife||600));
      const sz=e.size||1.4;
      // Stacked shadow passes for bloom effect
      cx.shadowColor=e.c;
      cx.shadowBlur=12;
      cx.fillStyle=e.c;
      cx.globalAlpha=a;
      cx.beginPath();cx.arc(e.x,e.y,sz,0,Math.PI*2);cx.fill();
      // Bright white core
      cx.shadowBlur=6;
      cx.fillStyle='#fff';
      cx.globalAlpha=a*0.8;
      cx.beginPath();cx.arc(e.x,e.y,sz*0.5,0,Math.PI*2);cx.fill();
      cx.shadowBlur=0;
    }else if(e.type==='shimmer'){
      const a=Math.max(0,e.life/(e.maxLife||1400));
      const flicker=0.6+0.4*Math.sin(e.life*0.03);
      cx.shadowColor=e.c;
      cx.shadowBlur=8;
      cx.fillStyle=e.c;
      cx.globalAlpha=a*flicker;
      cx.beginPath();cx.arc(e.x,e.y,e.size||1,0,Math.PI*2);cx.fill();
      cx.shadowBlur=0;
    }else if(e.type==='ring'){
      const a=Math.max(0,e.life/(e.maxLife||600));
      cx.shadowColor=e.c;
      cx.shadowBlur=14;
      cx.strokeStyle=e.c;
      cx.globalAlpha=a*0.85;
      cx.lineWidth=(e.lw||2)*a;
      cx.beginPath();cx.arc(e.x,e.y,e.r,0,Math.PI*2);cx.stroke();
      cx.shadowBlur=0;
    }else if(e.type==='wave'){
      const a=Math.max(0,e.life/(e.small?400:500));
      cx.shadowColor=e.c;
      cx.shadowBlur=6;
      cx.strokeStyle=e.c;cx.globalAlpha=a*0.8;cx.lineWidth=1.2;
      cx.beginPath();cx.arc(e.x,e.y,e.r,0,Math.PI*2);cx.stroke();
      cx.beginPath();cx.arc(e.x,e.y,e.r*0.6,0,Math.PI*2);cx.stroke();
      cx.shadowBlur=0;
    }else if(e.type==='zap'){
      // Lightning beam from bulb to a doomed negative — bright jagged path
      // with a yellow core and a wider white-hot glow, fading over its lifetime.
      const a=Math.max(0,e.life/(e.maxLife||520));
      const segs=e.segments||[];
      if(segs.length<2)return;
      // Re-jitter every frame for that electric crackle feel
      const jittered=segs.map((p,idx)=>{
        if(idx===0||idx===segs.length-1)return p;
        return {x:p.x+(Math.random()-0.5)*4,y:p.y+(Math.random()-0.5)*4};
      });
      // Outer glow pass
      cx.save();
      cx.globalCompositeOperation='lighter';
      cx.shadowColor='rgba(255,230,120,1)';cx.shadowBlur=22;
      cx.strokeStyle=`rgba(255,220,120,${0.55*a})`;
      cx.lineWidth=6;
      cx.lineCap='round';cx.lineJoin='round';
      cx.beginPath();
      jittered.forEach((p,idx)=>idx===0?cx.moveTo(p.x,p.y):cx.lineTo(p.x,p.y));
      cx.stroke();
      // Bright inner core
      cx.shadowColor='rgba(255,255,255,1)';cx.shadowBlur=12;
      cx.strokeStyle=`rgba(255,255,255,${0.95*a})`;
      cx.lineWidth=1.8;
      cx.beginPath();
      jittered.forEach((p,idx)=>idx===0?cx.moveTo(p.x,p.y):cx.lineTo(p.x,p.y));
      cx.stroke();
      // Small impact flash at the target end
      const tip=jittered[jittered.length-1];
      const flashG=cx.createRadialGradient(tip.x,tip.y,0,tip.x,tip.y,28);
      flashG.addColorStop(0,`rgba(255,255,200,${0.7*a})`);
      flashG.addColorStop(0.4,`rgba(255,220,120,${0.35*a})`);
      flashG.addColorStop(1,'rgba(255,200,80,0)');
      cx.fillStyle=flashG;
      cx.fillRect(tip.x-30,tip.y-30,60,60);
      cx.restore();
    }
  });
  cx.globalAlpha=1;
}

// ---------- Main loop ----------
let lastT=performance.now();
function loop(now){
  const dt=Math.min(50,now-lastT);lastT=now;
  // SINGLE-SCREEN LAYOUT: camera stays at 0, no scrolling
  cam.y=0;cam.vy=0;
  // Decay burnout shake and intensity each frame during/after FULL
  if(state.burnoutShake>0)state.burnoutShake=Math.max(0,state.burnoutShake-0.018);
  if(state.burnoutIntensity>0&&state.phase!==PH.FULL)state.burnoutIntensity=Math.max(0,state.burnoutIntensity-0.012);
  // Decay brain shake quickly (it's a fast red pulse, not a sustained effect)
  if(state.brainShake>0)state.brainShake=Math.max(0,state.brainShake-0.045);
  if(state.phase!==PH.INTRO&&state.phase!==PH.FULL){
    Engine.update(eng,dt);
    tickForces(dt);
    tickPhase(dt);
    tickFx(dt);
  }
  bg();
  // Compute screen-shake offset (random jitter scaled by burnoutShake)
  const shakeX=state.burnoutShake>0?(Math.random()-0.5)*18*state.burnoutShake:0;
  const shakeY=state.burnoutShake>0?(Math.random()-0.5)*18*state.burnoutShake:0;
  cx.save();cx.translate(shakeX,shakeY-cam.y);
  if(state.phase!==PH.INTRO){
    drawHousing();
    drawFalling();
    drawBulb();
    drawChoice();
    drawBrain();
    drawShapes();
    drawDragWord();
    drawFx();
  }
  cx.restore();
  // Screen-pulse flash on big combos (decays each frame)
  if(state.screenPulse>0){
    cx.save();
    const flashG=cx.createRadialGradient(W/2,H/2,0,W/2,H/2,Math.max(W,H));
    flashG.addColorStop(0,`rgba(79,195,247,${0.18*state.screenPulse})`);
    flashG.addColorStop(0.5,`rgba(139,111,255,${0.08*state.screenPulse})`);
    flashG.addColorStop(1,'rgba(0,0,0,0)');
    cx.fillStyle=flashG;
    cx.fillRect(0,0,W,H);
    cx.restore();
    state.screenPulse=Math.max(0,state.screenPulse-0.04);
  }
  // Burnout red overlay — saturating vignette + corner glitch bands.
  // Plays whenever burnoutIntensity > 0 (peaks during FULL, decays after).
  if(state.burnoutIntensity>0){
    const bi=state.burnoutIntensity;
    cx.save();
    // Hot red vignette from edges inward
    const vg=cx.createRadialGradient(W/2,H/2,Math.min(W,H)*0.25,W/2,H/2,Math.max(W,H)*0.75);
    vg.addColorStop(0,`rgba(255,40,40,${0.04*bi})`);
    vg.addColorStop(0.55,`rgba(255,30,30,${0.18*bi})`);
    vg.addColorStop(1,`rgba(180,10,10,${0.42*bi})`);
    cx.fillStyle=vg;cx.fillRect(0,0,W,H);
    // Top / bottom red glitch bands at peak intensity
    if(bi>0.4){
      cx.globalCompositeOperation='lighter';
      cx.fillStyle=`rgba(255,40,40,${0.12*bi})`;
      const bandH=8+Math.random()*16;
      const bandY=Math.random()*H;
      cx.fillRect(0,bandY,W,bandH);
      cx.fillRect(0,H-bandY-bandH,W,bandH);
    }
    cx.restore();
  }
  // Subtle scanline overlay (retro-cyberpunk vibe - matches Gemini concept)
  if(state.phase!==PH.INTRO)drawScanlines();
  // Music-reactive audio waveform (screen space, after cam restore)
  if(state.phase!==PH.INTRO)drawAudioWave();
  // Screen-space HUD overlays (decorative cyberpunk panels — fixed in screen space)
  if(state.phase!==PH.INTRO){
    drawSideBoxes();
    drawScreenHUD();
  }
  // Music-reactive flow bar glow — sampled and applied each frame
  sampleAudioLevel();
  applyMusicVisuals();
  requestAnimationFrame(loop);
}

// ---------- Faint scanline overlay for retro CRT/HUD feel ----------
function drawScanlines(){
  cx.save();
  cx.globalAlpha=0.045;
  cx.fillStyle='#4FC3F7';
  for(let y=0;y<H;y+=3){
    cx.fillRect(0,y,W,1);
  }
  // Subtle vignette darkening on edges
  cx.globalAlpha=1;
  const vg=cx.createRadialGradient(W/2,H/2,Math.min(W,H)*0.35,W/2,H/2,Math.max(W,H)*0.7);
  vg.addColorStop(0,'rgba(0,0,0,0)');
  vg.addColorStop(1,'rgba(0,0,0,0.45)');
  cx.fillStyle=vg;
  cx.fillRect(0,0,W,H);
  cx.restore();
}

// ---------- Decorative cyberpunk HUD overlays (matches Gemini concept) ----------
// ══════════════════════════════════════════════════════════════════
// SIDE BOX SYSTEM — 6 boxes (3 per side), all fill with water
// Left:  [FLOW] [FIGHTER] [DREAMER]
// Right: [LEVEL] [QUITTER] [REBEL]
// ══════════════════════════════════════════════════════════════════

// Streak particles that drop into the LEVEL box
let streakDrops=[];
function addStreakDrop(){
  const rx=(L.SBXR||W-72)+((L.SBW||64)/2);
  streakDrops.push({x:rx+(Math.random()-0.5)*8,y:L.BT||H*0.24,vy:0,life:1});
}

const PBOX_DEFS=[
  {key:'fighter',label:'SALIENCE', col:'#4FC3F7',side:'L',row:1},  // salience network: detects priority stimuli
  {key:'dreamer',label:'DEF.MODE', col:'#CE93D8',side:'L',row:2},  // default mode network: mind-wandering
  {key:'quitter',label:'AVOIDANT', col:'#FF5252',side:'R',row:1},  // avoidant coping style
  {key:'rebel',  label:'IMPULSIV', col:'#FF9800',side:'R',row:2},  // impulsivity / dysregulation
];

function drawSideBoxes(){
  if(state.phase===PH.INTRO)return;
  const t=performance.now()*.001;
  const BW=L.SBW||Math.min(W*0.115,68);
  const fullH=L.BB-L.BT;
  // Three boxes per side, stacked
  const BH=Math.floor((fullH-8)/3)-4;
  const LX=L.SBXL||4;
  const RX=L.SBXR||W-BW-4;
  // Raise the top FLOW and LEVEL boxes above the standard brain-top position
  const y0=Math.max(L.BY+L.BR*2.2, L.BT-BH*0.45);
  const rows=[y0, L.BT+2, L.BT+(BH+6)];

  // ── Personality scores ──
  const sc=state.personality;
  const pVals=[sc.fighter,sc.dreamer,sc.quitter,sc.rebel];
  const maxP=Math.max(1,...pVals);
  const fills=pVals.map(v=>Math.min(1.0,v/Math.max(1,maxP*1.15)));
  const domIdx=fills.indexOf(Math.max(...fills));

  // ── Streak/Level score ──
  const levelScore=Math.min(1,(state.erases||0)/Math.max(1,20));

  // ── Flow box ──
  const flowFill=Math.min(1,state.flow);

  function drawWaterBox(bx,by,bw,bh,fill,col,label,isDom,ticker){
    const bright=Math.pow(fill,0.5);
    const glow=bright*(isDom?28:16);
    cx.save();
    if(fill>0.15){cx.shadowColor=col;cx.shadowBlur=glow;}
    // Background
    cx.fillStyle='rgba(0,0,0,0.70)';
    cx.beginPath();cx.roundRect(bx,by,bw,bh,4);cx.fill();
    // Water fill
    const fillH=bh*fill;
    if(fillH>0.5){
      cx.save();
      cx.beginPath();cx.roundRect(bx,by,bw,bh,4);cx.clip();
      // Water body gradient
      const wG=cx.createLinearGradient(bx,by+bh,bx,by+bh-fillH);
      const hex=col;
      wG.addColorStop(0,hex+(Math.round((0.35+bright*0.25)*255).toString(16).padStart(2,'0')));
      wG.addColorStop(0.5,hex+(Math.round((0.50+bright*0.30)*255).toString(16).padStart(2,'0')));
      const surfW=fill>0.65?(fill-0.65)/0.35:0;
      if(surfW>0){
        const wb=Math.round((0.65+surfW*0.35)*255);
        wG.addColorStop(1,`rgba(${wb},${wb},${wb},${0.55+surfW*0.35})`);
      }else{
        wG.addColorStop(1,hex+(Math.round((0.65+bright*0.20)*255).toString(16).padStart(2,'0')));
      }
      cx.fillStyle=wG;
      cx.fillRect(bx,by+bh-fillH,bw,fillH);
      // Surface wave
      const wY=by+bh-fillH;
      cx.strokeStyle=col+(Math.round((0.40+bright*0.35)*255).toString(16).padStart(2,'0'));
      cx.lineWidth=1.2;
      cx.beginPath();
      for(let px=0;px<=bw;px+=2){
        const sy=wY+Math.sin((px/bw)*Math.PI*3+t*2.4)*2.0;
        px===0?cx.moveTo(bx,sy):cx.lineTo(bx+px,sy);
      }
      cx.stroke();
      // Sheen
      if(bright>0.45){
        const sAlpha=(bright-0.45)*0.45;
        cx.fillStyle=`rgba(255,255,255,${sAlpha})`;
        cx.fillRect(bx,wY,bw,5);
      }
      cx.restore();
    }
    // Border
    cx.strokeStyle=col+(Math.round((0.25+bright*0.70)*255).toString(16).padStart(2,'0'));
    cx.lineWidth=isDom?1.8:1.1;
    cx.shadowColor=col;cx.shadowBlur=bright*14;
    cx.beginPath();cx.roundRect(bx,by,bw,bh,4);cx.stroke();
    cx.shadowBlur=0;
    // Label
    const lsz=Math.max(6,Math.floor(bw*0.155));
    cx.fillStyle=fill<0.12?'rgba(255,255,255,.30)':col;
    cx.font=`700 ${lsz}px monospace`;cx.textAlign='center';
    cx.shadowColor=col;cx.shadowBlur=fill>0.25?5:0;
    cx.fillText(label,bx+bw/2,by+lsz+2);
    cx.shadowBlur=0;
    // Ticker (percentage or level)
    if(ticker!==undefined){
      cx.fillStyle=`rgba(255,255,255,${0.38+bright*0.52})`;
      cx.font=`500 ${lsz-1}px monospace`;
      cx.fillText(ticker,bx+bw/2,by+bh-3);
    }
    // Dominant star
    if(isDom&&fill>0.30){
      cx.fillStyle=col;cx.globalAlpha=Math.min(1,(fill-0.30)/0.25);
      cx.font=`bold ${Math.round(lsz*1.6)}px sans-serif`;
      cx.fillText('★',bx+bw/2,by+bh/2+lsz*0.55);
      cx.globalAlpha=1;
    }
    cx.restore();
  }

  // ── LEFT SIDE ──
  // Box 0: FLOW
  drawWaterBox(LX,rows[0],BW,BH,flowFill,'#4FC3F7','FLOW',false,Math.round(flowFill*100)+'%');
  // Box 1: FIGHTER
  drawWaterBox(LX,rows[1],BW,BH,fills[0],'#4FC3F7','SALIENCE',domIdx===0&&pVals[0]>2,null);
  // Box 2: DREAMER
  drawWaterBox(LX,rows[2],BW,BH,fills[1],'#CE93D8','DEF.MODE',domIdx===1&&pVals[1]>2,null);

  // ── RIGHT SIDE ──
  // Box 0: LEVEL (streaks absorbed)
  // Draw streak particles dropping into level box
  streakDrops.forEach((d,i)=>{
    d.vy+=0.4;d.y+=d.vy;d.life-=0.018;
    const dy=d.y-(rows[0]+BH-BH*levelScore);
    if(dy>0){d.y=rows[0]+BH-BH*levelScore;d.vy*=-0.3;}
    const a=Math.max(0,d.life);
    cx.globalAlpha=a;
    cx.fillStyle='#FFC832';
    cx.shadowColor='#FFC832';cx.shadowBlur=8;
    cx.beginPath();cx.arc(d.x,d.y,3,0,Math.PI*2);cx.fill();
    cx.shadowBlur=0;cx.globalAlpha=1;
  });
  streakDrops=streakDrops.filter(d=>d.life>0&&d.y<rows[0]+BH+10);
  drawWaterBox(RX,rows[0],BW,BH,levelScore,'#FFC832','LEVEL',false,`LV${Math.ceil(levelScore*10)||0}`);
  // Box 1: QUITTER
  drawWaterBox(RX,rows[1],BW,BH,fills[2],'#FF5252','AVOIDANT',domIdx===2&&pVals[2]>2,null);
  // Box 2: REBEL
  drawWaterBox(RX,rows[2],BW,BH,fills[3],'#FF9800','IMPULSIV',domIdx===3&&pVals[3]>2,null);

  // ── DOMINANT PERSONALITY VERDICT ──
  const dominated=pVals.some(v=>v>5);
  if(dominated){
    const domFill=fills[domIdx];
    if(domFill>0.50){
      const def=PBOX_DEFS[domIdx]||{col:'#4FC3F7',label:'FOCUSED'};
      const fa=Math.min(1,(domFill-0.50)/0.25);
      cx.save();
      cx.globalAlpha=fa*0.90;
      cx.fillStyle=def.col;
      cx.font=`700 ${Math.min(W*0.030,12)}px monospace`;
      cx.textAlign='center';
      cx.shadowColor=def.col;cx.shadowBlur=10+Math.sin(t*2)*3;
      cx.fillText('YOU ARE: '+def.label,W/2,L.BB+14);
      cx.restore();
    }
  }
}


function drawScreenHUD(){
  const t=performance.now()*.001;
  cx.save();
  cx.font='400 7px monospace';
  cx.fillStyle='rgba(79,195,247,.55)';
  cx.strokeStyle='rgba(79,195,247,.4)';
  cx.lineWidth=1;
  cx.shadowColor='rgba(79,195,247,.6)';
  cx.shadowBlur=4;

  // BRAIN ICON — moved to center-top above lightbulb (no overlap with side boxes)
  const _bShk=state.brainShake||0;
  const _bShkX=_bShk>0?(Math.random()-0.5)*6*_bShk:0;
  const _bShkY=_bShk>0?(Math.random()-0.5)*3*_bShk:0;
  // Position: small icon just left of center at very top, above the lightbulb
  const rx=W*0.50-L.BR*2.8+_bShkX, ry=L.BY*0.55+_bShkY, rr=14;
  const liveNegsHUD=state.shapes.filter(s=>!s.dead&&s.kind==='neg').length;
  const hudOvld=liveNegsHUD>=10;
  const hudHit=_bShk>0.2; // flash red on any new negative, fades quickly
  const hudRed=hudOvld||hudHit;
  const brainPulse=hudOvld?(0.85+Math.sin(t*7)*0.15):hudHit?(0.7+_bShk*0.3):1;
  // Outer circular scanner frame — cyan normally, red on hit or overload
  cx.strokeStyle=hudRed?`rgba(255,${hudOvld?80:120},82,${(hudOvld?0.5:_bShk*0.9)+Math.sin(t*6)*0.1})`:'rgba(79,195,247,.4)';
  cx.lineWidth=hudRed?1.8:1.2;
  cx.shadowColor=hudRed?'rgba(255,60,60,.7)':'rgba(79,195,247,.3)';
  cx.shadowBlur=hudRed?12:4;
  cx.beginPath();cx.arc(rx,ry,rr,0,Math.PI*2);cx.stroke();
  cx.shadowBlur=4;
  // Rotating sweep arc
  cx.strokeStyle=hudOvld?'rgba(255,120,120,.85)':'rgba(120,210,255,.85)';
  cx.lineWidth=1.6;
  const sweep=t*0.9;
  cx.beginPath();cx.arc(rx,ry,rr*0.94,sweep,sweep+0.7);cx.stroke();
  // ——— Classic walnut brain silhouette ———
  cx.save();
  cx.translate(rx,ry);
  const bs=rr*0.80;
  cx.shadowColor=hudRed?'rgba(255,70,70,.9)':'rgba(79,195,247,.7)';
  cx.shadowBlur=8;
  cx.fillStyle=hudRed?'rgba(100,8,8,.80)':'rgba(18,55,105,.80)';
  cx.strokeStyle=hudRed?`rgba(255,90,90,${brainPulse})`:'rgba(145,215,255,.98)';
  cx.lineWidth=1.6;
  // Fill pass
  cx.beginPath();
  cx.moveTo(-bs*0.16,bs*0.84);
  cx.bezierCurveTo(-bs*0.22,bs*1.0,-bs*0.70,bs*0.80,-bs*0.96,bs*0.24);
  cx.bezierCurveTo(-bs*1.10,-bs*0.06,-bs*1.05,-bs*0.78,-bs*0.66,-bs*0.98);
  cx.bezierCurveTo(-bs*0.44,-bs*1.10,-bs*0.14,-bs*1.12,0,-bs*1.08);
  cx.bezierCurveTo(bs*0.14,-bs*1.12,bs*0.44,-bs*1.10,bs*0.66,-bs*0.98);
  cx.bezierCurveTo(bs*1.05,-bs*0.78,bs*1.10,-bs*0.06,bs*0.96,bs*0.24);
  cx.bezierCurveTo(bs*0.70,bs*0.80,bs*0.22,bs*1.0,bs*0.16,bs*0.84);
  cx.bezierCurveTo(bs*0.11,bs*0.96,-bs*0.11,bs*0.96,-bs*0.16,bs*0.84);
  cx.closePath();cx.fill();
  // Cerebellum bump lower-back
  cx.fillStyle=hudRed?'rgba(140,8,8,.80)':'rgba(22,65,120,.82)';
  cx.beginPath();cx.ellipse(bs*0.50,bs*0.54,bs*0.28,bs*0.17,0.25,0,Math.PI*2);cx.fill();
  // Stroke main outline
  cx.beginPath();
  cx.moveTo(-bs*0.16,bs*0.84);
  cx.bezierCurveTo(-bs*0.22,bs*1.0,-bs*0.70,bs*0.80,-bs*0.96,bs*0.24);
  cx.bezierCurveTo(-bs*1.10,-bs*0.06,-bs*1.05,-bs*0.78,-bs*0.66,-bs*0.98);
  cx.bezierCurveTo(-bs*0.44,-bs*1.10,-bs*0.14,-bs*1.12,0,-bs*1.08);
  cx.bezierCurveTo(bs*0.14,-bs*1.12,bs*0.44,-bs*1.10,bs*0.66,-bs*0.98);
  cx.bezierCurveTo(bs*1.05,-bs*0.78,bs*1.10,-bs*0.06,bs*0.96,bs*0.24);
  cx.bezierCurveTo(bs*0.70,bs*0.80,bs*0.22,bs*1.0,bs*0.16,bs*0.84);
  cx.bezierCurveTo(bs*0.11,bs*0.96,-bs*0.11,bs*0.96,-bs*0.16,bs*0.84);
  cx.closePath();cx.stroke();
  // Cerebellum stroke + fold line
  cx.strokeStyle=hudRed?`rgba(255,100,100,${brainPulse})`:'rgba(145,215,255,.90)';
  cx.lineWidth=1.1;
  cx.beginPath();cx.ellipse(bs*0.50,bs*0.54,bs*0.28,bs*0.17,0.25,0,Math.PI*2);cx.stroke();
  cx.beginPath();cx.moveTo(bs*0.25,bs*0.48);cx.quadraticCurveTo(bs*0.50,bs*0.42,bs*0.74,bs*0.52);cx.stroke();
  cx.shadowBlur=0;
  // Central fissure — dashed walnut-split from top notch downward
  cx.strokeStyle='rgba(90,165,230,.55)';cx.lineWidth=0.9;cx.setLineDash([2,4]);
  cx.beginPath();cx.moveTo(0,-bs*1.08);cx.bezierCurveTo(bs*0.05,-bs*0.55,-bs*0.05,bs*0.0,0,bs*0.52);cx.stroke();cx.setLineDash([]);
  // Gyri — 3 each hemisphere
  const gyCol=hudRed?'rgba(255,150,150,.60)':'rgba(120,200,255,.62)';
  cx.strokeStyle=gyCol;cx.lineWidth=0.85;
  cx.beginPath();cx.moveTo(-bs*0.82,-bs*0.62);cx.quadraticCurveTo(-bs*0.46,-bs*0.82,-bs*0.06,-bs*0.64);cx.stroke();
  cx.beginPath();cx.moveTo(-bs*0.90,-bs*0.24);cx.quadraticCurveTo(-bs*0.50,-bs*0.42,-bs*0.06,-bs*0.24);cx.stroke();
  cx.beginPath();cx.moveTo(-bs*0.84,bs*0.14);cx.quadraticCurveTo(-bs*0.46,bs*0.02,-bs*0.06,bs*0.14);cx.stroke();
  cx.beginPath();cx.moveTo(bs*0.06,-bs*0.64);cx.quadraticCurveTo(bs*0.46,-bs*0.82,bs*0.82,-bs*0.60);cx.stroke();
  cx.beginPath();cx.moveTo(bs*0.06,-bs*0.24);cx.quadraticCurveTo(bs*0.50,-bs*0.42,bs*0.90,-bs*0.22);cx.stroke();
  cx.beginPath();cx.moveTo(bs*0.06,bs*0.14);cx.quadraticCurveTo(bs*0.46,bs*0.02,bs*0.84,bs*0.16);cx.stroke();
  cx.restore();
  cx.shadowBlur=0;
  cx.fillStyle=hudRed?'rgba(255,140,140,.80)':'rgba(180,220,255,.55)';
  cx.font='400 7px monospace';cx.textAlign='left';
  cx.fillText(hudOvld?'⚠ OVERLOAD':hudHit?'⚠ HIT':'NEURAL SCAN',rx-24,ry+rr+10);
  const radarPct=Math.min(100,Math.round(state.flow*100));
  cx.fillStyle='#4FC3F7';
  cx.fillText(radarPct+'% ACTIVE',rx-22,ry+rr+18);

  // LEFT-SIDE: vertical mini-chart
  const cy=H*0.62,ch=50;
  cx.shadowBlur=3;
  cx.strokeStyle='rgba(79,195,247,.3)';
  cx.strokeRect(8,cy,30,ch);
  cx.fillStyle='rgba(79,195,247,.5)';
  for(let i=0;i<6;i++){
    const bh=Math.abs(Math.sin(t*.7+i))*ch*0.9;
    cx.fillRect(10+i*4.5,cy+ch-bh,3,bh);
  }
  cx.fillStyle='rgba(180,220,255,.55)';
  cx.shadowBlur=0;
  cx.fillText('FLOW',10,cy-3);

  // RIGHT-SIDE: stats readouts
  const sx=W-58;
  cx.fillStyle='rgba(180,220,255,.55)';
  cx.shadowColor='rgba(79,195,247,.4)';
  cx.shadowBlur=3;
  const flowPct=Math.min(100,Math.round(state.flow*100));
  cx.fillText('LEVEL',sx,H*0.42);
  cx.font='700 11px monospace';
  cx.fillStyle='#4FC3F7';
  cx.shadowBlur=6;
  cx.fillText(String(flowPct).padStart(4,'0')+'.50',sx,H*0.42+12);
  cx.font='400 7px monospace';
  cx.fillStyle='rgba(180,220,255,.55)';
  cx.shadowBlur=3;
  cx.fillText('STREAK',sx,H*0.50);
  cx.font='700 11px monospace';
  cx.fillStyle='#4FC3F7';
  cx.shadowBlur=6;
  cx.fillText('x'+(state.streak||0),sx,H*0.50+12);

  // RIGHT-SIDE: mini bar chart
  cx.font='400 7px monospace';
  cx.fillStyle='rgba(180,220,255,.55)';
  cx.shadowBlur=3;
  cx.fillText('PULSE',sx,H*0.58);
  cx.shadowBlur=2;
  cx.strokeStyle='rgba(79,195,247,.35)';
  cx.beginPath();
  for(let i=0;i<24;i++){
    const px=sx+i*2,py=H*0.62+Math.sin(t*4+i*.5)*6;
    if(i===0)cx.moveTo(px,py);
    else cx.lineTo(px,py);
  }
  cx.stroke();

  // Frame corner brackets (cyberpunk detail)
  cx.shadowBlur=0;
  cx.strokeStyle='rgba(79,195,247,.5)';
  cx.lineWidth=1.5;
  const corner=14;
  // TL
  cx.beginPath();cx.moveTo(6,corner);cx.lineTo(6,6);cx.lineTo(corner,6);cx.stroke();
  // TR
  cx.beginPath();cx.moveTo(W-corner,6);cx.lineTo(W-6,6);cx.lineTo(W-6,corner);cx.stroke();
  // BL
  cx.beginPath();cx.moveTo(6,H-corner);cx.lineTo(6,H-6);cx.lineTo(corner,H-6);cx.stroke();
  // BR
  cx.beginPath();cx.moveTo(W-corner,H-6);cx.lineTo(W-6,H-6);cx.lineTo(W-6,H-corner);cx.stroke();

  cx.restore();
}

// ---------- Input ----------
let scrollDrag=null;
function pos(e){
  const r=cv.getBoundingClientRect();
  const t=e.touches&&e.touches[0]||e.changedTouches&&e.changedTouches[0]||e;
  return{x:t.clientX-r.left,y:t.clientY-r.top};
}

function onDown(e){
  if(state.phase===PH.INTRO||state.phase===PH.FULL)return;
  e.preventDefault();
  const p=pos(e);
  
  // If in CHOICE, check if a word was tapped to start dragging
  if(state.phase===PH.CHOICE){
    const wy=p.y+cam.y;
    let picked=null;
    state.choice.forEach(c=>{
      const cyPos=L.BY+L.BR*.3;
      if(Math.abs(p.x-c.x)<80&&Math.abs(wy-cyPos)<42)picked=c;
    });
    if(picked){
      // Vanish the other, start drag
      state.choice.forEach(c=>{if(c!==picked)c.vanish=1;});
      state.drag={
        word:picked.word,kind:picked.kind,
        x:picked.x,y:L.BY+L.BR*.3,
        vx:0,vy:0,
        px:p.x,py:p.y
      };
      state.choice=[];
      state.phase=PH.DRAG;
      updHUD();
      return;
    }
  }
  // Otherwise scroll
  scrollDrag={x:p.x,y:p.y,sx:p.x,sy:p.y,t:performance.now(),lastY:p.y,lastT:performance.now()};
  cam.vy=0;
}

function onMove(e){
  if(state.phase===PH.INTRO||state.phase===PH.FULL)return;
  
  if(state.drag){
    e.preventDefault();
    const p=pos(e);
    const wy=p.y+cam.y;
    // Word follows finger (in world coords)
    state.drag.vx=(p.x-state.drag.px)*0.5;
    state.drag.vy=(p.y-state.drag.py)*0.5;
    state.drag.x=p.x;
    state.drag.y=wy;
    state.drag.px=p.x;
    state.drag.py=p.y;
    return;
  }
  
  if(scrollDrag){
    e.preventDefault();
    const p=pos(e);
    cam.y+=(scrollDrag.y-p.y);
    clampCam();
    const nowT=performance.now();
    if(nowT-scrollDrag.lastT>0){
      cam.vy=(scrollDrag.lastY-p.y)/(nowT-scrollDrag.lastT)*16;
    }
    scrollDrag.lastY=p.y;scrollDrag.lastT=nowT;
    scrollDrag.x=p.x;scrollDrag.y=p.y;
  }
}

function onUp(e){
  if(state.phase===PH.INTRO||state.phase===PH.FULL)return;
  e.preventDefault();
  
  if(state.drag){
    const d=state.drag;
    // Clamp drop position to inside the brain container.
    // If the player drops WAY outside (more than 60px beyond edge), cancel the drag
    // and return the word to the choice pool so the game doesn't break.
    const worldY=d.y; // already in world coords
    // Only cancel if dropped FAR to the sides (not above brain - player drags from top)
    const padX=40;
    const tooFarX=d.x < L.BCX-L.BHW-padX || d.x > L.BCX+L.BHW+padX;
    // Do NOT cancel drops from above the brain — clamp them to the top of the brain
    const tooFarBelow=worldY > L.BB+80;
    if(tooFarX||tooFarBelow){
      // Cancel drag — put the word back as a choice item
      state.choice=[{word:d.word,kind:d.kind,x:W/2,y:L.BY,vanish:0}];
      state.phase=PH.CHOICE;state.t=0;
      state.drag=null;
      updHUD();
      return;
    }
    // Clamp X inside brain; clamp Y to brain bounds (drops from above → spawn at brain top)
    const cx2=Math.max(L.BCX-L.BHW+20, Math.min(L.BCX+L.BHW-20, d.x));
    // Spawn ABOVE the brain top so the word visibly falls IN from the top.
    // If dropped anywhere above brain bottom, always start from just above brain.
    const cy2=worldY>L.BB-30?L.BB-30:L.BT-35;
    spawnShape(d.word,cx2,cy2,d.vx,d.vy);
    state.drag=null;
    state.phase=PH.SETTLE;state.t=0;
    updHUD();
    return;
  }
  
  if(scrollDrag){
    scrollDrag=null;
  }
}

cv.addEventListener('mousedown',onDown,{passive:false});
cv.addEventListener('mousemove',onMove,{passive:false});
window.addEventListener('mouseup',onUp,{passive:false});
cv.addEventListener('touchstart',onDown,{passive:false});
cv.addEventListener('touchmove',onMove,{passive:false});
window.addEventListener('touchend',onUp,{passive:false});
window.addEventListener('touchcancel',onUp,{passive:false});

// ---------- Brain full ----------
function triggerFull(){
  state.phase=PH.FULL;
  // Kick off burnout cinematic: red saturation ramps up, screen shakes hard then decays.
  state.burnoutIntensity=1;
  state.burnoutShake=1;
  // Save progress - flow state reached for this category
  // (only when reaching by clearing, not by overflow)
  if(state.flow>=1)markCategoryCleared(state.category);
  const saying=SAYINGS[Math.floor(Math.random()*SAYINGS.length)];
  const el=document.getElementById('saying');
  el.textContent=saying;
  // restart animation
  el.style.animation='none';void el.offsetWidth;el.style.animation='';
  document.getElementById('over').classList.add('show');
  // Cycle 2 more sayings then close
  setTimeout(()=>{
    const s2=SAYINGS[Math.floor(Math.random()*SAYINGS.length)];
    el.textContent=s2;
    el.style.animation='none';void el.offsetWidth;el.style.animation='';
  },1100);
  setTimeout(()=>{
    const s3=SAYINGS[Math.floor(Math.random()*SAYINGS.length)];
    el.textContent=s3;
    el.style.animation='none';void el.offsetWidth;el.style.animation='';
  },2200);
  // After 3s try to close, fall back to reset
  setTimeout(()=>{
    try{window.close();}catch(_){}
    // If still here, show reset prompt
  },3000);
}

document.getElementById('over').addEventListener('click',()=>{
  // Reset full state
  document.getElementById('over').classList.remove('show');
  state.shapes.forEach(s=>{if(!s.dead)Composite.remove(eng.world,s.body);});
  state.shapes=[];state.fx=[];state.flow=0;state.hitWater=0;state.missWater=0;state.positiveStreak=0;state.zapPending=false;state.procBonus=false;state.brainShake=0;state.personality={fighter:0,dreamer:0,quitter:0,rebel:0};
  cam.y=0;cam.vy=0;
  document.getElementById('intro').classList.remove('gone');
  document.getElementById('menuBtn').classList.remove('show');
  state.phase=PH.INTRO;
  updHUD();
});

// ---------- Boot screen → Gallery wall ----------
// initSyncBtn is hidden (intro cinematic plays instead). Kept as no-op for safety.
const _initBtn=document.getElementById('initSyncBtn');
if(_initBtn)_initBtn.addEventListener('click',()=>{
  document.getElementById('bootScreen').classList.add('gone');
  document.getElementById('intro').classList.remove('gone');
  refreshIntroBadges();
});

// ---------- Gallery wall category selection ----------
document.querySelectorAll('.gallery-frame[data-cat]').forEach(btn=>{
  btn.addEventListener('click',()=>{
    state.category=btn.dataset.cat;
    document.getElementById('intro').classList.add('gone');
    document.getElementById('menuBtn').classList.add('show');
    setTimeout(()=>{startRound();},400);
  });
});

// ---------- Menu button (opens popup with options) ----------
function returnHome(){
  // Reset everything and show intro (gallery wall, not boot screen)
  state.shapes.forEach(s=>{if(!s.dead)Composite.remove(eng.world,s.body);});
  state.shapes=[];state.fx=[];state.flow=0;state.hitWater=0;state.missWater=0;state.positiveStreak=0;state.zapPending=false;state.procBonus=false;state.brainShake=0;state.personality={fighter:0,dreamer:0,quitter:0,rebel:0};
  state.falling=[];state.choice=[];state.drag=null;state.housing=[];
  cam.y=0;cam.vy=0;
  state.phase=PH.INTRO;
  document.getElementById('over').classList.remove('show');
  // Re-play intro or just show category select (depending on context)
  document.getElementById('intro').classList.remove('gone');
  document.getElementById('bootScreen').classList.add('gone');
  document.getElementById('menuBtn').classList.remove('show');
  document.getElementById('menuPopup').classList.remove('show');
  refreshIntroBadges();
  updHUD();
}
function restartCategory(){
  // Empty the brain but keep the current category
  state.shapes.forEach(s=>{if(!s.dead)Composite.remove(eng.world,s.body);});
  state.shapes=[];state.fx=[];state.flow=0;state.hitWater=0;state.missWater=0;state.positiveStreak=0;state.zapPending=false;state.procBonus=false;state.brainShake=0;state.personality={fighter:0,dreamer:0,quitter:0,rebel:0};
  state.falling=[];state.choice=[];state.drag=null;
  cam.y=0;cam.vy=0;
  document.getElementById('over').classList.remove('show');
  document.getElementById('menuPopup').classList.remove('show');
  startRound();
}
// Helper: attach handler to both tap (touchend) and click for reliable mobile + desktop
function tapHandler(el,fn){
  let touched=false;
  el.addEventListener('touchstart',(e)=>{e.stopPropagation();},{passive:true});
  el.addEventListener('touchend',(e)=>{
    e.stopPropagation();e.preventDefault();
    touched=true;
    fn(e);
    setTimeout(()=>{touched=false;},400);
  },{passive:false});
  el.addEventListener('click',(e)=>{
    e.stopPropagation();
    if(touched)return;
    fn(e);
  });
}

tapHandler(document.getElementById('menuBtn'),()=>{
  document.getElementById('menuPopup').classList.add('show');
});
tapHandler(document.getElementById('goHomeBtn'),()=>{
  returnHome();
});
tapHandler(document.getElementById('restartBtn'),()=>{
  restartCategory();
});
tapHandler(document.getElementById('menuClose'),()=>{
  document.getElementById('menuPopup').classList.remove('show');
});
document.getElementById('menuPopup').addEventListener('click',(e)=>{
  if(e.target.id==='menuPopup'){
    document.getElementById('menuPopup').classList.remove('show');
  }
});


// ---------- Background music engine ----------
// To add more tracks: drop files into www/audio/ and add their paths to TRACKS.
// If the files can't be found (standalone HTML without the audio/ folder),
// the game automatically falls back to a procedural ambient soundtrack.
const TRACKS=['audio/audio.mp3','audio/forest_gump.mp3','audio/janet.mp3'];

const bgMusic=document.getElementById('bgMusic');
let currentTrackIdx=0;
let musicStarted=false;
let proceduralMode=false; // true when we've switched to generated music

// ---------- Web Audio analyser (for music-reactive flow bar) ----------
let audioCtx=null,audioAnalyser=null,audioBuf=null;
let audioLevel=0;

function setupAudioAnalyser(){
  if(audioCtx)return;
  try{
    const AC=window.AudioContext||window.webkitAudioContext;
    if(!AC)return;
    audioCtx=new AC();
    const src=audioCtx.createMediaElementSource(bgMusic);
    audioAnalyser=audioCtx.createAnalyser();
    audioAnalyser.fftSize=128;
    audioAnalyser.smoothingTimeConstant=0.78;
    src.connect(audioAnalyser);
    audioAnalyser.connect(audioCtx.destination);
    audioBuf=new Uint8Array(audioAnalyser.frequencyBinCount);
  }catch(e){
    console.warn('Audio analyser unavailable:',e);
  }
}

// ---------- Procedural ambient fallback (plays when MP3 files are missing) ----------
// Vaporwave pad: 4-note chords, sine waves, slow cross-fade, tremolo LFO.
// Feeds directly into the same analyser so music-reactive visuals still work.
let _procCtx=null,_procAnalyser=null,_procBuf=null;
let _procOscs=[],_procInterval=null;

// Chord progression: Fmaj7 → Dmin7 → Bbmaj7 → Cmaj7 (cycle every 5s)
const _CHORDS=[
  [87.31,130.81,164.81,220.00],  // F2–C3–E3–A3  (Fmaj7)
  [73.42,110.00,130.81,174.61],  // D2–A2–C3–F3  (Dmin7)
  [58.27,116.54,146.83,174.61],  // Bb1–Bb2–D3–F3 (Bbmaj7)
  [65.41, 98.00,164.81,196.00],  // C2–G2–E3–G3  (Cmaj7)
];
let _chordIdx=0;

function _startProceduralMusic(){
  if(_procCtx)return;
  const AC=window.AudioContext||window.webkitAudioContext;
  if(!AC)return;
  proceduralMode=true;
  _procCtx=new AC();

  // Master chain: oscillators → gain → analyser → destination
  const master=_procCtx.createGain();
  master.gain.value=0; // fade in
  master.gain.linearRampToValueAtTime(0.22, _procCtx.currentTime+2.5);

  // Warm low-pass filter
  const lpf=_procCtx.createBiquadFilter();
  lpf.type='lowpass'; lpf.frequency.value=640; lpf.Q.value=0.6;

  // Tremolo LFO (slow 0.25 Hz wobble for that vaporwave feel)
  const lfo=_procCtx.createOscillator();
  const lfoGain=_procCtx.createGain();
  lfo.frequency.value=0.25; lfo.type='sine';
  lfoGain.gain.value=0.08;
  lfo.connect(lfoGain); lfo.start();

  // Analyser (so audioLevel reads from procedural music too)
  _procAnalyser=_procCtx.createAnalyser();
  _procAnalyser.fftSize=128;
  _procAnalyser.smoothingTimeConstant=0.78;
  _procBuf=new Uint8Array(_procAnalyser.frequencyBinCount);

  lpf.connect(master);
  lfoGain.connect(master.gain);
  master.connect(_procAnalyser);
  _procAnalyser.connect(_procCtx.destination);

  function playChord(freqs){
    // Fade out previous
    _procOscs.forEach(({o,g})=>{
      g.gain.setTargetAtTime(0,_procCtx.currentTime,0.6);
      o.stop(_procCtx.currentTime+3);
    });
    _procOscs=[];
    // Fade in new
    freqs.forEach((freq,i)=>{
      const o=_procCtx.createOscillator();
      const g=_procCtx.createGain();
      o.type='sine';
      o.frequency.value=freq;
      o.detune.value=(Math.random()-0.5)*10; // subtle detune for thickness
      g.gain.value=0;
      g.gain.setTargetAtTime(0.28/(freqs.length), _procCtx.currentTime, 1.4);
      o.connect(g); g.connect(lpf);
      o.start(); _procOscs.push({o,g});
      // Add a gentle 2nd harmonic at lower volume for richness
      const o2=_procCtx.createOscillator();
      const g2=_procCtx.createGain();
      o2.type='sine'; o2.frequency.value=freq*2; o2.detune.value=6;
      g2.gain.value=0;
      g2.gain.setTargetAtTime(0.06/(freqs.length), _procCtx.currentTime, 2.0);
      o2.connect(g2); g2.connect(lpf);
      o2.start(); _procOscs.push({o:o2,g:g2});
    });
  }

  playChord(_CHORDS[_chordIdx]);
  _procInterval=setInterval(()=>{
    _chordIdx=(_chordIdx+1)%_CHORDS.length;
    playChord(_CHORDS[_chordIdx]);
  },5200);

  musicStarted=true;
  console.log('Procedural ambient music started (MP3 files not found)');
}

// Override sampleAudioLevel to also read from procedural analyser
const _origSample=typeof sampleAudioLevel!=='undefined'?null:null; // placeholder
function _sampleProcLevel(){
  if(!_procAnalyser||!_procBuf)return;
  _procAnalyser.getByteFrequencyData(_procBuf);
  let sum=0,wsum=0;
  for(let i=0;i<_procBuf.length;i++){
    const w=i<_procBuf.length/2?1.4:0.6;
    sum+=_procBuf[i]*w; wsum+=w;
  }
  const raw=sum/(wsum*255);
  audioLevel=audioLevel*0.55+raw*0.45;
}

// Detect audio file load failure → switch to procedural
bgMusic.addEventListener('error',()=>{
  if(!musicStarted&&audioSettings.enabled){
    console.warn('MP3 files not found, switching to procedural music');
    // Will start on first user interaction (audio context needs a gesture)
    proceduralMode=true; // flag it now so tryStartMusic routes correctly
  }
});
// Also catch stalled / empty src situations
bgMusic.addEventListener('stalled',()=>{
  if(!musicStarted) setTimeout(()=>{ if(!musicStarted) proceduralMode=true; },2000);
});

// Proactively test if the first track actually exists using a HEAD request
// If it 404s immediately set proceduralMode so the first tap starts synth music
fetch(TRACKS[0],{method:'HEAD'}).catch(()=>{
  proceduralMode=true;
});
function sampleAudioLevel(){
  // Route to procedural analyser when in fallback mode
  if(proceduralMode){ _sampleProcLevel(); return; }
  if(!audioAnalyser||!audioBuf)return;
  audioAnalyser.getByteFrequencyData(audioBuf);
  let sum=0,wsum=0;
  for(let i=0;i<audioBuf.length;i++){
    const w=i<audioBuf.length/2?1.4:0.6;
    sum+=audioBuf[i]*w;wsum+=w;
  }
  const raw=sum/(wsum*255);
  audioLevel=audioLevel*0.6+raw*0.4;
}
// Apply the current audio level to the flow bar AND the neural background.
// More dramatic music-lock: bar pulses hot (cyan→magenta→white at peaks),
// neurons glow brighter and connection threshold expands on beat, brain outline
// breathes with the music.
let _audioNeuronBoost=0; // shared with bg() to pulse connections
function applyMusicVisuals(){
  const fillEl=document.getElementById('fill');
  if(!fillEl)return;
  const lvl=audioLevel;
  // Hard-clamp a "beat" value — spikes to 1 on loud transients, decays
  _audioNeuronBoost=Math.max(_audioNeuronBoost*0.88, lvl*1.4);

  // Color chain: cyan → violet → white as level rises
  let r,g,b;
  if(lvl<0.45){
    // cyan → violet
    const p=lvl/0.45;
    r=Math.round(79+p*120);   // 79→199
    g=Math.round(195-p*80);   // 195→115
    b=Math.round(247-p*10);   // 247→237
  }else{
    // violet → near-white
    const p=(lvl-0.45)/0.55;
    r=Math.round(199+p*56);   // 199→255
    g=Math.round(115+p*130);  // 115→245
    b=Math.round(237+p*18);   // 237→255
  }
  const col=`rgb(${r},${g},${b})`;

  // Glow massively stronger at high levels
  const glow=8+lvl*80;
  const haloA=0.15+lvl*0.85;
  const bloom=lvl>0.6?` 0 0 ${glow*6}px rgba(${r},${g},${b},${(lvl-0.6)*0.9}),`:' ';
  fillEl.style.background=`linear-gradient(90deg,${col},rgba(${Math.min(255,r+30)},${Math.min(255,g+30)},${b},0.9))`;
  fillEl.style.boxShadow=
    `0 0 ${glow}px ${col},`+
    `0 0 ${glow*2.5}px rgba(${r},${g},${b},${haloA*0.55}),`+
    `0 0 ${glow*5}px rgba(${r},${g},${b},${haloA*0.22}),`+
    bloom+
    `inset 0 0 ${4+lvl*8}px rgba(255,255,255,${0.08+lvl*0.18})`;
  fillEl.style.filter=`brightness(${1+lvl*0.9}) saturate(${1+lvl*0.90}) contrast(${1+lvl*0.2})`;

  // Height pulse — bar breathes with the music
  const barH=3+Math.round(lvl*9);
  const barEl=document.getElementById('bar');
  if(barEl){barEl.style.height=barH+'px';}

  // Push neural background neurons to glow with the beat
  if(lvl>0.35&&bgNeurons.length){
    const boost=_audioNeuronBoost;
    // Boost a random subset each frame rather than all at once (looks more organic)
    const n=Math.ceil(bgNeurons.length*boost*0.4);
    for(let i=0;i<n;i++){
      const idx=Math.floor(Math.random()*bgNeurons.length);
      bgNeurons[idx].glow=Math.min(0.9,bgNeurons[idx].glow+boost*0.5);
    }
  }

  // Canvas-side mini waveform (stored for drawAudioWave())
  _audioWaveLvl=lvl;
}
let _audioWaveLvl=0;
// Called from loop() in screen space (no cam transform)
function drawAudioWave(){
  if(!audioAnalyser||!audioBuf)return;
  audioAnalyser.getByteFrequencyData(audioBuf);
  const barY=H-28; // just above the bottom HUD area
  const barW=W*0.55;
  const barX=(W-barW)/2;
  const bins=Math.min(32,audioBuf.length);
  const bw=barW/bins;
  const lvl=_audioWaveLvl;
  const r=Math.round(79+lvl*176),g=Math.round(195-lvl*45),b=Math.round(247-lvl*90);
  cx.save();
  cx.globalAlpha=0.65+lvl*0.35;
  cx.shadowColor=`rgb(${r},${g},${b})`;
  cx.shadowBlur=8+lvl*12;
  for(let i=0;i<bins;i++){
    const val=audioBuf[i]/255;
    const bh=Math.max(2,val*22);
    const grd=cx.createLinearGradient(0,barY-bh,0,barY);
    grd.addColorStop(0,`rgba(${r},${g},${b},${0.9})`);
    grd.addColorStop(1,`rgba(${r},${g},${b},0.1)`);
    cx.fillStyle=grd;
    cx.fillRect(barX+i*bw+1,barY-bh,bw-2,bh);
  }
  cx.restore();
}

// Load persisted settings (or set defaults)
function loadAudioSettings(){
  try{
    const raw=localStorage.getItem('mre_audio_v1');
    if(!raw)return{volume:0.5,enabled:true};
    return JSON.parse(raw);
  }catch(e){return{volume:0.5,enabled:true};}
}
function saveAudioSettings(s){
  try{localStorage.setItem('mre_audio_v1',JSON.stringify(s));}catch(e){}
}
const audioSettings=loadAudioSettings();
bgMusic.volume=audioSettings.volume;

// When a track ends, rotate to the next one (if multiple exist)
bgMusic.addEventListener('ended',()=>{
  if(TRACKS.length>1){
    currentTrackIdx=(currentTrackIdx+1)%TRACKS.length;
    bgMusic.src=TRACKS[currentTrackIdx];
    bgMusic.play().catch(()=>{});
  }
});
// If only one track, loop attribute on <audio> handles it. With multiple, we disable loop:
if(TRACKS.length>1)bgMusic.loop=false;

// Browsers block autoplay until first user gesture - start music on first interaction
function tryStartMusic(){
  if(musicStarted||!audioSettings.enabled)return;
  if(proceduralMode){ 
    // Flagged as no-MP3 — start synth music on first user gesture
    if(!_procCtx) _startProceduralMusic();
    else if(_procCtx.state==='suspended')_procCtx.resume().catch(()=>{});
    return;
  }
  setupAudioAnalyser();
  if(audioCtx&&audioCtx.state==='suspended')audioCtx.resume().catch(()=>{});
  bgMusic.play().then(()=>{
    musicStarted=true;
  }).catch(()=>{
    // File load likely failed — start procedural fallback
    if(!proceduralMode&&audioSettings.enabled) _startProceduralMusic();
  });
}
// Hook into first tap anywhere
['touchstart','mousedown','keydown'].forEach(evt=>{
  document.addEventListener(evt,tryStartMusic,{once:false,passive:true});
});

// ---------- Settings panel wiring ----------
const settingsBtn=document.getElementById('settingsBtn');
const settingsPopup=document.getElementById('settingsPopup');
const settingsClose=document.getElementById('settingsClose');
const musicToggle=document.getElementById('musicToggle');
const volumeSlider=document.getElementById('volumeSlider');
const musicStateLabel=document.getElementById('musicStateLabel');
const volumeLabel=document.getElementById('volumeLabel');

// Apply persisted settings to UI
musicToggle.checked=audioSettings.enabled;
musicStateLabel.textContent=audioSettings.enabled?'on':'off';
volumeSlider.value=Math.round(audioSettings.volume*100);
volumeLabel.textContent=Math.round(audioSettings.volume*100)+'%';

// Open settings from menu
settingsBtn.addEventListener('click',()=>{
  document.getElementById('menuPopup').classList.remove('show');
  settingsPopup.classList.add('show');
});
// Close settings
settingsClose.addEventListener('click',()=>{
  settingsPopup.classList.remove('show');
});

// Toggle music on/off
musicToggle.addEventListener('change',()=>{
  audioSettings.enabled=musicToggle.checked;
  musicStateLabel.textContent=audioSettings.enabled?'on':'off';
  saveAudioSettings(audioSettings);
  if(audioSettings.enabled){
    if(proceduralMode){
      if(_procCtx)_procCtx.resume().catch(()=>{});
    }else{
      bgMusic.play().then(()=>{musicStarted=true;}).catch(()=>{ _startProceduralMusic(); });
    }
  }else{
    if(proceduralMode){ if(_procCtx)_procCtx.suspend().catch(()=>{}); }
    else bgMusic.pause();
  }
});
// Volume slider
volumeSlider.addEventListener('input',()=>{
  const v=parseInt(volumeSlider.value,10);
  audioSettings.volume=v/100;
  bgMusic.volume=audioSettings.volume;
  volumeLabel.textContent=v+'%';
  saveAudioSettings(audioSettings);
});

// Pause music when tab is hidden (saves battery, respects user)
document.addEventListener('visibilitychange',()=>{
  if(proceduralMode){
    if(_procCtx){
      if(document.hidden) _procCtx.suspend().catch(()=>{});
      else _procCtx.resume().catch(()=>{});
    }
    return;
  }
  if(document.hidden){
    if(!bgMusic.paused)bgMusic.pause();
  }else if(audioSettings.enabled&&musicStarted){
    bgMusic.play().catch(()=>{});
  }
});


// ---------- PROCRASTINATE button ----------
// "Kicking the can down the road" — clears 2 of the heaviest existing negatives
// but immediately spawns 5 new ones falling into the brain. Net cost: +3 thoughts.
// Disabled briefly after each press to prevent spam.
const PROC_COOLDOWN_MS=2500;
function procrastinate(){
  if(state.procCooldown>0)return;
  if(state.phase===PH.INTRO||state.phase===PH.FULL)return;
  // 1) Find the 2 largest existing negatives by physics body area (proxy for "big ones")
  const lives=state.shapes.filter(s=>!s.dead&&s.kind==='neg');
  // Sort by bounding-box area, biggest first
  lives.sort((a,b)=>{
    const bA=a.body.bounds,bB=b.body.bounds;
    if(!bA||!bB)return 0;
    const areaA=(bA.max.x-bA.min.x)*(bA.max.y-bA.min.y);
    const areaB=(bB.max.x-bB.min.x)*(bB.max.y-bB.min.y);
    return areaB-areaA;
  });
  const toClear=lives.slice(0,2);
  toClear.forEach(s=>dissolve(s));
  // 2) Spawn 5 new negatives from the brain ceiling, spread across the width
  const d=CATEGORY_DATA[state.category];
  for(let i=0;i<5;i++){
    const w=d.words[Math.floor(Math.random()*d.words.length)].name;
    const xJitter=L.BCX+(Math.random()-0.5)*L.BHW*1.4;
    const yStart=L.BT+10;
    setTimeout(()=>{
      // Slight stagger so they don't all collide at the same instant
      spawnShape(w,xJitter,yStart,(Math.random()-0.5)*1.2,0.5);
    },i*70);
  }
  // 3) Visual + audio cue: red screen flash + tiny camera shake
  state.burnoutIntensity=Math.max(state.burnoutIntensity,0.45);
  state.burnoutShake=Math.max(state.burnoutShake,0.35);
  // 4) Grant a 2× positive boost on the NEXT CHOICE round as compensation
  state.procBonus=true;
  // --- Personality scoring: procrastinating is a rebel move ---
  state.personality.rebel+=3;
  // 4) Cooldown UI
  state.procCooldown=PROC_COOLDOWN_MS;
  const pb=document.getElementById('procBtn');
  if(pb)pb.classList.add('cooldown');
  setTimeout(()=>{
    state.procCooldown=0;
    if(pb)pb.classList.remove('cooldown');
  },PROC_COOLDOWN_MS);
}
const procBtn=document.getElementById('procBtn');
if(procBtn){
  procBtn.addEventListener('click',(e)=>{e.preventDefault();procrastinate();});
  procBtn.addEventListener('touchend',(e)=>{e.preventDefault();procrastinate();},{passive:false});
}


// ---------- Boot ----------
addEventListener('resize',()=>{resize();updHUD();});
addEventListener('orientationchange',()=>{resize();updHUD();});
resize();
updHUD();
refreshIntroBadges();
requestAnimationFrame(loop);
</script>
<script>
// Register service worker for offline support (required for PWA installability)
if('serviceWorker' in navigator){
  window.addEventListener('load',()=>{
    navigator.serviceWorker.register('sw.js').catch(err=>{
      console.log('SW registration deferred:',err);
    });
  });
}

// PWA install prompt - capture and offer to user when appropriate
let deferredInstallPrompt=null;
window.addEventListener('beforeinstallprompt',(e)=>{
  e.preventDefault();
  deferredInstallPrompt=e;
});

// Prevent pinch-zoom and double-tap zoom on mobile (game is fixed-viewport)
document.addEventListener('gesturestart',e=>e.preventDefault());
document.addEventListener('gesturechange',e=>e.preventDefault());
let lastTouchEnd=0;
document.addEventListener('touchend',e=>{
  const now=Date.now();
  if(now-lastTouchEnd<=300)e.preventDefault();
  lastTouchEnd=now;
},{passive:false});

// Prevent context menu (long-press) on game canvas for cleaner mobile UX
document.addEventListener('contextmenu',e=>e.preventDefault());

// Lock orientation to portrait if supported
if(screen.orientation&&screen.orientation.lock){
  screen.orientation.lock('portrait').catch(()=>{/* not all browsers allow */});
}

// Wake-lock to keep screen on during gameplay (useful for meditation sessions)
let wakeLock=null;
async function requestWakeLock(){
  if('wakeLock' in navigator){
    try{
      wakeLock=await navigator.wakeLock.request('screen');
    }catch(err){/* ignore */}
  }
}
document.addEventListener('visibilitychange',()=>{
  if(document.visibilityState==='visible'&&wakeLock===null){requestWakeLock();}
});
requestWakeLock();
</script>

</body>
</html>
